/*
 * Conformance Test: Custom Resource instance (Widget CR via K8S::Custom::Resource).
 * The Widget CRD (group example.com) is provisioned out-of-band as a test
 * prerequisite. This fixture exercises the catch-all provisioner's full CRUD
 * lifecycle and discovery against a custom resource instance through formae core.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.33/custom/CustomResource.pkl" as cr
import "@k8s/v1.33/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new cr.CustomResource {
    label = "test-widget"
    apiVersion = "example.com/v1"
    kind = "Widget"
    metadata = new k8s.ObjectMeta {
      name = "widget-\(v.testRunID)"
      namespace = "default"
    }
    spec = new Dynamic {
      size = 7
    }
  }
}
