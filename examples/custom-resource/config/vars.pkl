import "@formae/formae.pkl"
import "@k8s/v1.33/k8s.pkl" as k8s

local stackName = "crd-conformance-stack"

testRunID = read("env:FORMAE_TEST_RUN_ID")

local k8sMinor = "1.33"

stack = new formae.Stack {
  label = stackName
  description = "CRD conformance test stack"
}

target = new formae.Target {
  label = "k8s-target"
  config = new k8s.Config {
    kubernetesVersion = k8sMinor
    auth = new k8s.KubeconfigAuth {}
    customResourceGroups = new { "example.com" }
  }
}
