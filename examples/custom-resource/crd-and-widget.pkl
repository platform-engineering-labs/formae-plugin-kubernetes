/*
 * Deploy a CRD and an instance of it in ONE formae apply — no kubectl.
 *
 * The CRD uses the dedicated K8S::Apiextensions::CustomResourceDefinition type;
 * the Widget uses the generic K8S::Custom::Resource catch-all. formae applies
 * them concurrently, but the CRD provisioner blocks until the CRD is Established
 * and the Widget's apply retries until its kind is served, so the Widget always
 * converges once the CRD exists — no explicit ordering needed.
 *
 *   formae apply --mode reconcile --yes examples/custom-resource/crd-and-widget.pkl
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.33/apiextensions/CustomResourceDefinition.pkl" as crd
import "@k8s/v1.33/custom/CustomResource.pkl" as cr
import "@k8s/v1.33/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new crd.CustomResourceDefinition {
    label = "widget-crd"
    metadata = new k8s.ObjectMeta { name = "widgets.example.com" }
    spec = new Dynamic {
      group = "example.com"
      names = new Dynamic {
        kind = "Widget"; listKind = "WidgetList"; plural = "widgets"; singular = "widget"
      }
      scope = "Namespaced"
      versions = new Listing {
        new Dynamic {
          name = "v1"; served = true; storage = true
          schema = new Dynamic {
            openAPIV3Schema = new Dynamic {
              type = "object"
              properties = new Dynamic {
                spec = new Dynamic {
                  type = "object"
                  properties = new Dynamic { size = new Dynamic { type = "integer" } }
                }
              }
            }
          }
        }
      }
    }
  }

  new cr.CustomResource {
    label = "widget-sample"
    apiVersion = "example.com/v1"
    kind = "Widget"
    metadata = new k8s.ObjectMeta {
      name = "widget-sample"
      namespace = "default"
    }
    spec = new Dynamic { size = 3 }
  }
}
