amends "@formae/forma.pkl"
import "@apps/lgtm/lgtm.pkl" as lgtmApp
import "@formae/formae.pkl"

import "@clusters/dispatch.pkl"

description {
  text = """
    LGTM observability stack on a managed Kubernetes cluster.

    Pick a cloud at apply time with `--provider`. Toggle synthetic demo traffic with `--enable-demo-traffic`:

      formae apply --mode reconcile --provider aws   examples/lgtm/main.pkl
      formae apply --mode reconcile --provider azure --enable-demo-traffic examples/lgtm/main.pkl
      formae apply --mode reconcile --provider local examples/lgtm/main.pkl

    Deploys Grafana + Loki + Tempo + Mimir + OpenTelemetry collector + MinIO (~25 pods). Each data-plane service runs in Simple Scalable mode (3 independently-scaled Deployments per service). Fits a 4 CPU / 8Gi cluster.

    Access Grafana (ClusterIP service, port-forward from local):
      kubectl -n observability port-forward svc/grafana 3000:80
      open http://localhost:3000   # anonymous Admin

    MinIO console:
      kubectl -n observability port-forward svc/minio-console 9001
      open http://localhost:9001   # minioadmin / minioadmin-change-me

    Set `--enable-demo-traffic` to false (or omit) once you wire real workloads up to the OTel gateway, so dashboards show only genuine traffic.

    Teardown:
      formae destroy --yes --provider <p> examples/lgtm/main.pkl
    """
  confirm = true
}

properties {
  provider = new formae.Prop {
    flag = "provider"
    default = read?("env:FORMAE_PROVIDER") ?? "aws"
  }
  enableDemoTraffic = new formae.Prop {
    flag = "enable-demo-traffic"
    default = false
  }
}

local providerName = properties.provider.value as String

local stack: formae.Stack = new {
  label = "k8s-lgtm-\(providerName)"
  description = "LGTM observability stack on a managed Kubernetes cluster (\(providerName))."
}

local cloud = dispatch.For(providerName)

local lgtm = new {
  resources = lgtmApp.allResources(
    cloud.target,
    properties.enableDemoTraffic.value as Boolean
  )
}

forma {
  stack

  ...cloud.resources
  cloud.target

  ...lgtm.resources
}
