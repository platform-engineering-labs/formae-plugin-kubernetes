// Vanilla K8S example — bookstore on any kubeconfig-accessible cluster
//
// Deploys the bookstore webapp to a local or pre-configured K8S cluster
// using kubeconfig auth. No cloud provider required.
//
// Deploy (default kubeconfig context):
//   formae apply --mode reconcile --yes --watch examples/vanilla/vanilla.pkl
//
// Deploy (specific context):
//   formae apply --mode reconcile --yes --watch examples/vanilla/vanilla.pkl
//
// Access:
//   kubectl -n bookstore port-forward svc/bookstore-frontend 8080:80
//   open http://localhost:8080
//
// Teardown:
//   formae destroy --yes examples/vanilla/vanilla.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s
import "@apps/bookstore.pkl" as bookstore

local _k8sTarget = new formae.Target {
  label = "k8s-target"
  namespace = "K8S"
  config = new k8s.Config {
    auth = new k8s.KubeconfigAuth {}
  }
}

forma {
  new formae.Stack {
    label = "bookstore-stack"
    description = "Bookstore webapp on vanilla K8S"
  }

  _k8sTarget

  for (r in bookstore.allResources(_k8sTarget)) { r }
}
