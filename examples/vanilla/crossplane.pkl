// Vanilla K8S example — Crossplane core on any kubeconfig-accessible cluster
//
// Deploys the Crossplane control plane (Namespace, RBAC, Deployment,
// Service, 14 CRDs) to a local or pre-configured K8S cluster using
// kubeconfig auth. No cloud provider required.
//
// Resolve Pkl dependencies (first time, or after PklProject changes):
//   pkl project resolve examples/apps/
//   pkl project resolve examples/vanilla/
//
// Deploy:
//   formae apply --mode reconcile --yes --watch examples/vanilla/crossplane.pkl
//
// Verify:
//   kubectl -n crossplane-system get pods
//   kubectl get crds | grep crossplane
//   kubectl -n crossplane-system logs deploy/crossplane
//
// Install a provider (optional — example only, not managed by formae):
//   kubectl apply -f - <<EOF
//   apiVersion: pkg.crossplane.io/v1
//   kind: Provider
//   metadata:
//     name: provider-kubernetes
//   spec:
//     package: xpkg.crossplane.io/crossplane-contrib/provider-kubernetes:v0.14.0
//   EOF
//
// Teardown:
//   formae destroy --yes examples/vanilla/crossplane.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s
import "@apps/crossplane.pkl" as crossplane

local _k8sTarget = new formae.Target {
  label = "k8s-target"
  config = new k8s.Config {
    kubernetesVersion = "1.34"
    auth = new k8s.KubeconfigAuth {}
  }
}

forma {
  new formae.Stack {
    label = "crossplane-stack"
    description = "Crossplane core on vanilla K8S"
  }

  _k8sTarget

  for (r in crossplane.allResources(_k8sTarget)) { r }
}
