/*
 * Example: Full-stack web application
 *
 * Deploys a frontend (nginx) and backend (API) with:
 *   - Dedicated namespace
 *   - ConfigMap for backend configuration
 *   - Secret for database credentials
 *   - ServiceAccount for the backend
 *   - Deployments for frontend and backend
 *   - Services to expose both internally
 *   - Ingress to route external traffic
 *
 * Prerequisites:
 *   formae apply examples/nginx-ingress.pkl   # deploy ingress controller (once per cluster)
 *
 * Deploy:
 *   formae apply examples/webapp.pkl
 *
 * Access (port-forward, no ingress controller needed):
 *   kubectl -n bookstore port-forward svc/bookstore-frontend 8080:80   # http://localhost:8080
 *   kubectl -n bookstore port-forward svc/bookstore-backend 3000:80    # http://localhost:3000
 *
 * Access (via ingress, requires nginx-ingress.pkl deployed):
 *   # Add to /etc/hosts:
 *   127.0.0.1 bookstore.example.com
 *   # Then browse:
 *   http://bookstore.example.com/       -> frontend
 *   http://bookstore.example.com/api    -> backend API
 *
 * Teardown:
 *   formae destroy examples/webapp.pkl
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/core/Namespace.pkl" as ns
import "@formae-plugin-k8s/core/ConfigMap.pkl" as cm
import "@formae-plugin-k8s/core/Secret.pkl" as sec
import "@formae-plugin-k8s/core/Service.pkl" as svc
import "@formae-plugin-k8s/core/ServiceAccount.pkl" as sa
import "@formae-plugin-k8s/apps/Deployment.pkl" as dep
import "@formae-plugin-k8s/networking/Ingress.pkl" as ing
import "@formae-plugin-k8s/k8s.pkl" as k8s

// ---------------------------------------------------------------------------
// Configuration — change these values to customize the deployment
// ---------------------------------------------------------------------------
local appName = "bookstore"
local domain = "bookstore.example.com"

local frontendImage = "nginx:1.27-alpine"
local frontendReplicas = 2

local backendImage = "node:22-alpine"
local backendReplicas = 3

local dbHost = "postgres.database.svc.cluster.local"
local dbName = "bookstore"
local dbUser = "bookstore-app"
local dbPassword = "change-me-in-production"

// ---------------------------------------------------------------------------
// Shared labels
// ---------------------------------------------------------------------------
local commonLabels = new Mapping {
  ["app"] = appName
  ["managed-by"] = "formae"
}

local frontendLabels = new Mapping {
  ...commonLabels
  ["component"] = "frontend"
}

local backendLabels = new Mapping {
  ...commonLabels
  ["component"] = "backend"
}

// ---------------------------------------------------------------------------
// Stack & Target
// ---------------------------------------------------------------------------
forma {
  new formae.Stack {
    label = "\(appName)-stack"
    description = "Bookstore web application"
  }

  new formae.Target {
    label = "\(appName)-target"
    namespace = "K8S"
    config = new k8s.Config {
      waitForLoadBalancer = false
    }
  }

  // -------------------------------------------------------------------------
  // Namespace
  // -------------------------------------------------------------------------
  local appNs = new ns.Namespace {
    label = "\(appName)-ns"
    metadata = new ns.NamespaceMetadata {
      name = appName
      labels = commonLabels
    }
  }

  appNs

  // -------------------------------------------------------------------------
  // ConfigMap — frontend nginx config (proxies /api to backend)
  // -------------------------------------------------------------------------
  new cm.ConfigMap {
    label = "\(appName)-frontend-config"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend-config"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    data = new Mapping {
      ["default.conf"] = new Listing {
        "server {"
        "    listen 80;"
        "    server_name _;"
        ""
        "    location /api {"
        "        proxy_pass http://\(appName)-backend;"
        "        proxy_set_header Host $host;"
        "        proxy_set_header X-Real-IP $remote_addr;"
        "    }"
        ""
        "    location / {"
        "        root /usr/share/nginx/html;"
        "        index index.html;"
        "    }"
        "}"
      }.join("\n")
      ["index.html"] = new Listing {
        "<!DOCTYPE html>"
        "<html><head>"
        "  <title>Bookstore</title>"
        "  <style>"
        "    body { font-family: system-ui, sans-serif; max-width: 600px; margin: 60px auto; padding: 0 20px; }"
        "    h1 { border-bottom: 2px solid #333; padding-bottom: 10px; }"
        "    code { background: #f4f4f4; padding: 2px 6px; border-radius: 3px; }"
        "    #api-result { background: #f4f4f4; padding: 16px; border-radius: 6px; white-space: pre; font-family: monospace; }"
        "  </style>"
        "</head><body>"
        "  <h1>Bookstore</h1>"
        "  <p>Frontend served by <strong>nginx</strong>. Backend API at <code>/api</code>.</p>"
        "  <h2>API Response</h2>"
        "  <div id=\"api-result\">Loading...</div>"
        "  <script>"
        "    fetch('/api').then(r=>r.json()).then(d=>{"
        "      document.getElementById('api-result').textContent=JSON.stringify(d,null,2)"
        "    }).catch(e=>{"
        "      document.getElementById('api-result').textContent='Error: '+e.message"
        "    })"
        "  </script>"
        "</body></html>"
      }.join("\n")
    }
  }

  // -------------------------------------------------------------------------
  // ConfigMap — backend application config
  // -------------------------------------------------------------------------
  new cm.ConfigMap {
    label = "\(appName)-backend-config"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend-config"
      namespace = appNs.res.name
      labels = backendLabels
    }
    data = new Mapping {
      ["DB_HOST"] = dbHost
      ["DB_NAME"] = dbName
      ["DB_PORT"] = "5432"
      ["LOG_LEVEL"] = "info"
      ["PORT"] = "3000"
    }
  }

  // -------------------------------------------------------------------------
  // Secret — database credentials
  // -------------------------------------------------------------------------
  new sec.Secret {
    label = "\(appName)-db-credentials"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-db-credentials"
      namespace = appNs.res.name
      labels = backendLabels
    }
    type = "Opaque"
    stringData = new Mapping {
      ["DB_USER"] = dbUser
      ["DB_PASSWORD"] = dbPassword
    }
  }

  // -------------------------------------------------------------------------
  // ServiceAccount — backend identity
  // -------------------------------------------------------------------------
  new sa.ServiceAccount {
    label = "\(appName)-backend-sa"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    automountServiceAccountToken = false
  }

  // -------------------------------------------------------------------------
  // Deployment — frontend (nginx with custom config + HTML)
  // -------------------------------------------------------------------------
  new dep.Deployment {
    label = "\(appName)-frontend"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    spec = new dep.DeploymentSpec {
      replicas = frontendReplicas
      selector = new k8s.LabelSelector {
        matchLabels = frontendLabels
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.PodTemplateMetadata {
          labels = frontendLabels
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "nginx"
              image = frontendImage
              ports = new Listing {
                new k8s.ContainerPort {
                  name = "http"
                  containerPort = 80
                }
              }
              volumeMounts = new Listing {
                new k8s.VolumeMount {
                  name = "nginx-config"
                  mountPath = "/etc/nginx/conf.d"
                  readOnly = true
                }
                new k8s.VolumeMount {
                  name = "html"
                  mountPath = "/usr/share/nginx/html"
                  readOnly = true
                }
              }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping {
                  ["cpu"] = "50m"
                  ["memory"] = "64Mi"
                }
                limits = new Mapping {
                  ["cpu"] = "200m"
                  ["memory"] = "128Mi"
                }
              }
            }
          }
          volumes = new Listing {
            new k8s.Volume {
              name = "nginx-config"
              configMap = new k8s.ConfigMapVolumeSource {
                name = "\(appName)-frontend-config"
                items = new Listing {
                  new k8s.KeyToPath { key = "default.conf"; path = "default.conf" }
                }
              }
            }
            new k8s.Volume {
              name = "html"
              configMap = new k8s.ConfigMapVolumeSource {
                name = "\(appName)-frontend-config"
                items = new Listing {
                  new k8s.KeyToPath { key = "index.html"; path = "index.html" }
                }
              }
            }
          }
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Deployment — backend (Node.js API)
  // -------------------------------------------------------------------------
  new dep.Deployment {
    label = "\(appName)-backend"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    spec = new dep.DeploymentSpec {
      replicas = backendReplicas
      selector = new k8s.LabelSelector {
        matchLabels = backendLabels
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.PodTemplateMetadata {
          labels = backendLabels
        }
        spec = new k8s.PodSpec {
          serviceAccountName = "\(appName)-backend"
          containers = new Listing {
            new k8s.Container {
              name = "api"
              image = backendImage
              command = new Listing { "node"; "-e" }
              args = new Listing {
                #"require("http").createServer((req,res)=>{res.writeHead(200,{"Content-Type":"application/json"});res.end(JSON.stringify({status:"ok",path:req.url,ts:new Date().toISOString()}))}).listen(3000,()=>console.log("API listening on :3000"))"#
              }
              ports = new Listing {
                new k8s.ContainerPort {
                  name = "http"
                  containerPort = 3000
                }
              }
              env = new Listing {
                new k8s.EnvVar { name = "NODE_ENV"; value = "production" }
              }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping {
                  ["cpu"] = "100m"
                  ["memory"] = "128Mi"
                }
                limits = new Mapping {
                  ["cpu"] = "500m"
                  ["memory"] = "256Mi"
                }
              }
            }
          }
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Service — frontend (ClusterIP, exposed via Ingress)
  // -------------------------------------------------------------------------
  new svc.Service {
    label = "\(appName)-frontend-svc"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    spec = new svc.ServiceSpec {
      selector = frontendLabels
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          targetPort = 80
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Service — backend (ClusterIP, internal + exposed via Ingress)
  // -------------------------------------------------------------------------
  new svc.Service {
    label = "\(appName)-backend-svc"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    spec = new svc.ServiceSpec {
      selector = backendLabels
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          targetPort = 3000
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Ingress — route traffic: / -> frontend, /api -> backend
  // -------------------------------------------------------------------------
  new ing.Ingress {
    label = "\(appName)-ingress"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-ingress"
      namespace = appNs.res.name
      labels = commonLabels
    }
    spec = new ing.IngressSpec {
      ingressClassName = "nginx"
      rules = new Listing {
        new ing.IngressRule {
          host = domain
          http = new ing.HTTPIngressRuleValue {
            paths = new Listing {
              new ing.HTTPIngressPath {
                path = "/api"
                pathType = "Prefix"
                backend = new ing.IngressBackend {
                  service = new ing.IngressServiceBackend {
                    name = "\(appName)-backend"
                    port = new ing.ServiceBackendPort {
                      number = 80
                    }
                  }
                }
              }
              new ing.HTTPIngressPath {
                path = "/"
                pathType = "Prefix"
                backend = new ing.IngressBackend {
                  service = new ing.IngressServiceBackend {
                    name = "\(appName)-frontend"
                    port = new ing.ServiceBackendPort {
                      number = 80
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
