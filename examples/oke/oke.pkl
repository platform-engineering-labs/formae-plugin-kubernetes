// OKE end-to-end example
//
// Provisions a full OKE cluster on Oracle Cloud (VCN, subnets, gateways,
// route tables, security lists, OKE cluster + node pool), then deploys the
// bookstore webapp using OCIAuth with Resolvable references.
//
// Prerequisites:
//   - OCI CLI configured with valid credentials (oci session authenticate)
//   - formae-plugin-oci and formae-plugin-k8s installed
//   - Replace default prop values in infrastructure/vars.pkl with your
//     compartmentId, availabilityDomain, nodeImageId, and serviceGatewayServiceId
//
// Deploy:
//   formae apply --mode reconcile --yes --watch examples/oke/oke.pkl
//
// Access (after deploy, via port-forward):
//   oci ce cluster create-kubeconfig --cluster-id <cluster-ocid> --region us-chicago-1
//   kubectl -n bookstore port-forward svc/bookstore-frontend 8080:80
//   open http://localhost:8080
//
// Teardown:
//   formae destroy --yes examples/oke/oke.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "./infrastructure/vars.pkl"
import "./infrastructure/vcn.pkl"
import "./infrastructure/security.pkl"
import "./infrastructure/network.pkl"
import "./infrastructure/oke.pkl"

import "@apps/bookstore.pkl" as bookstore
import "@k8s/k8s.pkl" as k8s


local _vcn = new vcn.VcnResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  vcnCidr = vars.vcnCidr
}

local _security = new security.SecurityResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  serviceLbSubnetCidr = vars.serviceLbSubnetCidr
  workerNodeSubnetCidr = vars.workerNodeSubnetCidr
  vcn = _vcn.vcn
}

local _network = new network.NetworkResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  serviceLbSubnetCidr = vars.serviceLbSubnetCidr
  workerNodeSubnetCidr = vars.workerNodeSubnetCidr
  serviceGatewayServiceId = vars.props.serviceGatewayServiceId.value
  vcn = _vcn.vcn
  securityList = _security.securityList
}

local _oke = new oke.OkeResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  k8sVersion = vars.k8sVersion
  vmShape = vars.vmShape
  nodeOcpus = vars.nodeOcpus
  nodeMemoryGBs = vars.nodeMemoryGBs
  nodePoolSize = vars.nodePoolSize
  availabilityDomain = vars.props.availabilityDomain.value
  nodeImageId = vars.props.nodeImageId.value
  vcn = _vcn.vcn
  svcLbSubnet = _network.svcLbSubnet
  workerSubnet = _network.workerSubnet
}


local _okeCluster = _oke.okeCluster

local _k8sTarget = new formae.Target {
  label = "k8s-target"
  config = new k8s.Config {
    // Major.minor of vars.k8sVersion. Keep in sync when bumping the
    // OCI cluster's k8sVersion (currently v1.34.3 → 1.34).
    kubernetesVersion = "1.34"
    auth = new k8s.OCIAuth {
      endpoint = _okeCluster.res.endpoint
      certificateAuthority = _okeCluster.res.certificateAuthority
      clusterOcid = _okeCluster.res.id
    }
  }
}


properties = vars.props


description {
  text = """
    OKE Full-Stack Example - Oracle Kubernetes Engine + Bookstore

    This example creates:
    - VCN with public (service LB) and private (worker nodes) subnets
    - Internet Gateway, NAT Gateway, and Service Gateway
    - Public and Private Route Tables
    - Security Lists for OKE networking
    - OKE Cluster with public API endpoint
    - Node Pool with flexible VM shapes (E4.Flex)
    - Bookstore webapp (frontend + backend) deployed via K8s

    Prerequisites:
    - OCI CLI configured (oci session authenticate)
    - formae-plugin-oci and formae-plugin-k8s installed
    - Set --prop compartmentId=ocid1.compartment.oc1..xxx
    """
  confirm = true
}


forma {
  vars.stack
  vars.target

  // OCI infrastructure
  ..._vcn.resources
  ..._security.resources
  ..._network.resources
  ..._oke.resources

  // K8s target (resolves endpoint + CA from OKE)
  _k8sTarget

  // Bookstore webapp
  for (r in bookstore.allResources(_k8sTarget)) { r }
}
