amends "@formae/forma.pkl"
import "@apps/crossplane.pkl" as crossplaneApp
import "@formae/formae.pkl"

import "@clusters/dispatch.pkl"

description {
  text = """
    Crossplane control plane on a managed Kubernetes cluster.

    Pick a cloud at apply time with `--provider`:

      formae apply --mode reconcile --provider aws   examples/crossplane/main.pkl
      formae apply --mode reconcile --provider azure examples/crossplane/main.pkl
      formae apply --mode reconcile --provider gcp   examples/crossplane/main.pkl
      formae apply --mode reconcile --provider oci   examples/crossplane/main.pkl
      formae apply --mode reconcile --provider local examples/crossplane/main.pkl

    Deploys Crossplane core (Namespace, RBAC, Deployment, Service). Crossplane's init container installs its CRDs (Provider, Configuration, Composition, ...) at first start. Those are NOT managed by formae, since Crossplane mutates them at runtime and a drift-reconcile loop would fight those mutations.

    Install a specific provider once Crossplane is running:
      kubectl apply -f - <<EOF
      apiVersion: pkg.crossplane.io/v1
      kind: Provider
      metadata:
        name: provider-kubernetes
      spec:
        package: xpkg.crossplane.io/crossplane-contrib/provider-kubernetes:v0.14.0
      EOF

    Teardown:
      formae destroy --yes --provider <p> examples/crossplane/main.pkl
    """
  confirm = true
}

properties {
  provider = new formae.Prop {
    flag = "provider"
    default = "aws"
  }
}

local providerName = properties.provider.value as String

local stack: formae.Stack = new {
  label = "k8s-crossplane-\(providerName)"
  description = "Crossplane control plane on a managed Kubernetes cluster (\(providerName))."
}

local cloud = dispatch.For(providerName)

local crossplane = new {
  resources = crossplaneApp.allResources(cloud.target)
}

forma {
  stack

  ...cloud.resources
  cloud.target

  ...crossplane.resources
}
