amends "@formae/forma.pkl"

import "@apps/crossplane.pkl" as crossplaneApp
import "@formae/formae.pkl"
import "@clusters/aws.pkl" as cluster

description {
  text = """
    Crossplane control plane on a managed EKS cluster (AWS).

      formae apply --mode reconcile examples/crossplane/aws.pkl

    Deploys Crossplane core (Namespace, RBAC, Deployment, Service). Crossplane's
    init container installs its CRDs at first start; those are NOT managed by
    formae. Install a provider via `kubectl apply` of a Provider CR once
    Crossplane is running.

    Teardown:
      formae destroy --on-dependents=cascade --yes examples/crossplane/aws.pkl
    """
  confirm = true
}

// Provider = this file's path. `clusterName` makes the cluster + target
// labels unique so crossplane can co-exist with other workloads on one account.
local clusterName = "crossplane"

local k8sTarget = cluster.target(clusterName)

local stack: formae.Stack = new {
  label = "k8s-crossplane-aws"
  description = "Crossplane control plane on a managed Kubernetes cluster (aws)."
}

local crossplane = new {
  resources = crossplaneApp.allResources(k8sTarget)
}

forma {
  stack

  ...cluster.resources(clusterName)
  k8sTarget

  ...crossplane.resources
}
