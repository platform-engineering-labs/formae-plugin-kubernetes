// EKS Auto-Mode ships its own EBS CSI driver under provisioner
// `ebs.csi.eks.amazonaws.com`, but does NOT auto-create a StorageClass.
// Workloads with PVCs (Minio, etc.) Pend forever without one defined.
// This SC fills that gap and marks itself default so unannotated PVCs
// bind without intervention.

import "@k8s/v1.34/storage/StorageClass.pkl" as sc
import "@k8s/v1.34/k8s.pkl" as k8s
import "@formae/formae.pkl"

function autoEbsStorageClass(k8sTarget: formae.Target): sc.StorageClass = new sc.StorageClass {
  target = k8sTarget.res
  label = "eks-auto-ebs-sc"
  metadata = new k8s.ObjectMeta {
    name = "auto-ebs"
    annotations = new Mapping {
      ["storageclass.kubernetes.io/is-default-class"] = "true"
    }
  }
  provisioner = "ebs.csi.eks.amazonaws.com"
  volumeBindingMode = "WaitForFirstConsumer"
  reclaimPolicy = "Delete"
  parameters = new Mapping {
    ["type"] = "gp3"
    ["encrypted"] = "true"
  }
}
