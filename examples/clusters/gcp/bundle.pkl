// GCP managed-Kubernetes bundle for the dispatcher.
//
// Provisions a Standard zonal GKE cluster (VPC, subnet, cluster) and
// exposes a Kubernetes target authenticated via `GKEAuth` (OAuth2-token
// refresh through the K8S plugin's WrapTransport).
//
// Standard (not Autopilot) because Autopilot uses a Google-managed node
// service account often blocked by the `compute.vmExternalIpAccess` org
// policy. A single zonal e2-medium node is enough for the demo workloads.
//
// Used by the workload entrypoints under `examples/<workload>/main.pkl` via
// the dispatcher in `examples/clusters/dispatch.pkl`. Cloud-specific knobs
// (cluster name, project, region, zone, CIDRs) are read from properties
// with safe defaults; override with `--prop <name>=<value>` at apply time.

import "@formae/formae.pkl"
import "@k8s/v1.34/k8s.pkl" as k8s

import "gke.pkl"
import "network.pkl"
import "vars.pkl"

local gkeCluster = gke.gkeCluster(vars.props)

resources: Listing = new {
  vars.target
  network.vpc(vars.props)
  network.subnet(vars.props)
  network.gkeRouter(vars.props)
  network.nat(vars.props)
  gkeCluster
}

target: formae.Target = new formae.Target {
  label = "k8s-target-gcp"
  config = new k8s.Config {
    kubernetesVersion = "1.34"
    auth = new k8s.GKEAuth {
      endpoint = gkeCluster.res.endpoint
      certificateAuthority = gkeCluster.res.clusterCaCertificate
    }
  }
}
