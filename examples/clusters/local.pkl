// Local/kubeconfig "managed-Kubernetes" cluster — flattened, file-as-picker shape.
//
// One self-contained module that provisions NOTHING: it just builds a
// `KubeconfigAuth` Kubernetes target against whichever cluster the local
// kubectl is pointing at. Useful for OrbStack, minikube, kind, or any
// pre-existing cluster you already have credentials for. No `dispatch.pkl`,
// no `Bundle` class, no sub-files.
//
// Consumed by workload entries (examples/<workload>/local.pkl), which select
// THIS provider by importing THIS file:
//
//   import "@clusters/local.pkl" as cluster
//   local k8sTarget = cluster.target("bookstore")
//   forma {
//     ...cluster.resources("bookstore")   // empty — local provisions nothing
//     k8sTarget
//   }
//
// `slug` is a per-workload identifier (NOT a `--name` flag): it makes the
// Kubernetes target label unique, so multiple workloads (lgtm/bookstore/
// crossplane) can co-exist pointing at the same local cluster without
// colliding on the same inventory target. It is named `slug` rather than
// `name` to avoid Pkl self-reference shadowing.
//
// Override the kubectl context with `--prop context=<name>` or the
// `K8S_CONTEXT` env var (default: whatever `kubectl config current-context`
// returns at apply time).

import "@formae/formae.pkl"
import "@k8s/v1.34/k8s.pkl" as k8s

local kubectlContext = read?("prop:context") ?? read?("env:K8S_CONTEXT")

// ---------------------------------------------------------------------------
// Public surface consumed by workload entries: resources(slug) + target(slug).
// ---------------------------------------------------------------------------
function resources(slug: String): Listing = new Listing {}

function target(slug: String): formae.Target = new formae.Target {
  label = "k8s-target-local-\(slug)"
  config = new k8s.Config {
    kubernetesVersion = "1.34"
    auth = new k8s.KubeconfigAuth {
      when (kubectlContext != null) {
        context = kubectlContext
      }
    }
  }
}
