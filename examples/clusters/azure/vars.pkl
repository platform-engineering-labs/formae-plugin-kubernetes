// Azure-side configuration shared by the cluster sub-modules.
//
// Holds the `props` Dynamic (cluster knobs, --prop overridable) and the
// Azure-side `target` (with `azure.Config` carrying the subscription id).
// Also exposes a few raw module-level values consumed directly by the
// network sub-module's top-level resource declarations.
//
// kubectl access: AKS is AAD-enabled by default, so `az aks get-credentials`
// produces a kubeconfig that needs `kubelogin` on PATH. After install,
// convert the kubeconfig to use your `az` session instead of a browser flow:
//
//   brew install Azure/kubelogin/kubelogin
//   az aks get-credentials -g <rg> -n <cluster> --overwrite-existing
//   kubelogin convert-kubeconfig -l azurecli
//
// Or skip AAD entirely with `--admin` on `get-credentials` for one-off use
// (uses local cluster admin certs; requires local accounts enabled).

import "@azure/azure.pkl"
import "@formae/formae.pkl"

projectName = "k8s-fullstack"
location = "eastus"
vnetCidr = "10.0.0.0/16"
aksSubnetCidr = "10.0.0.0/22"
dnsPrefix = "aks"

props = new Dynamic {
  name = new formae.Prop {
    flag = "name"
    default = module.projectName
  }
  location = new formae.Prop {
    flag = "location"
    default = module.location
  }
  subscriptionId = new formae.Prop {
    flag = "subscription-id"
    default = read?("env:AZURE_SUBSCRIPTION_ID")
      ?? throw("Azure subscription not set. Pass --subscription-id=<sub-id> or set AZURE_SUBSCRIPTION_ID.")
  }
  principalId = new formae.Prop {
    flag = "principal-id"
    default = read?("env:AZURE_PRINCIPAL_ID")
      ?? throw("Azure principal id not set. Pass --principal-id=<object-id> or set AZURE_PRINCIPAL_ID (`az ad signed-in-user show --query id -o tsv`).")
  }
}

target: formae.Target = new formae.Target {
  label = "azure-target"
  config = new azure.Config {
    subscriptionId = module.props.subscriptionId.value
  }
}
