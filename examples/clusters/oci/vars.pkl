// OCI-side configuration shared by the cluster sub-modules.
//
// Holds the `props` Dynamic (cluster knobs, --prop overridable) and the
// OCI-side `target` (with `oci.Config` carrying the region). Also exposes
// raw module-level values (cidrs, vm shape, k8s version) consumed directly
// by the network and oke sub-modules.

import "@formae/formae.pkl"
import "@oci/oci.pkl"

projectName = "k8s-fullstack"
ociRegion = "us-chicago-1"
k8sVersion = "v1.34.1"

vcnCidr = "10.0.0.0/16"
serviceLbSubnetCidr = "10.0.1.0/24"   // K8s LoadBalancer services (public)
workerNodeSubnetCidr = "10.0.2.0/24"  // worker nodes (private)

vmShape = "VM.Standard.E4.Flex"
nodeOcpus = 2.0
nodeMemoryGBs = 16.0
nodePoolSize = 2

props = new Dynamic {
  compartmentId = new formae.Prop {
    flag = "compartmentId"
    default = read?("env:OCI_COMPARTMENT_ID") ?? "ocid1.compartment.oc1..example"
  }

  availabilityDomain = new formae.Prop {
    flag = "availabilityDomain"
    default = read?("env:OCI_AVAILABILITY_DOMAIN") ?? "Twhb:US-CHICAGO-1-AD-1"
  }

  // OKE-optimized node image for region + K8s version.
  // Find images: oci ce node-pool-options get --node-pool-option-id all --compartment-id <id>
  nodeImageId = new formae.Prop {
    flag = "nodeImageId"
    default = read?("env:OCI_NODE_IMAGE_ID")
      ?? "ocid1.image.oc1.us-chicago-1.aaaaaaaasyjphzjohvvrttbw66amaxx6otldb26fvvn4nsogrvzsq2t6vama"
  }

  // Service Gateway service ID for OCI services.
  // Find: oci network service list --compartment-id <id>
  serviceGatewayServiceId = new formae.Prop {
    flag = "serviceGatewayServiceId"
    default = read?("env:OCI_SERVICE_GATEWAY_SERVICE_ID")
      ?? "ocid1.service.oc1.us-chicago-1.aaaaaaaakalxenk3rcszv74eamyc6dkjq6ngikfsdpctsll4nxw2lnfqbpbq"
  }
}

target: formae.Target = new formae.Target {
  label = "oci-target"
  config = new oci.Config {
    region = module.ociRegion
  }
}
