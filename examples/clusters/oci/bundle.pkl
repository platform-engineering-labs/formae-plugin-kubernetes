// OCI managed-Kubernetes bundle for the dispatcher.
//
// Provisions a full-stack OKE cluster (VCN, subnets, gateways, route tables,
// security lists, OKE cluster + node pool) and exposes a Kubernetes target
// authenticated via `OCIAuth` (OCI session-token refresh through the K8S
// plugin's WrapTransport).
//
// Used by the workload entrypoints under `examples/<workload>/main.pkl` via
// the dispatcher in `examples/clusters/dispatch.pkl`.
//
// Required env vars (or override with `--prop`):
//   OCI_COMPARTMENT_ID            — your compartment OCID
//   OCI_AVAILABILITY_DOMAIN       — e.g. "Twhb:US-CHICAGO-1-AD-1"
//   OCI_NODE_IMAGE_ID             — OKE-optimized image OCID (region- and version-specific)
//   OCI_SERVICE_GATEWAY_SERVICE_ID — Service Gateway service id for OCI services

import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s

import "network.pkl"
import "oke.pkl"
import "security.pkl"
import "vars.pkl"
import "vcn.pkl"

local vcnBundle = new vcn.VcnResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  vcnCidr = vars.vcnCidr
}

local securityBundle = new security.SecurityResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  serviceLbSubnetCidr = vars.serviceLbSubnetCidr
  workerNodeSubnetCidr = vars.workerNodeSubnetCidr
  vcn = vcnBundle.vcn
}

local networkBundle = new network.NetworkResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  serviceLbSubnetCidr = vars.serviceLbSubnetCidr
  workerNodeSubnetCidr = vars.workerNodeSubnetCidr
  serviceGatewayServiceId = vars.props.serviceGatewayServiceId.value
  vcn = vcnBundle.vcn
  securityList = securityBundle.securityList
}

local okeBundle = new oke.OkeResources {
  compartmentId = vars.props.compartmentId.value
  projectName = vars.projectName
  k8sVersion = vars.k8sVersion
  vmShape = vars.vmShape
  nodeOcpus = vars.nodeOcpus
  nodeMemoryGBs = vars.nodeMemoryGBs
  nodePoolSize = vars.nodePoolSize
  availabilityDomain = vars.props.availabilityDomain.value
  nodeImageId = vars.props.nodeImageId.value
  vcn = vcnBundle.vcn
  svcLbSubnet = networkBundle.svcLbSubnet
  workerSubnet = networkBundle.workerSubnet
}

resources: Listing = new {
  vars.target
  ...vcnBundle.resources
  ...securityBundle.resources
  ...networkBundle.resources
  ...okeBundle.resources
}

target: formae.Target = new formae.Target {
  label = "k8s-target-oci"
  config = new k8s.Config {
    kubernetesVersion = "1.34"
    auth = new k8s.OCIAuth {
      endpoint = okeBundle.okeCluster.res.endpoint
      certificateAuthority = okeBundle.okeCluster.res.certificateAuthority
      clusterOcid = okeBundle.okeCluster.res.id
    }
  }
}
