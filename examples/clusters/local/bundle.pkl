// Local/kubeconfig "managed-Kubernetes" bundle for the dispatcher.
//
// Doesn't provision anything — just builds a `KubeconfigAuth` target against
// whichever cluster the local kubectl is pointing at. Useful for OrbStack,
// minikube, kind, or any pre-existing cluster you already have credentials
// for. The `resources` listing is empty.
//
// Override the kubectl context with `--prop context=<name>` or the
// `K8S_CONTEXT` env var (default: whatever `kubectl config current-context`
// returns at apply time).

import "@formae/formae.pkl"
import "@k8s/v1.34/k8s.pkl" as k8s

local kubectlContext = read?("prop:context") ?? read?("env:K8S_CONTEXT")

resources: Listing = new Listing {}

target: formae.Target = new formae.Target {
  label = "k8s-target-local"
  config = new k8s.Config {
    kubernetesVersion = "1.34"
    auth = new k8s.KubeconfigAuth {
      when (kubectlContext != null) {
        context = kubectlContext
      }
    }
  }
}
