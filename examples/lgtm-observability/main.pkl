amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@apps/lgtm/lgtm.pkl" as lgtmApp
import "@clusters/dispatch.pkl"
import "@grafana/grafana.pkl"
import "@grafana/core/folder.pkl"
import "@grafana/core/datasource.pkl"
import "@grafana/core/dashboard.pkl"

description {
  text = """
    LGTM observability stack on a managed Kubernetes cluster, with Grafana
    Folder + DataSources + Dashboards provisioned by the grafana plugin.

    Three plugins compose in one forma:
      - A cloud plugin (aws | azure | gcp | oci) provisions the cluster
      - The k8s plugin deploys LGTM (Loki, Tempo, Mimir, Grafana, MinIO, OTel)
      - The grafana plugin configures Grafana via its HTTP API

    Target chaining wires it together: the K8s Target's auth is a $ref on the
    cluster endpoint; the Grafana Target's URL is a $ref on the Grafana
    Service's LoadBalancer ingress IP. No hardcoded endpoints.

    Prereqs:
      - GRAFANA_AUTH=admin:admin-change-me set before starting the agent.
        (Matches the password baked into the lgtm-grafana-admin Secret.)

      formae agent stop
      GRAFANA_AUTH=admin:admin-change-me formae agent start

    Apply (any cloud, defaults to aws; --provider switches; --enable-demo-traffic
    runs synthetic logs/traces/metrics through telemetrygen):

      formae apply --mode reconcile --provider gcp --enable-demo-traffic examples/lgtm-observability/main.pkl

    After apply, Grafana's LB IP is in the formae inventory as the per-provider
    grafana target's Config.Url:

      formae inventory targets --query 'label:grafana-target-aws' --output-consumer machine --output-schema json | jq -r '.[0].Config.Url."$value"'

    Open that URL in a browser, log in admin/admin-change-me, navigate to
    Dashboards → Formae Dashboards. Datasource connections are pre-provisioned
    by the grafana plugin and pointed at the cluster-internal LGTM services.

    Teardown:

      formae destroy --on-dependents=cascade --yes --provider <p> examples/lgtm-observability/main.pkl
    """
  confirm = true
}

properties {
  provider = new formae.Prop {
    flag = "provider"
    default = read?("env:FORMAE_PROVIDER") ?? "aws"
  }
  enableDemoTraffic = new formae.Prop {
    flag = "enable-demo-traffic"
    default = false
  }
}

local providerName = properties.provider.value as String

local stack: formae.Stack = new {
  label = "k8s-lgtm-observability-\(providerName)"
  description = "LGTM observability stack + plugin-managed Grafana dashboards (\(providerName))."
}

local cloud = dispatch.For(providerName)

// Pass enableGrafanaAdminAuth=true so the k8s grafana boots with admin/password
// auth (from a managed Secret) instead of anonymous mode. This is what lets the
// grafana plugin authenticate via GRAFANA_AUTH at agent start. Returns an object
// with .resources (the Listing) AND .grafanaSvc (a handle to the LB Service).
local lgtm = lgtmApp.allResources(
  cloud.target,
  properties.enableDemoTraffic.value as Boolean,
  true
)

// Grafana plugin target — URL is a $ref on the Grafana K8s Service's
// synthesized lbIngressUrl ("http://<host>[:port]"). The K8s plugin's Read
// preserves status.loadBalancer.ingress AND synthesizes ingress[0].url from
// the address + first port (see pkg/resources/prov/livestate.go). Pkl can't
// concatenate a literal scheme with a Resolvable IP at user level, so the
// URL has to come from a single Resolvable.
// Per-provider labels so parallel multi-cloud applies don't collide on a single
// inventory entry. UIDs stay stable across providers — they're scoped to the
// per-provider Grafana instance, not the formae inventory.
local grafanaTarget: formae.Target = new {
  label = "grafana-target-\(providerName)"
  namespace = "GRAFANA"
  config = new grafana.Config {
    url = lgtm.grafanaSvc.res.lbIngressUrl
  }
}

local dashboardsFolder = new folder.Folder {
  target = grafanaTarget.res
  label = "formae-dashboards-\(providerName)"
  uid = "formae-dashboards"
  title = "Formae Dashboards"
}

// Three datasources pointing at the cluster-internal LGTM read tiers. URLs use
// in-cluster DNS — Grafana's server proxies queries through, so callers don't
// need these reachable from outside the cluster. UIDs match the references the
// shipped dashboards in formae-grafana-dashboards expect.
local lokiDataSource = new datasource.DataSource {
  target = grafanaTarget.res
  label = "lgtm-loki-datasource-\(providerName)"
  uid = "loki"
  name = "Loki"
  datasourceType = "loki"
  url = "http://loki-read.observability.svc.cluster.local:3100"
  access = "proxy"
}

local tempoDataSource = new datasource.DataSource {
  target = grafanaTarget.res
  label = "lgtm-tempo-datasource-\(providerName)"
  uid = "tempo"
  name = "Tempo"
  datasourceType = "tempo"
  url = "http://tempo-read.observability.svc.cluster.local:3200"
  access = "proxy"
}

// Mimir is served via Prometheus-API protocol. UID `prometheus` matches the
// shipped dashboards' datasource references.
local mimirDataSource = new datasource.DataSource {
  target = grafanaTarget.res
  label = "lgtm-mimir-datasource-\(providerName)"
  uid = "prometheus"
  name = "Mimir"
  datasourceType = "prometheus"
  url = "http://mimir-read.observability.svc.cluster.local:8080/prometheus"
  access = "proxy"
  isDefault = true
}

// Dashboards loaded from the formae-grafana-dashboards repo. `read()` fetches
// at Pkl-eval time — the JSON gets embedded into the resource's configJson.
local dashboardRepo = "https://raw.githubusercontent.com/platform-engineering-labs/formae-grafana-dashboards/main/dashboards"
local overviewJson = read("\(dashboardRepo)/formae-overview.json").text
local pluginsJson = read("\(dashboardRepo)/formae-plugin.json").text

local formaeOverviewDashboard = new dashboard.Dashboard {
  target = grafanaTarget.res
  label = "formae-overview-dashboard-\(providerName)"
  uid = "formae-overview"
  title = "Formae Agent"
  folderUid = dashboardsFolder.res.uid
  configJson = overviewJson
}

local formaePluginsDashboard = new dashboard.Dashboard {
  target = grafanaTarget.res
  label = "formae-plugins-dashboard-\(providerName)"
  uid = "formae-plugins"
  title = "Formae Plugins"
  folderUid = dashboardsFolder.res.uid
  configJson = pluginsJson
}

forma {
  stack

  ...cloud.resources
  cloud.target

  ...lgtm.resources

  grafanaTarget

  dashboardsFolder
  lokiDataSource
  tempoDataSource
  mimirDataSource
  formaeOverviewDashboard
  formaePluginsDashboard
}
