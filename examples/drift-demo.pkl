/*
 * Drift Detection Demo
 *
 * Deploys a Deployment and ConfigMap, then demonstrates how external
 * changes (drift) are detected and reconciled on re-apply.
 *
 * Usage:
 *
 *   # 1. Initial deploy
 *   formae apply examples/drift-demo.pkl
 *
 *   # 2. Verify initial state
 *   kubectl -n drift-demo get deployment drift-demo-app \
 *     -o jsonpath='{.spec.replicas}'                         # -> 2
 *   kubectl -n drift-demo get configmap drift-demo-config \
 *     -o jsonpath='{.data.log_level}'                        # -> info
 *
 *   # 3. Introduce drift
 *   kubectl -n drift-demo scale deployment/drift-demo-app --replicas=5
 *   kubectl -n drift-demo patch configmap/drift-demo-config \
 *     --type merge -p '{"data":{"log_level":"debug"}}'
 *   kubectl -n drift-demo label deployment/drift-demo-app env=production
 *
 *   # 4. Verify drift exists
 *   kubectl -n drift-demo get deployment drift-demo-app \
 *     -o jsonpath='{.spec.replicas}'                         # -> 5 (drifted!)
 *   kubectl -n drift-demo get configmap drift-demo-config \
 *     -o jsonpath='{.data.log_level}'                        # -> debug (drifted!)
 *
 *   # 5. Re-apply to detect drift and reconcile
 *   formae apply examples/drift-demo.pkl
 *
 *   # 6. Verify reconciliation
 *   kubectl -n drift-demo get deployment drift-demo-app \
 *     -o jsonpath='{.spec.replicas}'                         # -> 2 (restored)
 *   kubectl -n drift-demo get configmap drift-demo-config \
 *     -o jsonpath='{.data.log_level}'                        # -> info (restored)
 *
 *   # 7. Cleanup
 *   formae destroy examples/drift-demo.pkl
 */
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@k8s/core/Namespace.pkl" as ns
import "@k8s/core/ConfigMap.pkl" as cm
import "@k8s/apps/Deployment.pkl" as dep
import "@k8s/k8s.pkl" as k8s

local appName = "drift-demo"

forma {
  new formae.Stack {
    label = "\(appName)-stack"
    description = "Drift detection demo"
  }

  new formae.Target {
    label = "\(appName)-target"
    namespace = "K8S"
    config = new k8s.Config {
      hasLoadBalancer = false
      auth = new k8s.KubeconfigAuth {}
    }
  }

  // Namespace
  local demoNs = new ns.Namespace {
    label = "\(appName)-ns"
    metadata = new ns.NamespaceMetadata {
      name = appName
      labels = new Mapping {
        ["managed-by"] = "formae"
      }
    }
  }
  demoNs

  // ConfigMap - application configuration
  new cm.ConfigMap {
    label = "\(appName)-config"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-config"
      namespace = demoNs.res.name
      labels = new Mapping {
        ["app"] = appName
      }
    }
    data = new Mapping {
      ["log_level"] = "info"
      ["max_connections"] = "100"
      ["environment"] = "staging"
    }
  }

  // Deployment - the main application
  new dep.Deployment {
    label = "\(appName)-app"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-app"
      namespace = demoNs.res.name
      labels = new Mapping {
        ["app"] = appName
        ["version"] = "v1"
      }
    }
    spec = new dep.DeploymentSpec {
      replicas = 2
      selector = new k8s.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = appName
        }
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.ObjectMeta {
          name = "\(appName)-app"
          labels = new Mapping {
            ["app"] = appName
          }
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "nginx"
              image = "nginx:1.25-alpine"
              ports = new Listing {
                new k8s.ContainerPort {
                  containerPort = 80
                }
              }
            }
          }
        }
      }
    }
  }
}
