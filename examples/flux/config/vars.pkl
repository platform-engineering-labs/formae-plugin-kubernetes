import "@formae/formae.pkl"
import "@k8s/v1.33/k8s.pkl" as k8s

stack = new formae.Stack {
  label = "flux-demo-stack"
  description = "Flux custom resources managed by formae"
}

target = new formae.Target {
  label = "k8s-target"
  config = new k8s.Config {
    kubernetesVersion = "1.33"
    auth = new k8s.KubeconfigAuth {}
    customResourceGroups = new { "source.toolkit.fluxcd.io" }
  }
}
