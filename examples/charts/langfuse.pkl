// Example: Deploy Langfuse using the native LangfuseChart.
//
// This creates: Namespace, ServiceAccount, Secret, Web Deployment,
// Web Service, Worker Deployment, and Ingress.
//
// Prerequisites (deploy separately):
//   - PostgreSQL (e.g., bitnami/postgresql or managed service)
//   - Redis (e.g., bitnami/valkey or managed service)
//
//   pkl eval -f pcf langfuse.pkl
//   formae apply --mode reconcile langfuse.pkl
//
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@formae-charts/LangfuseChart.pkl"

local langfuse = new LangfuseChart.Langfuse {
  name = "langfuse"
  namespace = "langfuse"
  imageTag = "3"
  createNamespace = true

  // Auth & security
  nextauthSecret = "change-me-nextauth-secret-min-32-chars"
  salt = "change-me-salt-value"
  encryptionKey = "change-me-encryption-key-min-32c!"

  // PostgreSQL
  databaseHost = "langfuse-postgresql"
  databasePassword = "langfuse-db-password"

  // Redis
  redisHost = "langfuse-redis-primary"

  // Scaling
  webReplicas = 2
  workerReplicas = 1

  // Resources
  webCpuRequest = "250m"
  webCpuLimit = "1000m"
  webMemoryRequest = "512Mi"
  webMemoryLimit = "1Gi"
  workerCpuRequest = "250m"
  workerMemoryRequest = "512Mi"

  // Ingress
  ingressHost = "langfuse.example.com"
  ingressClassName = "nginx"
  ingressTLSSecret = "langfuse-tls"
}

forma {
  new formae.Stack {
    label = "langfuse"
    description = "Langfuse LLM observability platform"
  }
  new formae.Target {
    label = "k8s-local"
    namespace = "K8S"
    config {
      ["context"] = "orbstack"
      ["namespace"] = "langfuse"
    }
  }
  for (r in langfuse.resources) {
    r
  }
}
