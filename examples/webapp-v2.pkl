/*
 * Example: Bookstore v2 — rolling update via patch
 *
 * This file is identical to webapp.pkl except for the content served by
 * the frontend and backend.  When applied on top of a running v1:
 *
 *   formae apply examples/webapp-v2.pkl
 *
 * Formae detects the property diff and patches only the changed resources
 * (the two ConfigMaps and the backend Deployment).  Unchanged resources
 * (Namespace, Secret, ServiceAccount, Services, Ingress) are left alone.
 *
 * What changes in v2:
 *   - Frontend HTML shows "Bookstore v2" with a refreshed colour scheme
 *   - Backend API response includes a "version" field
 *   - Backend image bumped to show a rolling update of the Deployment
 *
 * Rollback to v1:
 *   formae apply examples/webapp.pkl
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/core/Namespace.pkl" as ns
import "@k8s/core/ConfigMap.pkl" as cm
import "@k8s/core/Secret.pkl" as sec
import "@k8s/core/Service.pkl" as svc
import "@k8s/core/ServiceAccount.pkl" as sa
import "@k8s/apps/Deployment.pkl" as dep
import "@k8s/networking/Ingress.pkl" as ing
import "@k8s/k8s.pkl" as k8s

// ---------------------------------------------------------------------------
// Configuration — same as v1, only content changes
// ---------------------------------------------------------------------------
local appName = "bookstore"
local domain = "bookstore.example.com"

local frontendImage = "nginx:1.27-alpine"
local frontendReplicas = 2

local backendImage = "node:22-alpine"
local backendReplicas = 3

local dbHost = "postgres.database.svc.cluster.local"
local dbName = "bookstore"
local dbUser = "bookstore-app"
local dbPassword = "change-me-in-production"

// ---------------------------------------------------------------------------
// Shared labels
// ---------------------------------------------------------------------------
local commonLabels = new Mapping {
  ["app"] = appName
  ["managed-by"] = "formae"
}

local frontendLabels = new Mapping {
  ...commonLabels
  ["component"] = "frontend"
}

local backendLabels = new Mapping {
  ...commonLabels
  ["component"] = "backend"
}

// ---------------------------------------------------------------------------
// Stack & Target
// ---------------------------------------------------------------------------
forma {
  new formae.Stack {
    label = "\(appName)-stack"
    description = "Bookstore web application"
  }

  new formae.Target {
    label = "\(appName)-target"
    namespace = "K8S"
    config = new k8s.Config {
      waitForLoadBalancer = false
    }
  }

  // -------------------------------------------------------------------------
  // Namespace
  // -------------------------------------------------------------------------
  local appNs = new ns.Namespace {
    label = "\(appName)-ns"
    metadata = new ns.NamespaceMetadata {
      name = appName
      labels = commonLabels
    }
  }

  appNs

  // -------------------------------------------------------------------------
  // ConfigMap — frontend nginx config + v2 HTML
  // -------------------------------------------------------------------------
  new cm.ConfigMap {
    label = "\(appName)-frontend-config"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend-config"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    data = new Mapping {
      ["default.conf"] = new Listing {
        "server {"
        "    listen 80;"
        "    server_name _;"
        ""
        "    location /api {"
        "        proxy_pass http://\(appName)-backend;"
        "        proxy_set_header Host $host;"
        "        proxy_set_header X-Real-IP $remote_addr;"
        "    }"
        ""
        "    location / {"
        "        root /usr/share/nginx/html;"
        "        index index.html;"
        "    }"
        "}"
      }.join("\n")
      ["index.html"] = new Listing {
        "<!DOCTYPE html>"
        "<html><head>"
        "  <title>Bookstore v2</title>"
        "  <style>"
        "    body { font-family: system-ui, sans-serif; max-width: 600px; margin: 60px auto; padding: 0 20px; }"
        "    h1 { border-bottom: 2px solid #0066cc; padding-bottom: 10px; color: #0066cc; }"
        "    .version { display: inline-block; background: #0066cc; color: white; padding: 2px 8px; border-radius: 12px; font-size: 0.75em; vertical-align: middle; }"
        "    code { background: #e8f0fe; padding: 2px 6px; border-radius: 3px; }"
        "    #api-result { background: #e8f0fe; padding: 16px; border-radius: 6px; white-space: pre; font-family: monospace; }"
        "  </style>"
        "</head><body>"
        "  <h1>Bookstore <span class=\"version\">v2</span></h1>"
        "  <p>Frontend served by <strong>nginx</strong>. Backend API at <code>/api</code>.</p>"
        "  <p>New in v2: catalog search, improved performance, and a fresh look.</p>"
        "  <h2>API Response</h2>"
        "  <div id=\"api-result\">Loading...</div>"
        "  <script>"
        "    fetch('/api').then(r=>r.json()).then(d=>{"
        "      document.getElementById('api-result').textContent=JSON.stringify(d,null,2)"
        "    }).catch(e=>{"
        "      document.getElementById('api-result').textContent='Error: '+e.message"
        "    })"
        "  </script>"
        "</body></html>"
      }.join("\n")
    }
  }

  // -------------------------------------------------------------------------
  // ConfigMap — backend application config (unchanged)
  // -------------------------------------------------------------------------
  new cm.ConfigMap {
    label = "\(appName)-backend-config"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend-config"
      namespace = appNs.res.name
      labels = backendLabels
    }
    data = new Mapping {
      ["DB_HOST"] = dbHost
      ["DB_NAME"] = dbName
      ["DB_PORT"] = "5432"
      ["LOG_LEVEL"] = "info"
      ["PORT"] = "3000"
    }
  }

  // -------------------------------------------------------------------------
  // Secret — database credentials (unchanged)
  // -------------------------------------------------------------------------
  new sec.Secret {
    label = "\(appName)-db-credentials"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-db-credentials"
      namespace = appNs.res.name
      labels = backendLabels
    }
    type = "Opaque"
    stringData = new Mapping {
      ["DB_USER"] = dbUser
      ["DB_PASSWORD"] = dbPassword
    }
  }

  // -------------------------------------------------------------------------
  // ServiceAccount — backend identity (unchanged)
  // -------------------------------------------------------------------------
  new sa.ServiceAccount {
    label = "\(appName)-backend-sa"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    automountServiceAccountToken = false
  }

  // -------------------------------------------------------------------------
  // Deployment — frontend (unchanged image, but ConfigMap content changed
  // above triggers a rollout when the ConfigMap is updated)
  // -------------------------------------------------------------------------
  new dep.Deployment {
    label = "\(appName)-frontend"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    spec = new dep.DeploymentSpec {
      replicas = frontendReplicas
      selector = new k8s.LabelSelector {
        matchLabels = frontendLabels
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.PodTemplateMetadata {
          labels = frontendLabels
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "nginx"
              image = frontendImage
              ports = new Listing {
                new k8s.ContainerPort {
                  name = "http"
                  containerPort = 80
                }
              }
              volumeMounts = new Listing {
                new k8s.VolumeMount {
                  name = "nginx-config"
                  mountPath = "/etc/nginx/conf.d"
                  readOnly = true
                }
                new k8s.VolumeMount {
                  name = "html"
                  mountPath = "/usr/share/nginx/html"
                  readOnly = true
                }
              }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping {
                  ["cpu"] = "50m"
                  ["memory"] = "64Mi"
                }
                limits = new Mapping {
                  ["cpu"] = "200m"
                  ["memory"] = "128Mi"
                }
              }
            }
          }
          volumes = new Listing {
            new k8s.Volume {
              name = "nginx-config"
              configMap = new k8s.ConfigMapVolumeSource {
                name = "\(appName)-frontend-config"
                items = new Listing {
                  new k8s.KeyToPath { key = "default.conf"; path = "default.conf" }
                }
              }
            }
            new k8s.Volume {
              name = "html"
              configMap = new k8s.ConfigMapVolumeSource {
                name = "\(appName)-frontend-config"
                items = new Listing {
                  new k8s.KeyToPath { key = "index.html"; path = "index.html" }
                }
              }
            }
          }
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Deployment — backend v2 (updated API response with version field)
  // -------------------------------------------------------------------------
  new dep.Deployment {
    label = "\(appName)-backend"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    spec = new dep.DeploymentSpec {
      replicas = backendReplicas
      selector = new k8s.LabelSelector {
        matchLabels = backendLabels
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.PodTemplateMetadata {
          labels = backendLabels
        }
        spec = new k8s.PodSpec {
          serviceAccountName = "\(appName)-backend"
          containers = new Listing {
            new k8s.Container {
              name = "api"
              image = backendImage
              command = new Listing { "node"; "-e" }
              args = new Listing {
                #"require("http").createServer((req,res)=>{res.writeHead(200,{"Content-Type":"application/json"});res.end(JSON.stringify({version:"2.0",status:"ok",path:req.url,features:["catalog-search","recommendations"],ts:new Date().toISOString()}))}).listen(3000,()=>console.log("API v2 listening on :3000"))"#
              }
              ports = new Listing {
                new k8s.ContainerPort {
                  name = "http"
                  containerPort = 3000
                }
              }
              env = new Listing {
                new k8s.EnvVar { name = "NODE_ENV"; value = "production" }
              }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping {
                  ["cpu"] = "100m"
                  ["memory"] = "128Mi"
                }
                limits = new Mapping {
                  ["cpu"] = "500m"
                  ["memory"] = "256Mi"
                }
              }
            }
          }
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Service — frontend (unchanged)
  // -------------------------------------------------------------------------
  new svc.Service {
    label = "\(appName)-frontend-svc"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-frontend"
      namespace = appNs.res.name
      labels = frontendLabels
    }
    spec = new svc.ServiceSpec {
      selector = frontendLabels
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          targetPort = 80
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Service — backend (unchanged)
  // -------------------------------------------------------------------------
  new svc.Service {
    label = "\(appName)-backend-svc"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-backend"
      namespace = appNs.res.name
      labels = backendLabels
    }
    spec = new svc.ServiceSpec {
      selector = backendLabels
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          targetPort = 3000
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Ingress (unchanged)
  // -------------------------------------------------------------------------
  new ing.Ingress {
    label = "\(appName)-ingress"
    metadata = new k8s.ObjectMeta {
      name = "\(appName)-ingress"
      namespace = appNs.res.name
      labels = commonLabels
    }
    spec = new ing.IngressSpec {
      ingressClassName = "nginx"
      rules = new Listing {
        new ing.IngressRule {
          host = domain
          http = new ing.HTTPIngressRuleValue {
            paths = new Listing {
              new ing.HTTPIngressPath {
                path = "/api"
                pathType = "Prefix"
                backend = new ing.IngressBackend {
                  service = new ing.IngressServiceBackend {
                    name = "\(appName)-backend"
                    port = new ing.ServiceBackendPort {
                      number = 80
                    }
                  }
                }
              }
              new ing.HTTPIngressPath {
                path = "/"
                pathType = "Prefix"
                backend = new ing.IngressBackend {
                  service = new ing.IngressServiceBackend {
                    name = "\(appName)-frontend"
                    port = new ing.ServiceBackendPort {
                      number = 80
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
