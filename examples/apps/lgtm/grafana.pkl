// Grafana with two auth modes:
//   - Anonymous-admin (default): datasources + dashboards provisioned via
//     mounted ConfigMaps. Self-contained, no extra env required.
//   - Admin-auth (when enableAdminAuth = true): drops the anonymous env, mounts
//     no datasources/dashboards ConfigMaps. The agent's GRAFANA_AUTH env must
//     carry "admin:<password>" so the grafana plugin can manage datasources +
//     dashboards via the HTTP API. Used by examples/lgtm-observability.

import "@formae/formae.pkl"
import "@k8s/v1.34/core/Namespace.pkl" as ns
import "@k8s/v1.34/core/ConfigMap.pkl" as cm
import "@k8s/v1.34/core/Secret.pkl" as sec
import "@k8s/v1.34/core/Service.pkl" as svc
import "@k8s/v1.34/apps/Deployment.pkl" as dep
import "@k8s/v1.34/k8s.pkl" as k8s

local appName = "grafana"
local imageRef = "docker.io/grafana/grafana:11.4.0"
local adminSecretName = "grafana-admin"
local adminPassword = "admin-change-me"

local grafanaLabels = new Mapping {
  ["app.kubernetes.io/part-of"] = "lgtm"
  ["app.kubernetes.io/name"] = appName
  ["managed-by"] = "formae"
}

// Keys use `-` instead of `.` — Formae's Mapping handling expands dotted keys
// into nested objects. We use KeyToPath below to rename on-disk.
function datasourcesConfig(k8sTarget: formae.Target, appNs: ns.Namespace, nsName: String): cm.ConfigMap =
  new cm.ConfigMap {
    target = k8sTarget.res
    label = "lgtm-grafana-datasources"
    metadata = new k8s.NamespacedObjectMeta {
      name = "grafana-datasources"
      namespace = appNs.res.name
      labels = grafanaLabels
    }
    data = new Mapping {
      ["datasources-yaml"] = (new YamlRenderer {}).renderValue(new Dynamic {
        apiVersion = 1
        datasources = new Listing {
          new Dynamic {
            name = "Loki"
            type = "loki"
            uid = "loki"
            url = "http://loki-read.\(nsName).svc.cluster.local:3100"
            access = "proxy"
          }
          new Dynamic {
            name = "Tempo"
            type = "tempo"
            uid = "tempo"
            url = "http://tempo-read.\(nsName).svc.cluster.local:3200"
            access = "proxy"
          }
          new Dynamic {
            name = "Mimir"
            type = "prometheus"
            uid = "mimir"
            url = "http://mimir-read.\(nsName).svc.cluster.local:8080/prometheus"
            access = "proxy"
            isDefault = true
          }
        }
      })
    }
  }

function dashboardProviderConfig(k8sTarget: formae.Target, appNs: ns.Namespace): cm.ConfigMap =
  new cm.ConfigMap {
    target = k8sTarget.res
    label = "lgtm-grafana-dashprov"
    metadata = new k8s.NamespacedObjectMeta {
      name = "grafana-dashboard-provider"
      namespace = appNs.res.name
      labels = grafanaLabels
    }
    data = new Mapping {
      ["dashboards-yaml"] = (new YamlRenderer {}).renderValue(new Dynamic {
        apiVersion = 1
        providers = new Listing {
          new Dynamic {
            name = "default"
            orgId = 1
            folder = ""
            type = "file"
            disableDeletion = false
            updateIntervalSeconds = 30
            allowUiUpdates = true
            options {
              path = "/var/lib/grafana/dashboards"
            }
          }
        }
      })
    }
  }

function demoDashboardConfig(k8sTarget: formae.Target, appNs: ns.Namespace): cm.ConfigMap =
  new cm.ConfigMap {
    target = k8sTarget.res
    label = "lgtm-grafana-dashboard"
    metadata = new k8s.NamespacedObjectMeta {
      name = "grafana-demo-dashboard"
      namespace = appNs.res.name
      labels = grafanaLabels
    }
    data = new Mapping {
      ["lgtm-demo-json"] = #"""
        {
          "title": "LGTM Demo",
          "uid": "lgtm-demo",
          "schemaVersion": 39,
          "timezone": "browser",
          "panels": [
            {
              "type": "logs",
              "title": "Logs (Loki)",
              "datasource": { "type": "loki", "uid": "loki" },
              "targets": [{ "expr": "{service_name=\"telemetrygen\"}" }],
              "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 }
            },
            {
              "type": "timeseries",
              "title": "Metrics (Mimir)",
              "datasource": { "type": "prometheus", "uid": "mimir" },
              "targets": [{ "expr": "rate(gen[1m])" }],
              "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
            },
            {
              "type": "traces",
              "title": "Traces (Tempo)",
              "datasource": { "type": "tempo", "uid": "tempo" },
              "targets": [{ "query": "{ resource.service.name=\"telemetrygen\" }" }],
              "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
            }
          ]
        }
        """#
    }
  }

function adminSecret(k8sTarget: formae.Target, appNs: ns.Namespace): sec.Secret =
  new sec.Secret {
    target = k8sTarget.res
    label = "lgtm-grafana-admin"
    metadata = new k8s.NamespacedObjectMeta {
      name = adminSecretName
      namespace = appNs.res.name
      labels = grafanaLabels
    }
    stringData = new Mapping {
      ["admin-password"] = adminPassword
    }
  }

function grafanaDeployment(k8sTarget: formae.Target, appNs: ns.Namespace, enableAdminAuth: Boolean): dep.Deployment =
  new dep.Deployment {
    target = k8sTarget.res
    label = "lgtm-grafana"
    metadata = new k8s.NamespacedObjectMeta { name = appName; namespace = appNs.res.name; labels = grafanaLabels }
    spec = new dep.DeploymentSpec {
      // Single replica: Grafana's embedded SQLite diverges across pods.
      replicas = 1
      selector = new k8s.LabelSelector { matchLabels = grafanaLabels }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.ObjectMeta { name = appName; labels = grafanaLabels }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "grafana"
              image = imageRef
              env = if (enableAdminAuth)
                new Listing {
                  new k8s.EnvVar { name = "GF_SECURITY_ADMIN_USER"; value = "admin" }
                  new k8s.EnvVar {
                    name = "GF_SECURITY_ADMIN_PASSWORD"
                    valueFrom = new k8s.EnvVarSource {
                      secretKeyRef = new k8s.SecretKeySelector {
                        name = adminSecretName
                        key = "admin-password"
                      }
                    }
                  }
                }
              else
                new Listing {
                  new k8s.EnvVar { name = "GF_AUTH_ANONYMOUS_ENABLED"; value = "true" }
                  new k8s.EnvVar { name = "GF_AUTH_ANONYMOUS_ORG_ROLE"; value = "Admin" }
                  new k8s.EnvVar { name = "GF_AUTH_DISABLE_LOGIN_FORM"; value = "true" }
                }
              ports = new Listing {
                new k8s.ContainerPort { name = "http"; containerPort = 3000 }
              }
              volumeMounts = if (enableAdminAuth)
                new Listing {}
              else
                new Listing {
                  new k8s.VolumeMount {
                    name = "datasources"
                    mountPath = "/etc/grafana/provisioning/datasources"
                    readOnly = true
                  }
                  new k8s.VolumeMount {
                    name = "dashboard-provider"
                    mountPath = "/etc/grafana/provisioning/dashboards"
                    readOnly = true
                  }
                  new k8s.VolumeMount {
                    name = "demo-dashboard"
                    mountPath = "/var/lib/grafana/dashboards"
                    readOnly = true
                  }
                }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping { ["cpu"] = "100m"; ["memory"] = 256.mib }
                limits = new Mapping { ["cpu"] = "500m"; ["memory"] = 512.mib }
              }
            }
          }
          volumes = if (enableAdminAuth)
            new Listing {}
          else
            new Listing {
              new k8s.Volume {
                name = "datasources"
                configMap = new k8s.ConfigMapVolumeSource {
                  name = "grafana-datasources"
                  items = new Listing {
                    new k8s.KeyToPath { key = "datasources-yaml"; path = "datasources.yaml" }
                  }
                }
              }
              new k8s.Volume {
                name = "dashboard-provider"
                configMap = new k8s.ConfigMapVolumeSource {
                  name = "grafana-dashboard-provider"
                  items = new Listing {
                    new k8s.KeyToPath { key = "dashboards-yaml"; path = "dashboards.yaml" }
                  }
                }
              }
              new k8s.Volume {
                name = "demo-dashboard"
                configMap = new k8s.ConfigMapVolumeSource {
                  name = "grafana-demo-dashboard"
                  items = new Listing {
                    new k8s.KeyToPath { key = "lgtm-demo-json"; path = "lgtm-demo.json" }
                  }
                }
              }
            }
        }
      }
    }
  }

function grafanaService(k8sTarget: formae.Target, appNs: ns.Namespace): svc.Service =
  new svc.Service {
    target = k8sTarget.res
    label = "lgtm-grafana-svc"
    metadata = new k8s.NamespacedObjectMeta {
      name = appName
      namespace = appNs.res.name
      labels = grafanaLabels
      annotations = new Mapping {
        // EKS Auto-Mode defaults LoadBalancer Services to internal NLBs; this
        // annotation makes the NLB internet-facing. Other clouds ignore it.
        ["service.beta.kubernetes.io/aws-load-balancer-scheme"] = "internet-facing"
      }
    }
    spec = new svc.ServiceSpec {
      type = "LoadBalancer"
      selector = grafanaLabels
      ports = new Listing {
        new svc.ServicePort { name = "http"; port = 80; targetPort = 3000 }
      }
    }
  }

function allResources(k8sTarget: formae.Target, appNs: ns.Namespace, nsName: String, enableAdminAuth: Boolean) =
  new Listing {
    for (r in allResourcesExceptSvc(k8sTarget, appNs, nsName, enableAdminAuth)) { r }
    grafanaService(k8sTarget, appNs)
  }

/// Same as allResources but omits the LoadBalancer Service so the caller can
/// construct it externally and reference its `.res.lbIngressIp` Resolvable
/// (e.g. for a cross-plugin grafana Target). lgtm.pkl uses this to expose the
/// service handle to multi-plugin callers.
function allResourcesExceptSvc(k8sTarget: formae.Target, appNs: ns.Namespace, nsName: String, enableAdminAuth: Boolean) =
  if (enableAdminAuth)
    new Listing {
      adminSecret(k8sTarget, appNs)
      grafanaDeployment(k8sTarget, appNs, true)
    }
  else
    new Listing {
      datasourcesConfig(k8sTarget, appNs, nsName)
      dashboardProviderConfig(k8sTarget, appNs)
      demoDashboardConfig(k8sTarget, appNs)
      grafanaDeployment(k8sTarget, appNs, false)
    }
