// Example: Generate a static forma from bitnami/nginx.
//
// This outputs PKL source code that can be saved and used without pkl-reader-helm:
//
//   pkl eval nginx-static.pkl > nginx-forma.pkl
//   formae apply --mode reconcile nginx-forma.pkl
//
// Requires: pkl-reader-helm binary on PATH (only at generation time).

import "@formae-helm/v1.34/StaticGenerator.pkl"

local rel = new StaticGenerator.StaticHelmRelease {
  chart = "bitnami/nginx"
  version = "22.4.7"
  releaseName = "my-nginx"
  namespace = "formae-test"
  stackLabel = "helm-nginx"
  targetLabel = "k8s-local"
  targetContext = "orbstack"
  createNamespace = true
  values {
    replicaCount = 2
    service {
      type = "ClusterIP"
    }
    networkPolicy {
      enabled = false
    }
    podDisruptionBudget {
      create = false
    }
    tls {
      enabled = false
    }
  }
}

output {
  text = rel.pklSource
}
