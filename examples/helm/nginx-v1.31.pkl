/// nginx Helm chart pinned to K8s 1.31 wrappers — matches the local
/// kind cluster (formae-test-control-plane = v1.31.14).
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s
import "@k8s/v1.31/core/Namespace.pkl" as ns
import "@formae-helm/v1.31/HelmChart.pkl"

local chart = new HelmChart {
  chart = "bitnami/nginx"
  version = "22.4.7"
  releaseName = "my-nginx"
  namespace = "formae-helm-test"
  values = new Dynamic {
    replicaCount = 2
    service {
      type = "ClusterIP"
    }
    networkPolicy {
      enabled = false
    }
    podDisruptionBudget {
      create = false
    }
    tls {
      enabled = false
    }
  }
}

forma {
  new formae.Stack {
    label = "helm-nginx-v131"
    description = "Helm chart: bitnami/nginx 22.4.7 on K8s 1.31"
  }

  new formae.Target {
    label = "k8s-local"
    namespace = "K8S"
    config = new k8s.Config {
      kubernetesVersion = "1.31"
      defaultNamespace = "formae-helm-test"
      auth = new k8s.KubeconfigAuth {}
    }
  }

  new ns.Namespace {
    label = "my-nginx-namespace"
    metadata = new ns.NamespaceMetadata {
      name = "formae-helm-test"
    }
  }

  for (resource in chart.resources) {
    resource
  }
}
