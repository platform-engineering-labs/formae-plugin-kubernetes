/// Example: Generate a forma from bitnami/nginx using the Generator.
///
/// This produces a complete, standalone forma file when evaluated:
///
///   pkl eval -f pcf examples/helm/nginx-generator.pkl > nginx-forma.pcf
///   formae apply --mode reconcile nginx-forma.pcf
///
/// Requires: pkl-reader-helm binary on PATH, helm repos configured.
amends "@formae/forma.pkl"

import "@formae-helm/v1.34/Generator.pkl"

local rel = new Generator.HelmRelease {
  chart = "bitnami/nginx"
  version = "22.4.7"
  releaseName = "my-nginx"
  namespace = "formae-test"
  stackLabel = "helm-nginx"
  targetLabel = "k8s-local"
  targetContext = "orbstack"
  createNamespace = true
  values {
    replicaCount = 2
    service {
      type = "ClusterIP"
    }
    networkPolicy {
      enabled = false
    }
    podDisruptionBudget {
      create = false
    }
    tls {
      enabled = false
    }
  }
}

forma {
  for (entry in rel.formaEntries) {
    entry
  }
}
