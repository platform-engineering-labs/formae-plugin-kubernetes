/// nginx Helm chart pinned to K8s 1.34 wrappers.
///
/// Mirrors examples/helm/nginx-v1.31.pkl but targets the latest supported
/// K8s minor. Run against a kind cluster on v1.34.
///
/// Resolve Pkl dependencies (first time, or after PklProject changes):
///   pkl project resolve examples/helm/
///
/// Usage:
///   pkl eval examples/helm/nginx-v1.34.pkl
///   formae apply --mode reconcile --yes --watch examples/helm/nginx-v1.34.pkl
///
/// Requires:
///   - pkl-reader-helm binary on PATH (see helm/README.md "Install pkl-reader-helm")
///   - helm repos: helm repo add bitnami https://charts.bitnami.com/bitnami
///                 helm repo update
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s
import "@k8s/v1.34/core/Namespace.pkl" as ns
import "@k8s/helm/v1.34/HelmChart.pkl"

local chart = new HelmChart {
  chart = "bitnami/nginx"
  version = "22.4.7"
  releaseName = "my-nginx"
  namespace = "formae-helm-test"
  values = new Dynamic {
    replicaCount = 2
    service {
      type = "ClusterIP"
    }
    networkPolicy {
      enabled = false
    }
    podDisruptionBudget {
      create = false
    }
    tls {
      enabled = false
    }
  }
}

forma {
  new formae.Stack {
    label = "helm-nginx-v134"
    description = "Helm chart: bitnami/nginx 22.4.7 on K8s 1.34"
  }

  new formae.Target {
    label = "k8s-local"
    config = new k8s.Config {
      kubernetesVersion = "1.34"
      auth = new k8s.KubeconfigAuth {}
    }
  }

  new ns.Namespace {
    label = "my-nginx-namespace"
    metadata = new ns.NamespaceMetadata {
      name = "formae-helm-test"
    }
  }

  for (resource in chart.resources) {
    resource
  }
}
