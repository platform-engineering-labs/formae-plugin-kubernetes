/// bitnami/memcached standalone on K8s 1.31, via HelmChart.pkl.
///
/// Small in-memory cache. Smoke-runnable on a single-node KinD cluster.
///
/// Resolve Pkl dependencies (first time, or after PklProject changes):
///   pkl project resolve examples/helm/
///
/// Usage:
///   pkl eval examples/helm/memcached-v1.31.pkl
///   formae apply --mode reconcile --yes --watch examples/helm/memcached-v1.31.pkl
///
/// Requires:
///   - pkl-reader-helm binary on PATH (see helm/README.md "Install pkl-reader-helm")
///   - helm repos: helm repo add bitnami https://charts.bitnami.com/bitnami
///                 helm repo update
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@k8s/k8s.pkl" as k8s
import "@k8s/v1.31/core/Namespace.pkl" as ns
import "@formae-helm/v1.31/HelmChart.pkl"

local chart = new HelmChart {
  chart = "bitnami/memcached"
  version = "8.5.1"
  releaseName = "my-memcached"
  namespace = "formae-helm-test"
  values = new Dynamic {
    architecture = "standalone"
    auth {
      enabled = false
    }
    persistence {
      enabled = false
    }
    networkPolicy {
      enabled = false
    }
  }
}

forma {
  new formae.Stack {
    label = "helm-memcached-v131"
    description = "Helm chart: bitnami/memcached 8.5.1 on K8s 1.31"
  }

  new formae.Target {
    label = "k8s-local"
    config = new k8s.Config {
      kubernetesVersion = "1.31"
      auth = new k8s.KubeconfigAuth {}
    }
  }

  new ns.Namespace {
    label = "memcached-namespace"
    metadata = new ns.NamespaceMetadata {
      name = "formae-helm-test"
    }
  }

  for (resource in chart.resources) {
    resource
  }
}
