import "@formae/formae.pkl"
import "@aws/aws.pkl"

// ── Configurable properties ────────────────────────────────────────────────
projectName = "eks-fullstack"
clusterVersion = "1.34"
region = "us-west-2"
vpcCidr = "10.1.0.0/16"
subnetCidr1 = "10.1.1.0/24"
subnetCidr2 = "10.1.2.0/24"

// ── Formae properties (CLI-overridable via --prop) ─────────────────────────
props = new Dynamic {
  name = new formae.Prop {
    flag = "name"
    default = module.projectName
  }
  region = new formae.Prop {
    flag = "region"
    default = module.region
  }
  clusterVersion = new formae.Prop {
    flag = "cluster-version"
    default = module.clusterVersion
  }
  vpcCidr = new formae.Prop {
    flag = "vpcCidr"
    default = module.vpcCidr
  }
  subnetCidr1 = new formae.Prop {
    flag = "subnetCidr1"
    default = module.subnetCidr1
  }
  subnetCidr2 = new formae.Prop {
    flag = "subnetCidr2"
    default = module.subnetCidr2
  }
}

// ── Stack & Target ─────────────────────────────────────────────────────────
stack: formae.Stack = new {
  label = "eks-fullstack"
  description = "EKS cluster for full-stack Formae demo"
}

target: formae.Target = new formae.Target {
  label = "eks-aws-target"
  config = new aws.Config {
    region = module.props.region.value
  }
}

// Allow direct `pkl eval` of this library file. Without the Class converter,
// the PcfRenderer/JsonRenderer default fails on formae framework fields like
// `fixed Type: Class = type`. Library imports into entrypoint files are
// unaffected — `output` only applies to direct evaluation.
output {
  renderer = new JsonRenderer {
    converters {
      [Class] = (it) -> it.toString()
    }
  }
}
