/*
 * Example: nginx ingress controller
 *
 * Deploys the nginx ingress controller so that Ingress resources are served.
 * This is infrastructure — deploy once per cluster, then use webapp.pkl.
 *
 * Resources:
 *   - Namespace (ingress-nginx)
 *   - ServiceAccount
 *   - ClusterRole + ClusterRoleBinding (RBAC for watching Ingress/Service/Endpoints)
 *   - ConfigMap (nginx configuration)
 *   - Deployment (the controller itself)
 *   - Service (NodePort to expose on ports 80/443)
 *   - IngressClass (nginx, set as default)
 *
 * Deploy:
 *   formae apply examples/nginx-ingress.pkl
 *
 * Verify:
 *   kubectl -n ingress-nginx get pods     # controller should be Running
 *   kubectl get ingressclass              # "nginx" should appear
 *
 * Teardown:
 *   formae destroy examples/nginx-ingress.pkl
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/core/Namespace.pkl" as ns
import "@k8s/core/ConfigMap.pkl" as cm
import "@k8s/core/ServiceAccount.pkl" as sa
import "@k8s/core/Service.pkl" as svc
import "@k8s/apps/Deployment.pkl" as dep
import "@k8s/rbac/ClusterRole.pkl" as cr
import "@k8s/rbac/ClusterRoleBinding.pkl" as crb
import "@k8s/networking/IngressClass.pkl" as ic
import "@k8s/k8s.pkl" as k8s

// ---------------------------------------------------------------------------
// Configuration
// ---------------------------------------------------------------------------
local controllerImage = "registry.k8s.io/ingress-nginx/controller:v1.12.0"

local appLabels = new Mapping {
  ["app"] = "ingress-nginx"
  ["managed-by"] = "formae"
}

forma {
  new formae.Stack {
    label = "ingress-nginx-stack"
    description = "nginx ingress controller"
  }

  new formae.Target {
    label = "ingress-nginx-target"
    namespace = "K8S"
    config = new k8s.Config {
      waitForLoadBalancer = false
    }
  }

  // -------------------------------------------------------------------------
  // Namespace
  // -------------------------------------------------------------------------
  local ingressNs = new ns.Namespace {
    label = "ingress-nginx-ns"
    metadata = new ns.NamespaceMetadata {
      name = "ingress-nginx"
      labels = appLabels
    }
  }

  ingressNs

  // -------------------------------------------------------------------------
  // ServiceAccount
  // -------------------------------------------------------------------------
  new sa.ServiceAccount {
    label = "ingress-nginx-sa"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx"
      namespace = ingressNs.res.name
      labels = appLabels
    }
  }

  // -------------------------------------------------------------------------
  // ClusterRole — permissions the controller needs
  // -------------------------------------------------------------------------
  new cr.ClusterRole {
    label = "ingress-nginx-role"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx"
      labels = appLabels
    }
    rules = new Listing {
      new k8s.PolicyRule {
        apiGroups = new Listing { "" }
        resources = new Listing { "configmaps"; "endpoints"; "nodes"; "pods"; "secrets"; "services" }
        verbs = new Listing { "get"; "list"; "watch" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "" }
        resources = new Listing { "events" }
        verbs = new Listing { "create"; "patch" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "" }
        resources = new Listing { "nodes" }
        verbs = new Listing { "get" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "networking.k8s.io" }
        resources = new Listing { "ingresses"; "ingressclasses" }
        verbs = new Listing { "get"; "list"; "watch" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "networking.k8s.io" }
        resources = new Listing { "ingresses/status" }
        verbs = new Listing { "update" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "coordination.k8s.io" }
        resources = new Listing { "leases" }
        verbs = new Listing { "get"; "list"; "watch"; "create"; "update" }
      }
      new k8s.PolicyRule {
        apiGroups = new Listing { "discovery.k8s.io" }
        resources = new Listing { "endpointslices" }
        verbs = new Listing { "get"; "list"; "watch" }
      }
    }
  }

  // -------------------------------------------------------------------------
  // ClusterRoleBinding
  // -------------------------------------------------------------------------
  new crb.ClusterRoleBinding {
    label = "ingress-nginx-binding"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx"
      labels = appLabels
    }
    roleRef = new k8s.RoleRef {
      kind = "ClusterRole"
      name = "ingress-nginx"
    }
    subjects = new Listing {
      new k8s.Subject {
        kind = "ServiceAccount"
        name = "ingress-nginx"
        namespace = "ingress-nginx"
      }
    }
  }

  // -------------------------------------------------------------------------
  // ConfigMap — nginx controller configuration
  // -------------------------------------------------------------------------
  new cm.ConfigMap {
    label = "ingress-nginx-config"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx-controller"
      namespace = ingressNs.res.name
      labels = appLabels
    }
    data = new Mapping {
      ["use-forwarded-headers"] = "true"
    }
  }

  // -------------------------------------------------------------------------
  // Deployment — the ingress controller
  // -------------------------------------------------------------------------
  new dep.Deployment {
    label = "ingress-nginx-controller"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx-controller"
      namespace = ingressNs.res.name
      labels = appLabels
    }
    spec = new dep.DeploymentSpec {
      replicas = 1
      selector = new k8s.LabelSelector {
        matchLabels = appLabels
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.PodTemplateMetadata {
          labels = appLabels
        }
        spec = new k8s.PodSpec {
          serviceAccountName = "ingress-nginx"
          containers = new Listing {
            new k8s.Container {
              name = "controller"
              image = controllerImage
              args = new Listing {
                "/nginx-ingress-controller"
                "--election-id=ingress-nginx-leader"
                "--controller-class=k8s.io/ingress-nginx"
                "--ingress-class=nginx"
                "--configmap=ingress-nginx/ingress-nginx-controller"
                "--publish-service=ingress-nginx/ingress-nginx-controller"
              }
              ports = new Listing {
                new k8s.ContainerPort {
                  name = "http"
                  containerPort = 80
                }
                new k8s.ContainerPort {
                  name = "https"
                  containerPort = 443
                }
              }
              env = new Listing {
                new k8s.EnvVar {
                  name = "POD_NAME"
                  valueFrom = new k8s.EnvVarSource {
                    fieldRef = new k8s.ObjectFieldSelector { fieldPath = "metadata.name" }
                  }
                }
                new k8s.EnvVar {
                  name = "POD_NAMESPACE"
                  valueFrom = new k8s.EnvVarSource {
                    fieldRef = new k8s.ObjectFieldSelector { fieldPath = "metadata.namespace" }
                  }
                }
              }
              resources = new k8s.ResourceRequirements {
                requests = new Mapping {
                  ["cpu"] = "100m"
                  ["memory"] = "90Mi"
                }
              }
            }
          }
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // Service — expose the controller via NodePort
  // -------------------------------------------------------------------------
  new svc.Service {
    label = "ingress-nginx-svc"
    metadata = new k8s.ObjectMeta {
      name = "ingress-nginx-controller"
      namespace = ingressNs.res.name
      labels = appLabels
    }
    spec = new svc.ServiceSpec {
      type = "NodePort"
      selector = appLabels
      ports = new Listing {
        new svc.ServicePort {
          name = "http"
          port = 80
          targetPort = 80
        }
        new svc.ServicePort {
          name = "https"
          port = 443
          targetPort = 443
        }
      }
    }
  }

  // -------------------------------------------------------------------------
  // IngressClass — makes "nginx" available as an ingress class
  // -------------------------------------------------------------------------
  new ic.IngressClass {
    label = "ingress-nginx-class"
    metadata = new k8s.ObjectMeta {
      name = "nginx"
      labels = appLabels
      annotations = new Mapping {
        ["ingressclass.kubernetes.io/is-default-class"] = "true"
      }
    }
    spec = new ic.IngressClassSpec {
      controller = "k8s.io/ingress-nginx"
    }
  }
}
