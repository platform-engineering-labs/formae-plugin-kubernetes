/// HelmChart: Render a Helm chart and map its output to k8s types.
///
/// Usage in a forma file:
/// ```pkl
/// import "@formae-helm/HelmChart.pkl"
///
/// local chart = new HelmChart {
///   chart = "bitnami/nginx"
///   version = "22.4.7"
///   releaseName = "my-nginx"
///   namespace = "formae-test"
///   values = new Dynamic {
///     replicaCount = 2
///     service { type = "ClusterIP" }
///   }
/// }
///
/// forma {
///   // stack, target...
///   for (resource in chart.resources) {
///     resource
///   }
/// }
/// ```
module HelmChart

import "@helm/helm.pkl"
import "@formae/formae.pkl"

import "mappers/dispatch.pkl"

/// Helm chart reference (e.g., "bitnami/nginx").
chart: String

/// Chart version to render (e.g., "22.4.7").
version: String

/// Helm release name — used in resource naming and label prefix.
releaseName: String

/// Target namespace for namespaced resources.
namespace: String = "default"

/// Helm values to pass to the chart. Use `new Dynamic { ... }` syntax.
values: Dynamic? = null

/// Prefix for Formae resource labels. Defaults to releaseName.
labelPrefix: String = releaseName

/// When true, silently skip resource types not supported by k8s.
/// When false, throw on unsupported types.
skipUnsupported: Boolean = true

/// The rendered Helm chart resources, mapped to k8s types.
/// Ready to be spread into a `forma {}` block.
resources: Listing<formae.Resource> = new Listing {
  for (_key, _res in _rendered) {
    when (dispatch.isSupported(_res.apiVersion, _res.kind)) {
      dispatch.mapResource(_res, labelPrefix, namespace)
    }
    // Kinds without a typed mapper (CRDs the chart ships, custom-resource
    // instances) fall back to the generic K8S::Custom::Resource catch-all, so
    // one HelmChart installs an operator end-to-end. Set skipUnsupported = false
    // to instead throw on any non-typed kind (strict, typed-only mode).
    when (!dispatch.isSupported(_res.apiVersion, _res.kind) && skipUnsupported) {
      dispatch.mapCustom(_res, labelPrefix)
    }
    when (!dispatch.isSupported(_res.apiVersion, _res.kind) && !skipUnsupported) {
      throw("Unsupported resource type: \(_res.apiVersion)/\(_res.kind) (\(_res.metadata.name)). Set skipUnsupported = true to map it via K8S::Custom::Resource.")
    }
  }
}

/// Internal: the raw helm template output.
///
/// `helm.Template.values` is typed `Any` (no default) and the
/// renderer reads it eagerly even when the chart needs no overrides;
/// pass an empty Dynamic instead of leaving the field unset to avoid
/// "Tried to read property `values` but its value is undefined".
hidden _rendered = (new helm.Template {
  chart = module.chart
  version = module.version
  releaseName = module.releaseName
  namespace = module.namespace
  values = module.values ?? new Dynamic {}
}).resources
