module endpoints

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Core::Endpoints"

@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class Endpoints extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  @k8s.FieldHint { required = true }
  apiVersion: String = "v1"

  @k8s.FieldHint { required = true }
  kind: String = "Endpoints"

  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// Sets of addresses and ports
  @k8s.FieldHint {}
  subsets: Listing<EndpointSubset>?
}

/// EndpointSubset is a group of addresses with a common set of ports.
@k8s.SubResourceHint {}
open class EndpointSubset extends formae.SubResource {
  /// IP addresses
  @k8s.FieldHint {}
  addresses: Listing<EndpointAddress>?

  /// Port numbers
  @k8s.FieldHint {}
  ports: Listing<EndpointPort>?
}

/// EndpointAddress is an address of an endpoint.
@k8s.SubResourceHint {}
open class EndpointAddress extends formae.SubResource {
  @k8s.FieldHint { required = true }
  ip: String
}

/// EndpointPort is a tuple that describes a single port.
@k8s.SubResourceHint {}
open class EndpointPort extends formae.SubResource {
  @k8s.FieldHint { required = true }
  port: Int

  @k8s.FieldHint {}
  protocol: String?

  @k8s.FieldHint {}
  name: String?
}
