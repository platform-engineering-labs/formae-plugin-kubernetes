module secret

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Core::Secret"

/// K8S Secret resource.
/// Secrets hold sensitive data such as passwords, tokens, or keys.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class Secret extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for Secret is always "v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "v1"

  /// Kind is always "Secret"
  @k8s.FieldHint { required = true }
  kind: String = "Secret"

  /// Secret metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// Type of the secret (e.g., "Opaque", "kubernetes.io/tls").
  /// Immutable after creation.
  @k8s.FieldHint { createOnly = true }
  type: String?

  /// Data contains the secret data as base64-encoded strings.
  @k8s.FieldHint {}
  data: Mapping<String, String>?

  /// StringData allows specifying non-binary secret data in string form.
  /// It is write-only and merged into data on create/update.
  @k8s.FieldHint {}
  stringData: Mapping<String, String>?

  /// Immutable, if set to true, ensures that data stored in the Secret cannot be updated.
  @k8s.FieldHint {}
  immutable: Boolean?
}
