module serviceaccount

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Core::ServiceAccount"

/// K8S ServiceAccount resource.
/// ServiceAccounts provide an identity for processes that run in a Pod.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class ServiceAccount extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for ServiceAccount is always "v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "v1"

  /// Kind is always "ServiceAccount"
  @k8s.FieldHint { required = true }
  kind: String = "ServiceAccount"

  /// ServiceAccount metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// AutomountServiceAccountToken indicates whether pods running as this service account
  /// should have an API token automatically mounted.
  @k8s.FieldHint {}
  automountServiceAccountToken: Boolean?

  /// ImagePullSecrets is a list of references to secrets for pulling images.
  @k8s.FieldHint {}
  imagePullSecrets: Listing<LocalObjectReference>?
}

/// LocalObjectReference contains enough information to locate the referenced object.
@k8s.SubResourceHint {}
open class LocalObjectReference extends formae.SubResource {
  /// Name of the referent.
  @k8s.FieldHint { required = true }
  name: String
}
