module service

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Core::Service"

/// K8S Service resource.
/// A Service exposes a set of Pods as a network service.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class Service extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for Service is always "v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "v1"

  /// Kind is always "Service"
  @k8s.FieldHint { required = true }
  kind: String = "Service"

  /// Service metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// Service specification
  @k8s.FieldHint { required = true }
  spec: ServiceSpec
}

/// ServiceSpec defines the desired state of a Service.
@k8s.SubResourceHint {}
open class ServiceSpec extends formae.SubResource {
  /// Type of service: ClusterIP, NodePort, LoadBalancer, ExternalName.
  @k8s.FieldHint {}
  type: String?

  /// Selector selects pods to route traffic to.
  @k8s.FieldHint {}
  selector: Mapping<String, String>?

  /// Ports exposed by the service.
  @k8s.FieldHint {
    updateMethod = "EntitySet"
    indexField = "port"
  }
  ports: Listing<ServicePort>?

  /// ClusterIP is the IP address of the service.
  /// Usually assigned by the system. Set to "None" for headless services.
  @k8s.FieldHint {}
  clusterIP: String?

  /// ExternalTrafficPolicy denotes if this Service desires to route external
  /// traffic to node-local or cluster-wide endpoints.
  @k8s.FieldHint {}
  externalTrafficPolicy: String?

  /// SessionAffinity enables client IP-based session affinity.
  @k8s.FieldHint {}
  sessionAffinity: String?
}

/// ServicePort defines a port exposed by a Service.
@k8s.SubResourceHint {}
open class ServicePort extends formae.SubResource {
  /// Name of the port (required if multiple ports).
  @k8s.FieldHint {}
  name: String?

  /// Port number exposed by the service.
  @k8s.FieldHint { required = true }
  port: Int

  /// Target port on the pod.
  @k8s.FieldHint {}
  targetPort: (Int|String)?

  /// Protocol (TCP, UDP, SCTP). Defaults to TCP.
  @k8s.FieldHint {}
  protocol: String?

  /// NodePort is the port on each node (for NodePort/LoadBalancer services).
  @k8s.FieldHint {}
  nodePort: Int?
}
