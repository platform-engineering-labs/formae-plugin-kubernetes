module role

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Rbac::Role"

@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class Role extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  @k8s.FieldHint { required = true }
  apiVersion: String = "rbac.authorization.k8s.io/v1"

  @k8s.FieldHint { required = true }
  kind: String = "Role"

  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// List of policy rules
  @k8s.FieldHint { required = true }
  rules: Listing<PolicyRule>
}

/// PolicyRule holds information that describes a policy rule.
@k8s.SubResourceHint {}
open class PolicyRule extends formae.SubResource {
  /// API groups this rule applies to
  @k8s.FieldHint {}
  apiGroups: Listing<String>?

  /// Resources this rule applies to
  @k8s.FieldHint {}
  resources: Listing<String>?

  /// Verbs (get, list, watch, create, update, delete, etc.)
  @k8s.FieldHint { required = true }
  verbs: Listing<String>

  /// Resource names this rule applies to (optional restriction)
  @k8s.FieldHint {}
  resourceNames: Listing<String>?
}
