/// Mappers for core/v1 K8S resource types.
module core

import "../../../v1.32/subresources.pkl" as k8s
import "../../../v1.32/core/Namespace.pkl" as ns
import "../../../v1.32/core/Pod.pkl" as pod
import "../../../v1.32/core/ConfigMap.pkl" as cm
import "../../../v1.32/core/Secret.pkl" as secret
import "../../../v1.32/core/ServiceAccount.pkl" as sa
import "../../../v1.32/core/Service.pkl" as svc
import "../../../v1.32/core/Endpoints.pkl" as ep
import "../../../v1.32/core/LimitRange.pkl" as lr
import "../../../v1.32/core/PersistentVolume.pkl" as pv
import "../../../v1.32/core/PersistentVolumeClaim.pkl" as pvc
import "../../../v1.32/core/ResourceQuota.pkl" as rq

import "common.pkl"

// =============================================================================
// Namespace (cluster-scoped)
// =============================================================================

function mapNamespace(src: Any, prefix: String, _namespace: String): ns.Namespace =
  new ns.Namespace {
    label = common.makeLabel(prefix, "namespace", src.metadata.name)
    metadata = common.mapNamespaceMetadata(src.metadata)
  }

// =============================================================================
// Pod
// =============================================================================

function mapPod(src: Any, prefix: String, namespace: String): pod.Pod =
  new pod.Pod {
    label = common.makeLabel(prefix, "pod", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = common.mapPodSpec(src.spec)
  }

// =============================================================================
// ConfigMap
// =============================================================================

function mapConfigMap(src: Any, prefix: String, namespace: String): cm.ConfigMap =
  new cm.ConfigMap {
    label = common.makeLabel(prefix, "configmap", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    when (src.data != null) {
      data = common.mapStringMapping(src.data)
    }
    when (src.binaryData != null) {
      binaryData = common.mapStringMapping(src.binaryData)
    }
    when (src.immutable != null) {
      immutable = src.immutable
    }
  }

// =============================================================================
// Secret
// =============================================================================

function mapSecret(src: Any, prefix: String, namespace: String): secret.Secret =
  new secret.Secret {
    label = common.makeLabel(prefix, "secret", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    when (src.type != null) {
      type = src.type
    }
    when (src.data != null) {
      data = common.mapStringMapping(src.data)
    }
    when (src.stringData != null) {
      stringData = common.mapStringMapping(src.stringData)
    }
    when (src.immutable != null) {
      immutable = src.immutable
    }
  }

// =============================================================================
// ServiceAccount
// =============================================================================

function mapServiceAccount(src: Any, prefix: String, namespace: String): sa.ServiceAccount =
  new sa.ServiceAccount {
    label = common.makeLabel(prefix, "serviceaccount", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    when (src.automountServiceAccountToken != null) {
      automountServiceAccountToken = src.automountServiceAccountToken
    }
    when (src.imagePullSecrets != null) {
      imagePullSecrets = new Listing {
        for (_ref in src.imagePullSecrets) {
          new sa.LocalObjectReference {
            name = _ref.name
          }
        }
      }
    }
  }

// =============================================================================
// Service
// =============================================================================

function mapService(src: Any, prefix: String, namespace: String): svc.Service =
  new svc.Service {
    label = common.makeLabel(prefix, "service", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = mapServiceSpec(src.spec)
  }

function mapServiceSpec(src: Any): svc.ServiceSpec =
  new svc.ServiceSpec {
    when (src.type != null) {
      type = src.type
    }
    when (src.selector != null) {
      selector = common.mapStringMapping(src.selector)
    }
    when (src.ports != null) {
      ports = new Listing {
        for (_p in src.ports) {
          mapServicePort(_p)
        }
      }
    }
    when (src.clusterIP != null) {
      clusterIP = src.clusterIP
    }
    when (src.externalTrafficPolicy != null) {
      externalTrafficPolicy = src.externalTrafficPolicy
    }
    when (src.sessionAffinity != null) {
      sessionAffinity = src.sessionAffinity
    }
  }

function mapServicePort(src: Any): svc.ServicePort =
  new svc.ServicePort {
    port = src.port
    when (src.name != null) {
      name = src.name
    }
    when (src.targetPort != null) {
      targetPort = src.targetPort
    }
    when (src.protocol != null) {
      protocol = src.protocol
    }
    when (src.nodePort != null) {
      nodePort = src.nodePort
    }
  }

// =============================================================================
// Endpoints
// =============================================================================

function mapEndpoints(src: Any, prefix: String, namespace: String): ep.Endpoints =
  new ep.Endpoints {
    label = common.makeLabel(prefix, "endpoints", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    when (src.subsets != null) {
      subsets = new Listing {
        for (_subset in src.subsets) {
          new ep.EndpointSubset {
            when (_subset.addresses != null) {
              addresses = new Listing {
                for (_addr in _subset.addresses) {
                  new ep.EndpointAddress {
                    ip = _addr.ip
                  }
                }
              }
            }
            when (_subset.ports != null) {
              ports = new Listing {
                for (_p in _subset.ports) {
                  new ep.EndpointPort {
                    port = _p.port
                    when (_p.protocol != null) {
                      protocol = _p.protocol
                    }
                    when (_p.name != null) {
                      name = _p.name
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }

// =============================================================================
// LimitRange
// =============================================================================

function mapLimitRange(src: Any, prefix: String, namespace: String): lr.LimitRange =
  new lr.LimitRange {
    label = common.makeLabel(prefix, "limitrange", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = new lr.LimitRangeSpec {
      limits = new Listing {
        for (_item in src.spec.limits) {
          new lr.LimitRangeItem {
            type = _item.type
            when (_item.max != null) {
              max = common.mapQuantityMapping(_item.max)
            }
            when (_item.min != null) {
              min = common.mapQuantityMapping(_item.min)
            }
            when (_item.default != null) {
              default = common.mapQuantityMapping(_item.default)
            }
            when (_item.defaultRequest != null) {
              defaultRequest = common.mapQuantityMapping(_item.defaultRequest)
            }
          }
        }
      }
    }
  }

// =============================================================================
// PersistentVolume (cluster-scoped)
// =============================================================================

function mapPersistentVolume(src: Any, prefix: String, _namespace: String): pv.PersistentVolume =
  new pv.PersistentVolume {
    label = common.makeLabel(prefix, "persistentvolume", src.metadata.name)
    metadata = common.mapClusterMeta(src.metadata)
    spec = new pv.PersistentVolumeSpec {
      capacity = common.mapQuantityMapping(src.spec.capacity)
      accessModes = common.mapStringListing(src.spec.accessModes)
      when (src.spec.persistentVolumeReclaimPolicy != null) {
        persistentVolumeReclaimPolicy = src.spec.persistentVolumeReclaimPolicy
      }
      when (src.spec.storageClassName != null) {
        storageClassName = src.spec.storageClassName
      }
      when (src.spec.volumeMode != null) {
        volumeMode = src.spec.volumeMode
      }
      when (src.spec.hostPath != null) {
        hostPath = new pv.HostPathVolumeSource {
          path = src.spec.hostPath.path
          when (src.spec.hostPath.type != null) {
            type = src.spec.hostPath.type
          }
        }
      }
    }
  }

// =============================================================================
// PersistentVolumeClaim
// =============================================================================

function mapPersistentVolumeClaim(src: Any, prefix: String, namespace: String): pvc.PersistentVolumeClaim =
  new pvc.PersistentVolumeClaim {
    label = common.makeLabel(prefix, "persistentvolumeclaim", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = new pvc.PersistentVolumeClaimSpec {
      accessModes = common.mapStringListing(src.spec.accessModes)
      resources = new k8s.ResourceRequirements {
        requests = common.mapQuantityMapping(src.spec.resources.requests)
      }
      when (src.spec.storageClassName != null) {
        storageClassName = src.spec.storageClassName
      }
      when (src.spec.volumeName != null) {
        volumeName = src.spec.volumeName
      }
      when (src.spec.volumeMode != null) {
        volumeMode = src.spec.volumeMode
      }
    }
  }

// =============================================================================
// ResourceQuota
// =============================================================================

function mapResourceQuota(src: Any, prefix: String, namespace: String): rq.ResourceQuota =
  new rq.ResourceQuota {
    label = common.makeLabel(prefix, "resourcequota", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = new rq.ResourceQuotaSpec {
      when (src.spec.hard != null) {
        hard = common.mapQuantityMapping(src.spec.hard)
      }
      when (src.spec.scopes != null) {
        scopes = common.mapStringListing(src.spec.scopes)
      }
    }
  }
