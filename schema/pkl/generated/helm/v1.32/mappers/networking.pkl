/// Mappers for networking.k8s.io/v1 K8S resource types.
module networking

import "../../../k8s.pkl" as k8s
import "../../../v1.32/apps/ReplicaSet.pkl" as rs
import "../../../v1.32/networking/Ingress.pkl" as ing
import "../../../v1.32/networking/IngressClass.pkl" as ic
import "../../../v1.32/networking/NetworkPolicy.pkl" as np

import "common.pkl"

// =============================================================================
// Ingress
// =============================================================================

function mapIngress(src: Any, prefix: String, namespace: String): ing.Ingress =
  new ing.Ingress {
    label = common.makeLabel(prefix, "ingress", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = mapIngressSpec(src.spec)
  }

function mapIngressSpec(src: Any): ing.IngressSpec =
  new ing.IngressSpec {
    when (src.ingressClassName != null) {
      ingressClassName = src.ingressClassName
    }
    when (src.defaultBackend != null) {
      defaultBackend = mapIngressBackend(src.defaultBackend)
    }
    when (src.tls != null) {
      tls = new Listing {
        for (_t in src.tls) {
          new ing.IngressTLS {
            when (_t.hosts != null) {
              hosts = common.mapStringListing(_t.hosts)
            }
            when (_t.secretName != null) {
              secretName = _t.secretName
            }
          }
        }
      }
    }
    when (src.rules != null) {
      rules = new Listing {
        for (_rule in src.rules) {
          mapIngressRule(_rule)
        }
      }
    }
  }

function mapIngressRule(src: Any): ing.IngressRule =
  new ing.IngressRule {
    when (src.host != null) {
      host = src.host
    }
    when (src.http != null) {
      http = new ing.HTTPIngressRuleValue {
        paths = new Listing {
          for (_path in src.http.paths) {
            new ing.HTTPIngressPath {
              when (_path.path != null) {
                path = _path.path
              }
              pathType = _path.pathType
              backend = mapIngressBackend(_path.backend)
            }
          }
        }
      }
    }
  }

function mapIngressBackend(src: Any): ing.IngressBackend =
  new ing.IngressBackend {
    when (src.service != null) {
      service = new ing.IngressServiceBackend {
        name = src.service.name
        port = new ing.ServiceBackendPort {
          when (src.service.port.name != null) {
            name = src.service.port.name
          }
          when (src.service.port.number != null) {
            number = src.service.port.number
          }
        }
      }
    }
  }

// =============================================================================
// IngressClass (cluster-scoped)
// =============================================================================

function mapIngressClass(src: Any, prefix: String, _namespace: String): ic.IngressClass =
  new ic.IngressClass {
    label = common.makeLabel(prefix, "ingressclass", src.metadata.name)
    metadata = common.mapClusterMeta(src.metadata)
    when (src.spec != null) {
      spec = new ic.IngressClassSpec {
        when (src.spec.controller != null) {
          controller = src.spec.controller
        }
        when (src.spec.parameters != null) {
          parameters = new ic.IngressClassParametersReference {
            kind = src.spec.parameters.kind
            name = src.spec.parameters.name
            when (src.spec.parameters.apiGroup != null) {
              apiGroup = src.spec.parameters.apiGroup
            }
            when (src.spec.parameters.namespace != null) {
              namespace = src.spec.parameters.namespace
            }
            when (src.spec.parameters.scope != null) {
              scope = src.spec.parameters.scope
            }
          }
        }
      }
    }
  }

// =============================================================================
// NetworkPolicy
// =============================================================================

function mapNetworkPolicy(src: Any, prefix: String, namespace: String): np.NetworkPolicy =
  new np.NetworkPolicy {
    label = common.makeLabel(prefix, "networkpolicy", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = mapNetworkPolicySpec(src.spec)
  }

function mapNetworkPolicySpec(src: Any): np.NetworkPolicySpec =
  new np.NetworkPolicySpec {
    podSelector = common.mapLabelSelector(src.podSelector)
    when (src.ingress != null) {
      ingress = new Listing {
        for (_rule in src.ingress) {
          new np.NetworkPolicyIngressRule {
            when (_rule.from != null) {
              from = new Listing {
                for (_peer in _rule.from) {
                  mapNetworkPolicyPeer(_peer)
                }
              }
            }
            when (_rule.ports != null) {
              ports = new Listing {
                for (_p in _rule.ports) {
                  mapNetworkPolicyPort(_p)
                }
              }
            }
          }
        }
      }
    }
    when (src.egress != null) {
      egress = new Listing {
        for (_rule in src.egress) {
          new np.NetworkPolicyEgressRule {
            when (_rule.to != null) {
              to = new Listing {
                for (_peer in _rule.to) {
                  mapNetworkPolicyPeer(_peer)
                }
              }
            }
            when (_rule.ports != null) {
              ports = new Listing {
                for (_p in _rule.ports) {
                  mapNetworkPolicyPort(_p)
                }
              }
            }
          }
        }
      }
    }
    when (src.policyTypes != null) {
      policyTypes = common.mapStringListing(src.policyTypes)
    }
  }

function mapNetworkPolicyPeer(src: Any): np.NetworkPolicyPeer =
  new np.NetworkPolicyPeer {
    when (src.podSelector != null) {
      podSelector = common.mapLabelSelector(src.podSelector)
    }
    when (src.namespaceSelector != null) {
      namespaceSelector = common.mapLabelSelector(src.namespaceSelector)
    }
    when (src.ipBlock != null) {
      ipBlock = new np.IPBlock {
        cidr = src.ipBlock.cidr
        when (src.ipBlock.except != null) {
          except = common.mapStringListing(src.ipBlock.except)
        }
      }
    }
  }

function mapNetworkPolicyPort(src: Any): np.NetworkPolicyPort =
  new np.NetworkPolicyPort {
    when (src.port != null) {
      port = src.port
    }
    when (src.protocol != null) {
      protocol = src.protocol
    }
  }
