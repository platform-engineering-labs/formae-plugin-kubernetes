/// Mappers for policy/v1 K8S resource types.
module policy

import "../../../v1.35/subresources.pkl" as k8s
import "../../../v1.35/policy/PodDisruptionBudget.pkl" as pdb
import "../../../v1.35/apps/ReplicaSet.pkl" as rs

import "common.pkl"

// =============================================================================
// PodDisruptionBudget
// =============================================================================

function mapPodDisruptionBudget(src: Any, prefix: String, namespace: String): pdb.PodDisruptionBudget =
  new pdb.PodDisruptionBudget {
    label = common.makeLabel(prefix, "poddisruptionbudget", src.metadata.name)
    metadata = common.mapObjectMeta(src.metadata, namespace)
    spec = new pdb.PodDisruptionBudgetSpec {
      when (src.spec.minAvailable != null) {
        minAvailable = src.spec.minAvailable
      }
      when (src.spec.maxUnavailable != null) {
        maxUnavailable = src.spec.maxUnavailable
      }
      when (src.spec.selector != null) {
        selector = common.mapLabelSelector(src.spec.selector)
      }
    }
  }
