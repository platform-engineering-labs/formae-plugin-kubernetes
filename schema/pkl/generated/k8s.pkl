  @FieldHint {}
  kind: String?

  @FieldHint {}
  namespace: String?

  @FieldHint {}
  name: (String|formae.Resolvable)?

  @FieldHint {}
  uid: String?

  @FieldHint {}
  resourceVersion: String?

  @FieldHint {}
  fieldPath: String?
}

