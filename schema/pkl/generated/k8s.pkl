// =============================================================================
// Native typealiases
// -----------------------------------------------------------------------------
// Constrained primitives that mirror Kubernetes API validation. Used across
// every resource module so phantom typos (a port of 0, a memory string
// without a unit, a negative replica count) fail at `pkl eval` time rather
// than at SSA apply.
// =============================================================================

/// Kubernetes minor version: `MAJOR.MINOR` only, no `v` prefix, no patch.
/// e.g. `"1.27"`. Used for the target `kubernetesVersion` and for the
/// `@K8sVersion` annotation fields.
typealias KubernetesMinorVersion = String(matches(Regex(#"^\d+\.\d+$"#)))

/// Kubernetes resource Quantity (`resource.Quantity`).
/// Decimal SI: `k|M|G|T|P|E`. Binary SI: `Ki|Mi|Gi|Ti|Pi|Ei`. CPU fractional: `m`.
/// Sub-unit decimals: `m|u|n`. Scientific notation also accepted (e.g. `1e3`).
/// Examples: `"100m"`, `"1Gi"`, `"512Mi"`, `"2"`, `"1.5"`, `"1e3"`.
typealias Quantity = String(matches(Regex(#"^[+-]?(\d+(\.\d*)?|\.\d+)((e[+-]?\d+)|([numkMGTPE]i?))?$"#)))

/// Mapping of resource name (`cpu`, `memory`, `ephemeral-storage`, `hugepages-2Mi`, …) → Quantity.
typealias ResourceQuantities = Mapping<String, Quantity>

/// TCP/UDP/SCTP port number, 1..65535 inclusive. Disallows port 0.
typealias PortNumber = Int(isBetween(1, 65535))

/// L4 protocol accepted by Kubernetes ports.
typealias Protocol = "TCP"|"UDP"|"SCTP"

/// Affinity / topology-spread weight. apiserver enforces 1..100.
typealias Weight = Int(isBetween(1, 100))

/// HPA `stabilizationWindowSeconds`. apiserver enforces 0..3600.
typealias StabilizationWindowSeconds = Int(isBetween(0, 3600))

/// Unix file-permission mode bits. 0..0o777 (0..511 decimal).
/// K8s serializes file modes as decimal integers, so `0o644` and `420` are equivalent.
typealias FileMode = Int(isBetween(0, 0o777))

/// Non-negative 32-bit integer. For replica counts, retention limits, history limits, etc.
typealias NonNegativeInt = Int(isBetween(0, 2147483647))

/// Positive 32-bit integer (>= 1). For periods, deadlines, lease durations, etc.
typealias PositiveInt = Int(isBetween(1, 2147483647))

/// Signed 32-bit integer. For PriorityClass `value`, container exitCode, etc.
typealias Int32 = Int(isBetween(-2147483648, 2147483647))

/// Unix user / group ID. Non-negative 32-bit unsigned integer.
typealias UnixID = Int(isBetween(0, 4294967295))

/// Kubernetes `IntOrString`: an int or a percent-style string like `"25%"`.
typealias IntOrString = (Int|String)

/// Percentage string, e.g. `"25%"`. 0..100% accepted.
typealias Percentage = String(matches(Regex(#"^([0-9]|[1-9][0-9]|100)%$"#)))

/// 0..100 inclusive — used for lendable / utilization percents.
typealias Percent = Int(isBetween(0, 100))

/// Flow-control percent: `-1` sentinel allowed (means "unbounded") plus 0..100.
/// Used for `borrowingLimitPercent`.
typealias FlowControlPercent = Int(isBetween(-1, 100))

/// FlowSchema `matchingPrecedence`. apiserver enforces 1..10000.
typealias MatchingPrecedence = Int(isBetween(1, 10000))

/// Admission webhook `timeoutSeconds`. apiserver enforces 1..30.
typealias WebhookTimeoutSeconds = Int(isBetween(1, 30))

/// IPv4 or IPv6 address (dotted-quad or colon-hex). Lightweight check —
/// the apiserver does full validation.
typealias IPAddress = String(matches(Regex(#"^([0-9]{1,3}(\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)$"#)))

/// Service cluster IP — an `IPAddress`, or the literal `"None"` for headless services.
typealias ClusterIP = (IPAddress|"None")

/// CIDR block (IPv4 or IPv6 with prefix length).
typealias CIDR = String(matches(Regex(#"^([0-9]{1,3}(\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)/\d{1,3}$"#)))

/// DNS-1123 label — lowercase alphanumeric and hyphens, 1..63 chars.
/// Used for service names, namespace names, label values.
typealias DNS1123Label = String(matches(Regex(#"^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"#)) && length <= 63)

/// DNS-1123 subdomain — labels separated by dots, max 253 chars.
/// Used for most resource `metadata.name` values.
typealias DNS1123Subdomain = String(matches(Regex(#"^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"#)) && length <= 253)

/// Cron schedule string (5- or 6-field cron, or `@hourly`/`@daily`/etc.).
/// Non-empty check only — full cron grammar is validated by the apiserver.
typealias CronSchedule = String(!isEmpty)

