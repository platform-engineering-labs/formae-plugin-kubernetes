// =============================================================================
// Shared typed list-element classes
// -----------------------------------------------------------------------------
// These replace previous Listing<Dynamic> usages with typed SubResource classes
// so that per-field @FieldHint annotations (notably hasProviderDefault) apply
// during diff comparison. Without these, K8s-injected defaults on list elements
// would surface as phantom remove+add operations in the plan preview.
// =============================================================================

/// Reference to an object in the same namespace; typically used for secrets.
@SubResourceHint {}
open class LocalObjectReference extends formae.SubResource {
  @FieldHint { required = true }
  name: (String|formae.Resolvable)
}

/// Generic reference to a Kubernetes object. Most fields are optional; only
/// `name` is typically set in practice.
@SubResourceHint {}
open class ObjectReference extends formae.SubResource {
  @FieldHint {}
  apiVersion: String?

  @FieldHint {}
  kind: String?

  @FieldHint {}
  namespace: String?

  @FieldHint {}
  name: (String|formae.Resolvable)?

  @FieldHint {}
  uid: String?

  @FieldHint {}
  resourceVersion: String?

  @FieldHint {}
  fieldPath: String?
}

/// Tolerates a node taint so a pod can be scheduled on matching nodes.
@SubResourceHint {}
open class Toleration extends formae.SubResource {
  @FieldHint {}
  key: String?

  @FieldHint { hasProviderDefault = true }
  operator: String? = "Equal"

  @FieldHint {}
  value: String?

  @FieldHint {}
  effect: String?

  @FieldHint {}
  tolerationSeconds: NonNegativeInt?
}

