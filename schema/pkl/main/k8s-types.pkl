 * SPDX-License-Identifier: Apache-2.0
 *
 * K8S Plugin Schema - Shared types library.
 *
 * Holds the version-agnostic content used by every K8s minor:
 *   - primitive typealiases (Quantity, PortNumber, DNS1123*, ...)
 *   - K8s Quantity conversion helpers (toK8sQuantity, dataSizeToK8s, ...)
 *   - the K8sVersion annotation class (consumed by discover.pkl)
 *   - the Resource base + ObjectMeta + NamespacedObjectMeta classes
 *   - re-exported formae.* annotation typealiases (ResourceHint, FieldHint, SubResourceHint)
 *
 * Consumed by:
 *   - main/k8s.pkl (for KubernetesMinorVersion on Config.kubernetesVersion)
 *   - main/k8s-subresources.pkl (amends this module)
 *   - tools/gen-versioned-reflect/discover.pkl (for K8sVersion)
 *
 * No @K8sVersion gates appear in this file — all content is version-agnostic
 * and lives unchanged at the generated package root.
 */
open module k8sTypes

import "@formae/formae.pkl"

// =============================================================================
// Native typealiases
// =============================================================================

typealias KubernetesMinorVersion = String(matches(Regex(#"^\d+\.\d+$"#)))

typealias QuantityString = String(matches(Regex(#"^[+-]?(\d+(\.\d*)?|\.\d+)((e[+-]?\d+)|([numkMGTPE]i?))?$"#)))
typealias Quantity = (DataSize|QuantityString)

typealias ResourceQuantities = Mapping<String, Quantity>

const function dataSizeToK8s(d: DataSize): String =
  let (v = d.value.toString())
    if (d.unit == "b") v
    else if (d.unit == "kib") "\(v)Ki"
    else if (d.unit == "mib") "\(v)Mi"
    else if (d.unit == "gib") "\(v)Gi"
    else if (d.unit == "tib") "\(v)Ti"
    else if (d.unit == "pib") "\(v)Pi"
    else if (d.unit == "kb") "\(v)k"
    else if (d.unit == "mb") "\(v)M"
    else if (d.unit == "gb") "\(v)G"
    else if (d.unit == "tb") "\(v)T"
    else if (d.unit == "pb") "\(v)P"
    else "\(d.toUnit("b").value)"

const function toK8sQuantity(v: Quantity): String =
  if (v is DataSize) dataSizeToK8s(v) else v

const function toK8sQuantityMapping(m: Mapping<String, Quantity>): Mapping<String, String> =
  m.toMap().mapValues((_, v) -> toK8sQuantity(v)).toMapping()

typealias PortNumber = Int(isBetween(1, 65535))
typealias Protocol = "TCP"|"UDP"|"SCTP"
typealias Weight = Int(isBetween(1, 100))
typealias StabilizationWindowSeconds = Int(isBetween(0, 3600))
typealias FileMode = Int(isBetween(0, 0o777))
typealias NonNegativeInt = Int(isBetween(0, 2147483647))
typealias PositiveInt = Int(isBetween(1, 2147483647))
typealias Int32 = Int(isBetween(-2147483648, 2147483647))
typealias UnixID = Int(isBetween(0, 4294967295))
typealias IntOrString = (Int|String)
typealias Percentage = String(matches(Regex(#"^([0-9]|[1-9][0-9]|100)%$"#)))
typealias Percent = Int(isBetween(0, 100))
typealias FlowControlPercent = Int(isBetween(-1, 100))
typealias MatchingPrecedence = Int(isBetween(1, 10000))
typealias WebhookTimeoutSeconds = Int(isBetween(1, 30))
typealias IPAddress = String(matches(Regex(#"^([0-9]{1,3}(\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)$"#)))
typealias ClusterIP = (IPAddress|"None")
typealias CIDR = String(matches(Regex(#"^([0-9]{1,3}(\.[0-9]{1,3}){3}|[0-9a-fA-F:]+)/\d{1,3}$"#)))
typealias DNS1123Label = String(matches(Regex(#"^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"#)) && length <= 63)
typealias DNS1123Subdomain = String(matches(Regex(#"^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"#)) && length <= 253)
typealias CronSchedule = String(!isEmpty)

// =============================================================================
// Annotation aliases for K8S resources (re-exported from formae.pkl)
// =============================================================================

typealias ResourceHint = formae.ResourceHint
typealias FieldHint = formae.FieldHint
typealias SubResourceHint = formae.SubResourceHint

// =============================================================================
// K8sVersion annotation
// =============================================================================

/// Marks a field or class as gated by a Kubernetes API version range.
class K8sVersion extends Annotation {
  introducedIn: KubernetesMinorVersion?
  deprecatedIn: KubernetesMinorVersion?
  removedIn: KubernetesMinorVersion?
  reference: String?
}

// =============================================================================
// Base Resource class
// =============================================================================

open class Resource extends formae.Resource {
  @FieldHint { required = true }
  apiVersion: String

  @FieldHint { required = true }
  kind: String

  @FieldHint { required = true }
  metadata: ObjectMeta
}

// =============================================================================
// ObjectMeta
// =============================================================================

@SubResourceHint {}
open class ObjectMeta extends formae.SubResource {
  @FieldHint { required = true; createOnly = true }
  name: String

  @FieldHint {}
  namespace: (String|formae.Resolvable)?

  @FieldHint { hasProviderDefault = true }
  labels: Mapping<String, String>?

  @FieldHint { hasProviderDefault = true }
  annotations: Mapping<String, String>?
}

@SubResourceHint {}
open class NamespacedObjectMeta extends ObjectMeta {
  @FieldHint { required = true; createOnly = true }
  name: String

  @FieldHint { required = true }
  namespace: (String|formae.Resolvable)

  @FieldHint { hasProviderDefault = true }
  labels: Mapping<String, String>?

  @FieldHint { hasProviderDefault = true }
  annotations: Mapping<String, String>?
}
