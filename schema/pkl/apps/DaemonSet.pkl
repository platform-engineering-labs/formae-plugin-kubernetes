module daemonset

import "@formae/formae.pkl"
import "../k8s.pkl"
import "../core/Pod.pkl" as pod
import "ReplicaSet.pkl" as rs

const type = "K8S::Apps::DaemonSet"

/// K8S DaemonSet resource.
/// A DaemonSet ensures that all (or some) nodes run a copy of a Pod.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class DaemonSet extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for DaemonSet is always "apps/v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "apps/v1"

  /// Kind is always "DaemonSet"
  @k8s.FieldHint { required = true }
  kind: String = "DaemonSet"

  /// DaemonSet metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// DaemonSet specification
  @k8s.FieldHint { required = true }
  spec: DaemonSetSpec
}

/// DaemonSetSpec defines the desired state of a DaemonSet.
@k8s.SubResourceHint {}
open class DaemonSetSpec extends formae.SubResource {
  /// Label selector for pods.
  @k8s.FieldHint { required = true }
  selector: rs.LabelSelector

  /// Template describes the pods that will be created on each node.
  @k8s.FieldHint { required = true }
  template: rs.PodTemplateSpec

  /// Minimum number of seconds for which a newly created DaemonSet pod should be ready.
  @k8s.FieldHint {}
  minReadySeconds: Int?

  /// The number of old history to retain.
  @k8s.FieldHint {}
  revisionHistoryLimit: Int?

  /// Update strategy for the DaemonSet.
  @k8s.FieldHint {}
  updateStrategy: DaemonSetUpdateStrategy?
}

/// DaemonSetUpdateStrategy defines the update strategy for a DaemonSet.
@k8s.SubResourceHint {}
open class DaemonSetUpdateStrategy extends formae.SubResource {
  /// Type of update strategy: "RollingUpdate" or "OnDelete".
  @k8s.FieldHint {}
  type: String?

  /// RollingUpdate config for RollingUpdate strategy.
  @k8s.FieldHint {}
  rollingUpdate: RollingUpdateDaemonSet?
}

/// RollingUpdateDaemonSet controls the rolling update of a DaemonSet.
@k8s.SubResourceHint {}
open class RollingUpdateDaemonSet extends formae.SubResource {
  /// Maximum number of DaemonSet pods that can be unavailable during the update.
  @k8s.FieldHint {}
  maxUnavailable: (Int|String)?

  /// Maximum number of DaemonSet pods that can be scheduled above desired number during update.
  @k8s.FieldHint {}
  maxSurge: (Int|String)?
}
