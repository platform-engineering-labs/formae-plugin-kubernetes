module replicaset

import "@formae/formae.pkl"
import "../k8s.pkl"

const type = "K8S::Apps::ReplicaSet"

/// K8S ReplicaSet resource.
/// A ReplicaSet ensures that a specified number of pod replicas are running at any given time.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class ReplicaSet extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for ReplicaSet is always "apps/v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "apps/v1"

  /// Kind is always "ReplicaSet"
  @k8s.FieldHint { required = true }
  kind: String = "ReplicaSet"

  /// ReplicaSet metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// ReplicaSet specification
  @k8s.FieldHint { required = true }
  spec: ReplicaSetSpec
}

/// ReplicaSetSpec defines the desired state of a ReplicaSet.
@k8s.SubResourceHint {}
open class ReplicaSetSpec extends formae.SubResource {
  /// Number of desired pod replicas.
  /// Defaults to 1 if not specified.
  @k8s.FieldHint {}
  replicas: Int?

  /// Minimum number of seconds for which a newly created pod should be ready
  /// without any of its container crashing, for it to be considered available.
  @k8s.FieldHint {}
  minReadySeconds: Int?

  /// Label selector for pods.
  /// Existing ReplicaSets whose pods are selected by this will be affected.
  @k8s.FieldHint { required = true }
  selector: k8s.LabelSelector

  /// Template describes the pods that will be created.
  @k8s.FieldHint { required = true }
  template: k8s.PodTemplateSpec
}
