module deployment

import "@formae/formae.pkl"
import "../k8s.pkl"
import "../core/Pod.pkl" as pod
import "ReplicaSet.pkl" as rs

const type = "K8S::Apps::Deployment"

/// K8S Deployment resource.
/// A Deployment manages a set of replica Pods with declarative updates.
@k8s.ResourceHint {
  type = module.type
  identifier = "$.metadata.uid"
  discoverable = true
  parent = "K8S::Core::Namespace"
  listParam = new formae.ListProperty {
    parentProperty = "metadata.name"
    listParameter = "namespace"
  }
}
open class Deployment extends k8s.Resource {
  fixed hidden resourceType: String = module.type

  /// API version for Deployment is always "apps/v1"
  @k8s.FieldHint { required = true }
  apiVersion: String = "apps/v1"

  /// Kind is always "Deployment"
  @k8s.FieldHint { required = true }
  kind: String = "Deployment"

  /// Deployment metadata
  @k8s.FieldHint { required = true }
  metadata: k8s.ObjectMeta

  /// Deployment specification
  @k8s.FieldHint { required = true }
  spec: DeploymentSpec
}

/// DeploymentSpec defines the desired state of a Deployment.
@k8s.SubResourceHint {}
open class DeploymentSpec extends formae.SubResource {
  /// Number of desired pod replicas.
  @k8s.FieldHint {}
  replicas: Int?

  /// Label selector for pods.
  @k8s.FieldHint { required = true }
  selector: rs.LabelSelector

  /// Template describes the pods that will be created.
  @k8s.FieldHint { required = true }
  template: rs.PodTemplateSpec

  /// Minimum number of seconds for which a newly created pod should be ready
  /// without any of its container crashing, for it to be considered available.
  @k8s.FieldHint {}
  minReadySeconds: Int?

  /// The maximum time in seconds for a deployment to make progress before it
  /// is considered to be failed.
  @k8s.FieldHint {}
  progressDeadlineSeconds: Int?

  /// The number of old ReplicaSets to retain.
  @k8s.FieldHint {}
  revisionHistoryLimit: Int?

  /// Deployment strategy to use to replace existing pods with new ones.
  @k8s.FieldHint {}
  strategy: DeploymentStrategy?

  /// Indicates that the deployment is paused.
  @k8s.FieldHint {}
  paused: Boolean?
}

/// DeploymentStrategy describes how to replace existing pods with new ones.
@k8s.SubResourceHint {}
open class DeploymentStrategy extends formae.SubResource {
  /// Type of deployment strategy: "Recreate" or "RollingUpdate".
  @k8s.FieldHint {}
  type: String?

  /// Rolling update config params for RollingUpdate strategy.
  @k8s.FieldHint {}
  rollingUpdate: RollingUpdateDeployment?
}

/// RollingUpdateDeployment controls the rolling update of a Deployment.
@k8s.SubResourceHint {}
open class RollingUpdateDeployment extends formae.SubResource {
  /// The maximum number of pods that can be unavailable during the update.
  @k8s.FieldHint {}
  maxUnavailable: (Int|String)?

  /// The maximum number of pods that can be scheduled above the desired number.
  @k8s.FieldHint {}
  maxSurge: (Int|String)?
}
