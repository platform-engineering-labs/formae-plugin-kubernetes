/// Generator: Configure a Helm chart release and get all forma entries in one object.
///
/// Usage — user writes a minimal forma file:
///
///   ```pkl
///   amends "@formae/forma.pkl"
///   import "@formae-helm/Generator.pkl"
///
///   local rel = new Generator.HelmRelease {
///     chart = "bitnami/nginx"
///     version = "22.4.7"
///     releaseName = "my-nginx"
///     namespace = "formae-test"
///     targetLabel = "k8s-local"
///     targetContext = "orbstack"
///     createNamespace = true
///     values {
///       replicaCount = 2
///       service { type = "ClusterIP" }
///     }
///   }
///
///   forma {
///     for (entry in rel.formaEntries) {
///       entry
///     }
///   }
///   ```
///
/// Then generate a static forma:
///
///   ```bash
///   pkl eval -f pcf my-chart.pkl > my-forma.pcf
///   formae apply --mode reconcile my-forma.pcf
///   ```
module Generator

import "@formae/formae.pkl"
import "@k8s/v1.25/core/Namespace.pkl" as ns
import "HelmChart.pkl"

/// A Helm release configuration that produces Formae forma entries.
///
/// Wraps HelmChart with stack/target/namespace configuration.
/// The `formaEntries` property contains everything needed for a `forma {}` block:
/// Stack, Target, optional Namespace, and all mapped chart resources.
open class HelmRelease {
  /// Helm chart reference (e.g., "bitnami/nginx").
  chart: String

  /// Chart version (e.g., "22.4.7").
  version: String

  /// Helm release name. Used in resource names and as default label prefix.
  releaseName: String

  /// Target namespace for namespaced resources.
  namespace: String = "default"

  /// Helm values. Use `values { ... }` shorthand for nested config.
  values: Dynamic?

  /// Stack label. Defaults to releaseName.
  stackLabel: String = releaseName

  /// Stack description.
  stackDescription: String = "Helm chart: \(chart) \(version)"

  /// Target label.
  targetLabel: String = "k8s"

  /// K8S context for the target. Null uses current-context.
  targetContext: String?

  /// K8S kubeconfig path. Null uses default.
  targetKubeconfig: String?

  /// Whether to include a Namespace resource in the output.
  createNamespace: Boolean = false

  /// Prefix for Formae resource labels. Defaults to releaseName.
  labelPrefix: String = releaseName

  /// When true, silently skip unsupported resource types (CRDs, etc.).
  skipUnsupported: Boolean = true

  /// The chart resources only (no stack/target/namespace).
  resources: Listing<formae.Resource> = _helmChart.resources

  /// All forma entries: Stack + Target + optional Namespace + chart resources.
  /// Spread this into your `forma {}` block.
  formaEntries: Listing = let (_self = this)
    new Listing {
      new formae.Stack {
        label = _self.stackLabel
        description = _self.stackDescription
      }
      new formae.Target {
        label = _self.targetLabel
        namespace = "K8S"
        config = _self._targetConfig
      }
      when (_self.createNamespace) {
        new ns.Namespace {
          label = "\(_self.labelPrefix)-namespace"
          metadata = new ns.NamespaceMetadata {
            name = _self.namespace
          }
        }
      }
      for (_resource in _self._helmChart.resources) {
        _resource
      }
    }

  // ── Internal ────────────────────────────────────────────────────────────

  hidden _helmChart: HelmChart = let (_self = this)
    new HelmChart {
      chart = _self.chart
      version = _self.version
      releaseName = _self.releaseName
      namespace = _self.namespace
      labelPrefix = _self.labelPrefix
      skipUnsupported = _self.skipUnsupported
      when (_self.values != null) {
        values = _self.values
      }
    }

  hidden _targetConfig: Mapping<String, String> = let (_self = this)
    new Mapping {
      when (_self.targetContext != null) {
        ["context"] = _self.targetContext
      }
      when (_self.targetKubeconfig != null) {
        ["kubeconfig"] = _self.targetKubeconfig
      }
      ["namespace"] = _self.namespace
    }
}
