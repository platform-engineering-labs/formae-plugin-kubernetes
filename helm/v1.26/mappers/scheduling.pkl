/// Mappers for scheduling.k8s.io/v1 K8S resource types.
module scheduling

import "@k8s/k8s.pkl" as k8s
import "@k8s/v1.26/scheduling/PriorityClass.pkl" as pc

import "common.pkl"

// =============================================================================
// PriorityClass (cluster-scoped)
// =============================================================================

function mapPriorityClass(src: Any, prefix: String, _namespace: String): pc.PriorityClass =
  new pc.PriorityClass {
    label = common.makeLabel(prefix, "priorityclass", src.metadata.name)
    metadata = common.mapClusterMeta(src.metadata)
    value = src.value
    when (src.globalDefault != null) {
      globalDefault = src.globalDefault
    }
    when (src.description != null) {
      description = src.description
    }
    when (src.preemptionPolicy != null) {
      preemptionPolicy = src.preemptionPolicy
    }
  }
