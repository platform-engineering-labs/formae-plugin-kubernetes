amends "pkl:Project"

package {
  name = "formae-helm"
  baseUri = "package://hub.platform.engineering/plugins/k8s/helm/\(name)/\(name)"
  version = "0.3.0"
  packageZipUrl = "https://hub.platform.engineering/plugins/k8s/helm/\(name)/\(name)@\(version).zip"
}

dependencies {
  // formae-helm lives next to the K8s plugin's PKL schema package and
  // depends on it for typed K8s resources. The codegen
  // (tools/gen-versioned-helm) reads the schema package's v*/ list to
  // learn which K8s minors to emit per-version helm wrappers for, then
  // rewrites `@k8s/<group>/<Kind>.pkl` imports → `@k8s/v<X.Y>/...`.
  // Resolved locally in dev; release builds resolve against the
  // published `package://hub.../k8s@<min>` URI.
  ["k8s"] = import("../schema/pkl/generated/PklProject")
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.85.0"
  }
  // Pin matches the pkl-reader-helm binary version documented in
  // helm/README.md ("Install pkl-reader-helm"). Keep these two in lock-step
  // when bumping — the schema package and the binary share a major.minor
  // wire-protocol contract; a drift between them silently disables Helm
  // chart evaluation.
  ["helm"] {
    uri = "package://pkg.pkl-lang.org/pkl-readers/helm@0.1.2"
  }
}

evaluatorSettings {
  externalResourceReaders {
    ["reader+helm"] {
      executable = "pkl-reader-helm"
    }
  }
}
