function renderClusterRole(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new cr.ClusterRole {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "clusterrole", src.metadata.name))
