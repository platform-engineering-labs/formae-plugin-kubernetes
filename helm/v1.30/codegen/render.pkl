// ── Autoscaling ──────────────────────────────────────────────────────────────

function renderHPA(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new hpa.HorizontalPodAutoscaler {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "horizontalpodautoscaler", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new hpa.HorizontalPodAutoscalerSpec {"
        when (src.spec.scaleTargetRef != null) {
          w.joinNonEmpty(new Listing {
            ind + "    scaleTargetRef = new hpa.CrossVersionObjectReference {"
            w.strProp(ind + "      ", "apiVersion", src.spec.scaleTargetRef.apiVersion)
            w.strProp(ind + "      ", "kind", src.spec.scaleTargetRef.kind)
            w.strProp(ind + "      ", "name", src.spec.scaleTargetRef.name)
            ind + "    }"
          }.toList())
        }
        w.intProp(ind + "    ", "minReplicas", src.spec.minReplicas)
        w.intProp(ind + "    ", "maxReplicas", src.spec.maxReplicas)
        when (src.spec.metrics != null) {
          ind + "    metrics {"
          for (_m in src.spec.metrics) {
            w.joinNonEmpty(new Listing {
              ind + "      new {"
              w.strProp(ind + "        ", "type", _m.type)
              when (_m.resource != null) {
                w.joinNonEmpty(new Listing {
                  ind + "        resource {"
                  w.strProp(ind + "          ", "name", _m.resource.name)
                  when (_m.resource.target != null) {
                    w.joinNonEmpty(new Listing {
                      ind + "          target {"
                      w.strProp(ind + "            ", "type", _m.resource.target.type)
                      w.intProp(ind + "            ", "averageUtilization", _m.resource.target.averageUtilization)
                      w.strProp(ind + "            ", "averageValue", if (_m.resource.target.averageValue != null) "\(_m.resource.target.averageValue)" else null)
                      ind + "          }"
                    }.toList())
                  }
                  ind + "        }"
                }.toList())
              }
              ind + "      }"
            }.toList())
          }
          ind + "    }"
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

// ── Coordination ─────────────────────────────────────────────────────────────

function renderLease(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new lease.Lease {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "lease", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new lease.LeaseSpec {"
        w.strProp(ind + "    ", "holderIdentity", src.spec.holderIdentity)
        w.intProp(ind + "    ", "leaseDurationSeconds", src.spec.leaseDurationSeconds)
        w.intProp(ind + "    ", "leaseTransitions", src.spec.leaseTransitions)
        w.strProp(ind + "    ", "renewTime", src.spec.renewTime)
        w.strProp(ind + "    ", "acquireTime", src.spec.acquireTime)
        w.strProp(ind + "    ", "preferredHolder", src.spec.preferredHolder)
        w.strProp(ind + "    ", "strategy", src.spec.strategy)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

// ── Node ─────────────────────────────────────────────────────────────────────

function renderRuntimeClass(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new rc.RuntimeClass {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "runtimeclass", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    w.strProp(ind + "  ", "handler", src.handler)
    when (src.overhead != null) {
      w.joinNonEmpty(new Listing {
        ind + "  overhead = new rc.Overhead {"
        w.qtyMappingBlock(src.overhead.podFixed, ind + "    ", "podFixed")
        ind + "  }"
      }.toList())
    }
    when (src.scheduling != null) {
      w.joinNonEmpty(new Listing {
        ind + "  scheduling = new rc.Scheduling {"
        w.mappingBlock(src.scheduling.nodeSelector, ind + "    ", "nodeSelector")
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

// ── Admissionregistration ────────────────────────────────────────────────────

/// Render k8s.WebhookClientConfig (shared by VWC and MWC).
function renderWebhookClientConfig(cc: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "clientConfig = new k8s.WebhookClientConfig {"
    w.strProp(ind + "  ", "url", cc.url)
    w.strProp(ind + "  ", "caBundle", cc.caBundle)
    when (cc.service != null) {
      w.joinNonEmpty(new Listing {
        ind + "  service = new k8s.ServiceReference {"
        w.strProp(ind + "    ", "name", cc.service.name)
        w.strProp(ind + "    ", "namespace", cc.service.namespace)
        w.strProp(ind + "    ", "path", cc.service.path)
        w.intProp(ind + "    ", "port", cc.service.port)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

/// Render k8s.RuleWithOperations (shared by VWC and MWC).
function renderRuleWithOperations(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.stringListBlock(rule.resources, ind + "  ", "resources")
    w.stringListBlock(rule.operations, ind + "  ", "operations")
    w.stringListBlock(rule.apiGroups, ind + "  ", "apiGroups")
    w.stringListBlock(rule.apiVersions, ind + "  ", "apiVersions")
    w.strProp(ind + "  ", "scope", rule.scope)
    ind + "}"
  }.toList())

/// Render k8s.LabelSelector.
function renderK8sLabelSelector(sel: Any?, ind: String, propName: String): String =
  if (sel == null) ""
  else w.joinNonEmpty(new Listing {
    ind + propName + " = new k8s.LabelSelector {"
    w.mappingBlock(sel.matchLabels, ind + "  ", "matchLabels")
    when (sel.matchExpressions != null) {
      ind + "  matchExpressions {"
      for (_expr in sel.matchExpressions) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "key", _expr.key)
          w.strProp(ind + "      ", "operator", _expr.operator)
          w.stringListBlock(_expr.values, ind + "      ", "values")
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderValidatingWebhookConfiguration(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new vwc.ValidatingWebhookConfiguration {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "validatingwebhookconfiguration", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.webhooks != null) {
      ind + "  webhooks {"
      for (_wh in src.webhooks) {
        renderValidatingWebhook(_wh, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderValidatingWebhook(wh: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", wh.name)
    w.strProp(ind + "  ", "sideEffects", wh.sideEffects)
    w.strProp(ind + "  ", "failurePolicy", wh.failurePolicy)
    w.strProp(ind + "  ", "matchPolicy", wh.matchPolicy)
    w.intProp(ind + "  ", "timeoutSeconds", wh.timeoutSeconds)
    w.stringListBlock(wh.admissionReviewVersions, ind + "  ", "admissionReviewVersions")
    when (wh.clientConfig != null) { renderWebhookClientConfig(wh.clientConfig, ind + "  ") }
    renderK8sLabelSelector(wh.namespaceSelector, ind + "  ", "namespaceSelector")
    renderK8sLabelSelector(wh.objectSelector, ind + "  ", "objectSelector")
    when (wh.rules != null) {
      ind + "  rules {"
      for (_r in wh.rules) {
        renderRuleWithOperations(_r, ind + "    ")
      }
      ind + "  }"
    }
    when (wh.matchConditions != null) {
      ind + "  matchConditions {"
      for (_mc in wh.matchConditions) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "name", _mc.name)
          w.strProp(ind + "      ", "expression", _mc.expression)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderMutatingWebhookConfiguration(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new mwc.MutatingWebhookConfiguration {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "mutatingwebhookconfiguration", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.webhooks != null) {
      ind + "  webhooks {"
      for (_wh in src.webhooks) {
        renderMutatingWebhook(_wh, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderMutatingWebhook(wh: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", wh.name)
    w.strProp(ind + "  ", "sideEffects", wh.sideEffects)
    w.strProp(ind + "  ", "failurePolicy", wh.failurePolicy)
    w.strProp(ind + "  ", "matchPolicy", wh.matchPolicy)
    w.strProp(ind + "  ", "reinvocationPolicy", wh.reinvocationPolicy)
    w.intProp(ind + "  ", "timeoutSeconds", wh.timeoutSeconds)
    w.stringListBlock(wh.admissionReviewVersions, ind + "  ", "admissionReviewVersions")
    when (wh.clientConfig != null) { renderWebhookClientConfig(wh.clientConfig, ind + "  ") }
    renderK8sLabelSelector(wh.namespaceSelector, ind + "  ", "namespaceSelector")
    renderK8sLabelSelector(wh.objectSelector, ind + "  ", "objectSelector")
    when (wh.rules != null) {
      ind + "  rules {"
      for (_r in wh.rules) {
        renderRuleWithOperations(_r, ind + "    ")
      }
      ind + "  }"
    }
    when (wh.matchConditions != null) {
      ind + "  matchConditions {"
      for (_mc in wh.matchConditions) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "name", _mc.name)
          w.strProp(ind + "      ", "expression", _mc.expression)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

// ── Flowcontrol ──────────────────────────────────────────────────────────────

function renderFlowSchema(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new fs.FlowSchema {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "flowschema", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.spec != null) { renderFlowSchemaSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderFlowSchemaSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new fs.FlowSchemaSpec {"
    when (spec.priorityLevelConfiguration != null) {
      w.joinNonEmpty(new Listing {
        ind + "  priorityLevelConfiguration = new fs.PriorityLevelConfigurationReference {"
        w.strProp(ind + "    ", "name", spec.priorityLevelConfiguration.name)
        ind + "  }"
      }.toList())
    }
    w.intProp(ind + "  ", "matchingPrecedence", spec.matchingPrecedence)
    when (spec.distinguisherMethod != null) {
      w.joinNonEmpty(new Listing {
        ind + "  distinguisherMethod = new fs.FlowDistinguisherMethod {"
        w.strProp(ind + "    ", "`type`", spec.distinguisherMethod.type)
        ind + "  }"
      }.toList())
    }
    when (spec.rules != null) {
      ind + "  rules {"
      for (_r in spec.rules) {
        renderPolicyRulesWithSubjects(_r, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderPolicyRulesWithSubjects(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    when (rule.subjects != null) {
      ind + "  subjects {"
      for (_s in rule.subjects) {
        renderFlowSchemaSubject(_s, ind + "    ")
      }
      ind + "  }"
    }
    when (rule.resourceRules != null) {
      ind + "  resourceRules {"
      for (_r in rule.resourceRules) {
        renderResourcePolicyRule(_r, ind + "    ")
      }
      ind + "  }"
    }
    when (rule.nonResourceRules != null) {
      ind + "  nonResourceRules {"
      for (_r in rule.nonResourceRules) {
        renderNonResourcePolicyRule(_r, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderFlowSchemaSubject(subj: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "kind", subj.kind)
    when (subj.serviceAccount != null) {
      w.joinNonEmpty(new Listing {
        ind + "  serviceAccount = new fs.ServiceAccountSubject {"
        w.strProp(ind + "    ", "name", subj.serviceAccount.name)
        w.strProp(ind + "    ", "namespace", subj.serviceAccount.namespace)
        ind + "  }"
      }.toList())
    }
    when (subj.user != null) {
      w.joinNonEmpty(new Listing {
        ind + "  user = new fs.UserSubject {"
        w.strProp(ind + "    ", "name", subj.user.name)
        ind + "  }"
      }.toList())
    }
    when (subj.group != null) {
      w.joinNonEmpty(new Listing {
        ind + "  group = new fs.GroupSubject {"
        w.strProp(ind + "    ", "name", subj.group.name)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderResourcePolicyRule(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.stringListBlock(rule.apiGroups, ind + "  ", "apiGroups")
    w.stringListBlock(rule.resources, ind + "  ", "resources")
    w.stringListBlock(rule.verbs, ind + "  ", "verbs")
    w.boolProp(ind + "  ", "clusterScope", rule.clusterScope)
    w.stringListBlock(rule.namespaces, ind + "  ", "namespaces")
    ind + "}"
  }.toList())

function renderNonResourcePolicyRule(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.stringListBlock(rule.verbs, ind + "  ", "verbs")
    w.stringListBlock(rule.nonResourceURLs, ind + "  ", "nonResourceURLs")
    ind + "}"
  }.toList())

function renderPriorityLevelConfiguration(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new plc.PriorityLevelConfiguration {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "prioritylevelconfiguration", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.spec != null) { renderPriorityLevelConfigurationSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderPriorityLevelConfigurationSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new plc.PriorityLevelConfigurationSpec {"
    w.strProp(ind + "  ", "`type`", spec.type)
    when (spec.limited != null) {
      w.joinNonEmpty(new Listing {
        ind + "  limited = new plc.LimitedPriorityLevelConfiguration {"
        w.intProp(ind + "    ", "nominalConcurrencyShares", spec.limited.nominalConcurrencyShares)
        w.intProp(ind + "    ", "lendablePercent", spec.limited.lendablePercent)
        w.intProp(ind + "    ", "borrowingLimitPercent", spec.limited.borrowingLimitPercent)
        when (spec.limited.limitResponse != null) {
          w.joinNonEmpty(new Listing {
            ind + "    limitResponse = new plc.LimitResponse {"
            w.strProp(ind + "      ", "`type`", spec.limited.limitResponse.type)
            when (spec.limited.limitResponse.queuing != null) {
              w.joinNonEmpty(new Listing {
                ind + "      queuing = new plc.QueuingConfiguration {"
                w.intProp(ind + "        ", "queues", spec.limited.limitResponse.queuing.queues)
                w.intProp(ind + "        ", "handSize", spec.limited.limitResponse.queuing.handSize)
                w.intProp(ind + "        ", "queueLengthLimit", spec.limited.limitResponse.queuing.queueLengthLimit)
                ind + "      }"
              }.toList())
            }
            ind + "    }"
          }.toList())
        }
        ind + "  }"
      }.toList())
    }
    when (spec.exempt != null) {
      w.joinNonEmpty(new Listing {
        ind + "  exempt = new plc.ExemptPriorityLevelConfiguration {"
        w.intProp(ind + "    ", "lendablePercent", spec.exempt.lendablePercent)
        w.intProp(ind + "    ", "nominalConcurrencyShares", spec.exempt.nominalConcurrencyShares)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

// ── Dispatch ─────────────────────────────────────────────────────────────────

/// Generate PKL source for a single resource.
function renderResource(src: Any, prefix: String, ns: String): String =
  let (api = src.apiVersion)
  let (kind = src.kind)
  // core/v1
  if (api == "v1" && kind == "Namespace") renderNamespace(src, prefix)
  else if (api == "v1" && kind == "Pod") renderPod(src, prefix, ns)
  else if (api == "v1" && kind == "ConfigMap") renderConfigMap(src, prefix, ns)
  else if (api == "v1" && kind == "Secret") renderSecret(src, prefix, ns)
  else if (api == "v1" && kind == "ServiceAccount") renderServiceAccount(src, prefix, ns)
  else if (api == "v1" && kind == "Service") renderService(src, prefix, ns)
  else if (api == "v1" && kind == "Endpoints") renderEndpoints(src, prefix, ns)
  else if (api == "v1" && kind == "LimitRange") renderLimitRange(src, prefix, ns)
  else if (api == "v1" && kind == "PersistentVolume") renderPersistentVolume(src, prefix)
  else if (api == "v1" && kind == "PersistentVolumeClaim") renderPersistentVolumeClaim(src, prefix, ns)
  else if (api == "v1" && kind == "ResourceQuota") renderResourceQuota(src, prefix, ns)
  // apps/v1
  else if (api == "apps/v1" && kind == "Deployment") renderDeployment(src, prefix, ns)
  else if (api == "apps/v1" && kind == "ReplicaSet") renderReplicaSet(src, prefix, ns)
  else if (api == "apps/v1" && kind == "StatefulSet") renderStatefulSet(src, prefix, ns)
  else if (api == "apps/v1" && kind == "DaemonSet") renderDaemonSet(src, prefix, ns)
  // batch/v1
  else if (api == "batch/v1" && kind == "Job") renderJob(src, prefix, ns)
  else if (api == "batch/v1" && kind == "CronJob") renderCronJob(src, prefix, ns)
  // networking
  else if (api == "networking.k8s.io/v1" && kind == "Ingress") renderIngress(src, prefix, ns)
  else if (api == "networking.k8s.io/v1" && kind == "IngressClass") renderIngressClass(src, prefix)
  else if (api == "networking.k8s.io/v1" && kind == "NetworkPolicy") renderNetworkPolicy(src, prefix, ns)
  // rbac
  else if (api == "rbac.authorization.k8s.io/v1" && kind == "Role") renderRole(src, prefix, ns)
  else if (api == "rbac.authorization.k8s.io/v1" && kind == "RoleBinding") renderRoleBinding(src, prefix, ns)
  else if (api == "rbac.authorization.k8s.io/v1" && kind == "ClusterRole") renderClusterRole(src, prefix)
  else if (api == "rbac.authorization.k8s.io/v1" && kind == "ClusterRoleBinding") renderClusterRoleBinding(src, prefix)
  // policy
  else if (api == "policy/v1" && kind == "PodDisruptionBudget") renderPodDisruptionBudget(src, prefix, ns)
  // storage
  else if (api == "storage.k8s.io/v1" && kind == "StorageClass") renderStorageClass(src, prefix)
  else if (api == "storage.k8s.io/v1" && kind == "CSIDriver") renderCSIDriver(src, prefix)
  // scheduling
  else if (api == "scheduling.k8s.io/v1" && kind == "PriorityClass") renderPriorityClass(src, prefix)
  // autoscaling
  else if (api == "autoscaling/v2" && kind == "HorizontalPodAutoscaler") renderHPA(src, prefix, ns)
  // coordination
  else if (api == "coordination.k8s.io/v1" && kind == "Lease") renderLease(src, prefix, ns)
  // node
  else if (api == "node.k8s.io/v1" && kind == "RuntimeClass") renderRuntimeClass(src, prefix)
  // admissionregistration
  else if (api == "admissionregistration.k8s.io/v1" && kind == "ValidatingWebhookConfiguration") renderValidatingWebhookConfiguration(src, prefix)
  else if (api == "admissionregistration.k8s.io/v1" && kind == "MutatingWebhookConfiguration") renderMutatingWebhookConfiguration(src, prefix)
  // flowcontrol
  else if (api == "flowcontrol.apiserver.k8s.io/v1" && kind == "FlowSchema") renderFlowSchema(src, prefix)
  else if (api == "flowcontrol.apiserver.k8s.io/v1" && kind == "PriorityLevelConfiguration") renderPriorityLevelConfiguration(src, prefix)
  else "  // SKIPPED: unsupported resource \(api)/\(kind)"

// ── Top-level forma renderer ─────────────────────────────────────────────────

/// Generate a complete, self-contained forma PKL file from Helm chart config.
///
/// The output is valid PKL source that uses typed k8s resources
/// and does NOT require pkl-reader-helm at deploy time.
function renderForma(
  stackLabel: String,
  stackDescription: String,
  targetLabel: String,
  targetConfig: Mapping<String, String>,
  namespace: String,
  createNamespace: Boolean,
  labelPrefix: String,
  skipUnsupported: Boolean,
  helmTemplate: Any
): String =
  // Collect resources and imports
  let (resources = new Listing {
    for (_key, _res in helmTemplate) {
      when (isSupported(_res.apiVersion, _res.kind)) {
        _res
      }
    }
  })
  let (allImports = new Listing {
    for (_key, _res in helmTemplate) {
      when (isSupported(_res.apiVersion, _res.kind)) {
        for (_imp in importsForType(_res.apiVersion, _res.kind)) {
          _imp
        }
      }
    }
  })
  // Deduplicate imports
  let (uniqueImports = allImports.toList().distinct.sort())
  // Add namespace import if creating namespace
  let (finalImports =
    if (createNamespace)
      (uniqueImports + List("import \"@k8s/v1.30/core/Namespace.pkl\" as ns")).distinct.sort()
    else uniqueImports
  )
  // Build the module
  let (header = new Listing {
    "/// Auto-generated forma from Helm chart."
    "/// Generated by formae-helm static generator. No pkl-reader-helm required."
    "/// Edit freely — this file is self-contained."
    "amends \"@formae/forma.pkl\""
    ""
    "import \"@formae/formae.pkl\""
    for (_imp in finalImports) { _imp }
    ""
    "forma {"
  }.toList().join("\n"))
  let (stack =
    "  new formae.Stack {\n" +
    "    label = " + w.q(stackLabel) + "\n" +
    "    description = " + w.q(stackDescription) + "\n" +
    "  }")
  let (target =
    let (configLines = new Listing {
      for (_k, _v in targetConfig) {
        "      [" + w.q("\(_k)") + "] = " + w.q("\(_v)")
      }
    }.toList().join("\n"))
    "  new formae.Target {\n" +
    "    label = " + w.q(targetLabel) + "\n" +
    "    namespace = \"K8S\"\n" +
    "    config {\n" +
    configLines + "\n" +
    "    }\n" +
    "  }")
  let (nsBlock =
    if (!createNamespace) ""
    else
      "  new ns.Namespace {\n" +
      "    label = " + w.q(labelPrefix + "-namespace") + "\n" +
      "    metadata = new ns.NamespaceMetadata {\n" +
      "      name = " + w.q(namespace) + "\n" +
      "    }\n" +
      "  }")
  let (resourceBlocks = new Listing {
    for (_key, _res in helmTemplate) {
      when (isSupported(_res.apiVersion, _res.kind)) {
        renderResource(_res, labelPrefix, namespace)
      }
    }
  }.toList())
  let (body = w.joinNonEmpty(
    List(stack, target, nsBlock) + resourceBlocks
  ))
  header + "\n" + body + "\n}\n"
