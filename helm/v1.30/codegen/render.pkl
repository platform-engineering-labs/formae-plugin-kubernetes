  }.toList())

function renderCSIDriverSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new csi.CSIDriverSpec {"
    w.boolProp(ind + "  ", "attachRequired", spec.attachRequired)
    w.boolProp(ind + "  ", "podInfoOnMount", spec.podInfoOnMount)
    w.strProp(ind + "  ", "fsGroupPolicy", spec.fsGroupPolicy)
    w.boolProp(ind + "  ", "requiresRepublish", spec.requiresRepublish)
    w.boolProp(ind + "  ", "storageCapacity", spec.storageCapacity)
    w.boolProp(ind + "  ", "seLinuxMount", spec.seLinuxMount)
    w.stringListBlock(spec.volumeLifecycleModes, ind + "  ", "volumeLifecycleModes")
    when (spec.tokenRequests != null) {
      ind + "  tokenRequests {"
      for (_tr in spec.tokenRequests) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "audience", _tr.audience)
          w.intProp(ind + "      ", "expirationSeconds", _tr.expirationSeconds)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

