function renderJobSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new job.JobSpec {"
    w.intProp(ind + "  ", "completions", spec.completions)
    w.intProp(ind + "  ", "parallelism", spec.parallelism)
    w.intProp(ind + "  ", "backoffLimit", spec.backoffLimit)
    w.intProp(ind + "  ", "activeDeadlineSeconds", spec.activeDeadlineSeconds)
    w.intProp(ind + "  ", "ttlSecondsAfterFinished", spec.ttlSecondsAfterFinished)
    w.boolProp(ind + "  ", "suspend", spec.suspend)
    w.strProp(ind + "  ", "completionMode", spec.completionMode)
    when (spec.template != null) { renderPodTemplateSpec(spec.template, ind + "  ") }
    ind + "}"
  }.toList())

function renderCronJob(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new cj.CronJob {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "cronjob", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) { renderCronJobSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderCronJobSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new cj.CronJobSpec {"
    w.strProp(ind + "  ", "schedule", spec.schedule)
    w.strProp(ind + "  ", "timeZone", spec.timeZone)
    w.strProp(ind + "  ", "concurrencyPolicy", spec.concurrencyPolicy)
    w.intProp(ind + "  ", "startingDeadlineSeconds", spec.startingDeadlineSeconds)
    w.intProp(ind + "  ", "successfulJobsHistoryLimit", spec.successfulJobsHistoryLimit)
    w.intProp(ind + "  ", "failedJobsHistoryLimit", spec.failedJobsHistoryLimit)
    w.boolProp(ind + "  ", "suspend", spec.suspend)
    when (spec.jobTemplate != null) {
      w.joinNonEmpty(new Listing {
        ind + "  jobTemplate = new cj.JobTemplate {"
        when (spec.jobTemplate.metadata != null) {
          renderPodTemplateMeta(spec.jobTemplate.metadata, ind + "    ")
        }
        when (spec.jobTemplate.spec != null) {
          renderJobSpec(spec.jobTemplate.spec, ind + "    ")
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

// ── Networking ───────────────────────────────────────────────────────────────

function renderIngress(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new ing.Ingress {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "ingress", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) { renderIngressSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderIngressSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new ing.IngressSpec {"
    w.strProp(ind + "  ", "ingressClassName", spec.ingressClassName)
    when (spec.defaultBackend != null) {
      renderIngressBackend(spec.defaultBackend, ind + "  ", "defaultBackend")
    }
    when (spec.tls != null) {
      ind + "  tls {"
      for (_t in spec.tls) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.stringListBlock(_t.hosts, ind + "      ", "hosts")
          w.strProp(ind + "      ", "secretName", _t.secretName)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    when (spec.rules != null) {
      ind + "  rules {"
      for (_rule in spec.rules) {
        renderIngressRule(_rule, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderIngressRule(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "host", rule.host)
    when (rule.http != null && rule.http.paths != null) {
      ind + "  http {"
      ind + "    paths {"
      for (_path in rule.http.paths) {
        w.joinNonEmpty(new Listing {
          ind + "      new {"
          w.strProp(ind + "        ", "path", _path.path)
          w.strProp(ind + "        ", "pathType", _path.pathType)
          when (_path.backend != null) {
            renderIngressBackend(_path.backend, ind + "        ", "backend")
          }
          ind + "      }"
        }.toList())
      }
      ind + "    }"
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderIngressBackend(backend: Any, ind: String, prop: String): String =
  if (backend.service == null) ""
  else w.joinNonEmpty(new Listing {
    ind + prop + " = new ing.IngressBackend {"
    w.joinNonEmpty(new Listing {
      ind + "  service {"
      w.strProp(ind + "    ", "name", backend.service.name)
      when (backend.service.port != null) {
        w.joinNonEmpty(new Listing {
          ind + "    port {"
          w.strProp(ind + "      ", "name", backend.service.port.name)
          w.intProp(ind + "      ", "number", backend.service.port.number)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }.toList())
    ind + "}"
  }.toList())

function renderIngressClass(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new ic.IngressClass {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "ingressclass", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new ic.IngressClassSpec {"
        w.strProp(ind + "    ", "controller", src.spec.controller)
        when (src.spec.parameters != null) {
          w.joinNonEmpty(new Listing {
            ind + "    parameters = new ic.IngressClassParameters {"
            w.strProp(ind + "      ", "kind", src.spec.parameters.kind)
            w.strProp(ind + "      ", "name", src.spec.parameters.name)
            w.strProp(ind + "      ", "apiGroup", src.spec.parameters.apiGroup)
            w.strProp(ind + "      ", "namespace", src.spec.parameters.namespace)
            w.strProp(ind + "      ", "scope", src.spec.parameters.scope)
            ind + "    }"
          }.toList())
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderNetworkPolicy(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new np.NetworkPolicy {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "networkpolicy", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new np.NetworkPolicySpec {"
        renderLabelSelectorAs(src.spec.podSelector, "rs", ind + "    ", "podSelector")
        w.stringListBlock(src.spec.policyTypes, ind + "    ", "policyTypes")
        when (src.spec.ingress != null) {
          ind + "    ingress {"
          for (_rule in src.spec.ingress) {
            renderNetworkPolicyRule(_rule, ind + "      ", "from")
          }
          ind + "    }"
        }
        when (src.spec.egress != null) {
          ind + "    egress {"
          for (_rule in src.spec.egress) {
            renderNetworkPolicyRule(_rule, ind + "      ", "to")
          }
          ind + "    }"
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderNetworkPolicyRule(rule: Any, ind: String, peerProp: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    when (rule.getPropertyOrNull(peerProp) != null) {
      ind + "  " + peerProp + " {"
      for (_peer in rule.getPropertyOrNull(peerProp)) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          when (_peer.podSelector != null) { renderLabelSelectorAs(_peer.podSelector, "rs", ind + "      ", "podSelector") }
          when (_peer.namespaceSelector != null) {
            let (nsSel = _peer.namespaceSelector)
            w.joinNonEmpty(new Listing {
              ind + "      namespaceSelector = new rs.LabelSelector {"
              w.mappingBlock(nsSel.matchLabels, ind + "        ", "matchLabels")
              ind + "      }"
            }.toList())
          }
          when (_peer.ipBlock != null) {
            w.joinNonEmpty(new Listing {
              ind + "      ipBlock {"
              w.strProp(ind + "        ", "cidr", _peer.ipBlock.cidr)
              w.stringListBlock(_peer.ipBlock.except, ind + "        ", "except")
              ind + "      }"
            }.toList())
          }
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    when (rule.ports != null) {
      ind + "  ports {"
      for (_p in rule.ports) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "port", if (_p.port != null) "\(_p.port)" else null)
          w.strProp(ind + "      ", "protocol", _p.protocol)
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

