    when (src.rules != null) {
      ind + "  rules {"
      for (_r in src.rules) { renderPolicyRule(_r, ind + "    ") }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderRoleBinding(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new rb.RoleBinding {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "rolebinding", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.roleRef != null) { renderRoleRef(src.roleRef, "rb", ind + "  ") }
    renderSubjects(src.subjects, "rb", ind + "  ")
    ind + "}"
