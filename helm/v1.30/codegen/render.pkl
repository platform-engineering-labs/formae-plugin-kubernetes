/// Static PKL code generator for Formae Helm resources.
///
/// Takes raw K8S manifests from helm template and generates typed PKL source
/// that uses k8s types — no pkl-reader-helm needed at deploy time.
module render

import "writer.pkl" as w

// ── Label helper ─────────────────────────────────────────────────────────────

function makeLabel(prefix: String, kind: String, name: String): String =
  prefix + "-" + kind.toLowerCase() + "-" + name

// ── Annotation filter ────────────────────────────────────────────────────────

function filterAnnotations(meta: Any?): Mapping<String, String>? =
  if (meta == null) null
  else if (meta.annotations == null) null
  else
    let (filtered = new Mapping {
      for (_k, _v in meta.annotations) {
        when (_v != null && "\(_v)" != "") {
          ["\(_k)"] = "\(_v)"
        }
      }
    })
    if (filtered.isEmpty) null
    else filtered

// ── Import tracking ──────────────────────────────────────────────────────────
//
// Each resource type needs specific imports.  We collect the set of import
// lines required by all resources in the forma.

/// Import line for k8s.pkl (ObjectMeta).
const k8sImport: String = "import \"@k8s/k8s.pkl\""

/// Import line for ReplicaSet.pkl (LabelSelector, PodTemplateSpec).
const rsImport: String = "import \"@k8s/v1.30/apps/ReplicaSet.pkl\" as rs"

/// Import line for Pod.pkl (PodSpec, Container).
const podImport: String = "import \"@k8s/v1.30/core/Pod.pkl\" as pod"

/// Returns the set of import lines needed for a given type.
function importsForType(apiVersion: String, kind: String): Listing<String> =
  // core/v1
  if (apiVersion == "v1" && kind == "Namespace")
    new Listing { "import \"@k8s/v1.30/core/Namespace.pkl\" as ns" }
  else if (apiVersion == "v1" && kind == "Pod")
    new Listing { k8sImport; podImport }
  else if (apiVersion == "v1" && kind == "ConfigMap")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/ConfigMap.pkl\" as cm" }
  else if (apiVersion == "v1" && kind == "Secret")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/Secret.pkl\" as secret" }
  else if (apiVersion == "v1" && kind == "ServiceAccount")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/ServiceAccount.pkl\" as sa" }
  else if (apiVersion == "v1" && kind == "Service")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/Service.pkl\" as svc" }
  else if (apiVersion == "v1" && kind == "Endpoints")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/Endpoints.pkl\" as ep" }
  else if (apiVersion == "v1" && kind == "LimitRange")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/LimitRange.pkl\" as lr" }
  else if (apiVersion == "v1" && kind == "PersistentVolume")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/PersistentVolume.pkl\" as pv" }
  else if (apiVersion == "v1" && kind == "PersistentVolumeClaim")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/PersistentVolumeClaim.pkl\" as pvc" }
  else if (apiVersion == "v1" && kind == "ResourceQuota")
    new Listing { k8sImport; "import \"@k8s/v1.30/core/ResourceQuota.pkl\" as rq" }
  // apps/v1
  else if (apiVersion == "apps/v1" && kind == "Deployment")
    new Listing { k8sImport; rsImport; podImport; "import \"@k8s/v1.30/apps/Deployment.pkl\" as dep" }
  else if (apiVersion == "apps/v1" && kind == "ReplicaSet")
    new Listing { k8sImport; rsImport; podImport }
  else if (apiVersion == "apps/v1" && kind == "StatefulSet")
    new Listing { k8sImport; rsImport; podImport; "import \"@k8s/v1.30/apps/StatefulSet.pkl\" as sts" }
  else if (apiVersion == "apps/v1" && kind == "DaemonSet")
    new Listing { k8sImport; rsImport; podImport; "import \"@k8s/v1.30/apps/DaemonSet.pkl\" as ds" }
  // batch/v1
  else if (apiVersion == "batch/v1" && kind == "Job")
    new Listing { k8sImport; rsImport; podImport; "import \"@k8s/v1.30/batch/Job.pkl\" as job" }
  else if (apiVersion == "batch/v1" && kind == "CronJob")
    new Listing { k8sImport; rsImport; podImport; "import \"@k8s/v1.30/batch/CronJob.pkl\" as cj" }
  // networking
  else if (apiVersion == "networking.k8s.io/v1" && kind == "Ingress")
    new Listing { k8sImport; "import \"@k8s/v1.30/networking/Ingress.pkl\" as ing" }
  else if (apiVersion == "networking.k8s.io/v1" && kind == "IngressClass")
    new Listing { k8sImport; "import \"@k8s/v1.30/networking/IngressClass.pkl\" as ic" }
  else if (apiVersion == "networking.k8s.io/v1" && kind == "NetworkPolicy")
    new Listing { k8sImport; rsImport; "import \"@k8s/v1.30/networking/NetworkPolicy.pkl\" as np" }
  // rbac
  else if (apiVersion == "rbac.authorization.k8s.io/v1" && kind == "Role")
    new Listing { k8sImport; "import \"@k8s/v1.30/rbac/Role.pkl\" as role" }
  else if (apiVersion == "rbac.authorization.k8s.io/v1" && kind == "RoleBinding")
    new Listing { k8sImport; "import \"@k8s/v1.30/rbac/RoleBinding.pkl\" as rb" }
  else if (apiVersion == "rbac.authorization.k8s.io/v1" && kind == "ClusterRole")
    new Listing { k8sImport; "import \"@k8s/v1.30/rbac/ClusterRole.pkl\" as cr" }
  else if (apiVersion == "rbac.authorization.k8s.io/v1" && kind == "ClusterRoleBinding")
    new Listing { k8sImport; "import \"@k8s/v1.30/rbac/ClusterRoleBinding.pkl\" as crb" }
  // policy
  else if (apiVersion == "policy/v1" && kind == "PodDisruptionBudget")
    new Listing { k8sImport; rsImport; "import \"@k8s/v1.30/policy/PodDisruptionBudget.pkl\" as pdb" }
  // storage
  else if (apiVersion == "storage.k8s.io/v1" && kind == "StorageClass")
    new Listing { k8sImport; "import \"@k8s/v1.30/storage/StorageClass.pkl\" as sc" }
  else if (apiVersion == "storage.k8s.io/v1" && kind == "CSIDriver")
    new Listing { k8sImport; "import \"@k8s/v1.30/storage/CSIDriver.pkl\" as csi" }
  // scheduling
  else if (apiVersion == "scheduling.k8s.io/v1" && kind == "PriorityClass")
    new Listing { k8sImport; "import \"@k8s/v1.30/scheduling/PriorityClass.pkl\" as pc" }
  // autoscaling
  else if (apiVersion == "autoscaling/v2" && kind == "HorizontalPodAutoscaler")
    new Listing { k8sImport; "import \"@k8s/v1.30/autoscaling/HorizontalPodAutoscaler.pkl\" as hpa" }
  // coordination
  else if (apiVersion == "coordination.k8s.io/v1" && kind == "Lease")
    new Listing { k8sImport; "import \"@k8s/v1.30/coordination/Lease.pkl\" as lease" }
  // node
  else if (apiVersion == "node.k8s.io/v1" && kind == "RuntimeClass")
    new Listing { k8sImport; "import \"@k8s/v1.30/node/RuntimeClass.pkl\" as rc" }
  // admissionregistration
  else if (apiVersion == "admissionregistration.k8s.io/v1" && kind == "ValidatingWebhookConfiguration")
    new Listing { k8sImport; "import \"@k8s/v1.30/admissionregistration/ValidatingWebhookConfiguration.pkl\" as vwc" }
  else if (apiVersion == "admissionregistration.k8s.io/v1" && kind == "MutatingWebhookConfiguration")
    new Listing { k8sImport; "import \"@k8s/v1.30/admissionregistration/MutatingWebhookConfiguration.pkl\" as mwc" }
  // flowcontrol
  else if (apiVersion == "flowcontrol.apiserver.k8s.io/v1" && kind == "FlowSchema")
    new Listing { k8sImport; "import \"@k8s/v1.30/flowcontrol/FlowSchema.pkl\" as fs" }
  else if (apiVersion == "flowcontrol.apiserver.k8s.io/v1" && kind == "PriorityLevelConfiguration")
    new Listing { k8sImport; "import \"@k8s/v1.30/flowcontrol/PriorityLevelConfiguration.pkl\" as plc" }
  else new Listing {}

function isSupported(apiVersion: String, kind: String): Boolean =
  !importsForType(apiVersion, kind).toList().isEmpty

// ── Shared renderers ─────────────────────────────────────────────────────────

/// Render k8s.ObjectMeta for namespaced resources.
function renderObjectMeta(meta: Any, ns: String, ind: String): String =
  let (annots = filterAnnotations(meta))
  w.joinNonEmpty(new Listing {
    ind + "metadata = new k8s.ObjectMeta {"
    w.strProp(ind + "  ", "name", meta.name)
    w.strProp(ind + "  ", "namespace", ns)
    w.mappingBlock(meta.labels, ind + "  ", "labels")
    when (annots != null) { w.mappingBlock(annots, ind + "  ", "annotations") }
    ind + "}"
  }.toList())

/// Render k8s.ObjectMeta for cluster-scoped resources (no namespace).
function renderClusterMeta(meta: Any, ind: String): String =
  let (annots = filterAnnotations(meta))
  w.joinNonEmpty(new Listing {
    ind + "metadata = new k8s.ObjectMeta {"
    w.strProp(ind + "  ", "name", meta.name)
    w.mappingBlock(meta.labels, ind + "  ", "labels")
    when (annots != null) { w.mappingBlock(annots, ind + "  ", "annotations") }
    ind + "}"
  }.toList())

/// Render ns.NamespaceMetadata (cluster-scoped, purpose-built for Namespace).
function renderNamespaceMetadata(meta: Any, ind: String): String =
  let (annots = filterAnnotations(meta))
  w.joinNonEmpty(new Listing {
    ind + "metadata = new ns.NamespaceMetadata {"
    w.strProp(ind + "  ", "name", meta.name)
    w.mappingBlock(meta.labels, ind + "  ", "labels")
    when (annots != null) { w.mappingBlock(annots, ind + "  ", "annotations") }
    ind + "}"
  }.toList())

/// Render rs.LabelSelector.
function renderLabelSelectorAs(sel: Any?, alias: String, ind: String, propName: String): String =
  if (sel == null) ""
  else w.joinNonEmpty(new Listing {
    ind + propName + " = new " + alias + ".LabelSelector {"
    w.mappingBlock(sel.matchLabels, ind + "  ", "matchLabels")
    when (sel.matchExpressions != null) {
      ind + "  matchExpressions {"
      for (_expr in sel.matchExpressions) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "key", _expr.key)
          w.strProp(ind + "      ", "operator", _expr.operator)
          w.stringListBlock(_expr.values, ind + "      ", "values")
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderLabelSelector(sel: Any?, alias: String, ind: String): String =
  if (sel == null) ""
  else w.joinNonEmpty(new Listing {
    ind + "selector = new " + alias + ".LabelSelector {"
    w.mappingBlock(sel.matchLabels, ind + "  ", "matchLabels")
    when (sel.matchExpressions != null) {
      ind + "  matchExpressions {"
      for (_expr in sel.matchExpressions) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "key", _expr.key)
          w.strProp(ind + "      ", "operator", _expr.operator)
          w.stringListBlock(_expr.values, ind + "      ", "values")
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

/// Render rs.PodTemplateMetadata.
function renderPodTemplateMeta(meta: Any?, ind: String): String =
  if (meta == null) ""
  else
    let (annots = filterAnnotations(meta))
    w.joinNonEmpty(new Listing {
      ind + "metadata = new rs.PodTemplateMetadata {"
      w.mappingBlock(meta.labels, ind + "  ", "labels")
      when (annots != null) { w.mappingBlock(annots, ind + "  ", "annotations") }
      ind + "}"
    }.toList())

/// Render pod.PodSpec.
/// Schema fields: containers, restartPolicy, nodeSelector, serviceAccountName
function renderPodSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new pod.PodSpec {"
    when (spec.containers != null) {
      ind + "  containers {"
      for (_c in spec.containers) {
        renderContainer(_c, ind + "    ")
      }
      ind + "  }"
    }
    w.strProp(ind + "  ", "restartPolicy", spec.restartPolicy)
    w.strProp(ind + "  ", "serviceAccountName", spec.serviceAccountName)
    w.mappingBlock(spec.nodeSelector, ind + "  ", "nodeSelector")
    ind + "}"
  }.toList())

/// Render a single container (anonymous new inside typed Listing).
/// Schema fields: name, image, command, args, env, ports, resources
function renderContainer(c: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", c.name)
    w.strProp(ind + "  ", "image", c.image)
    w.stringListBlock(c.command, ind + "  ", "command")
    w.stringListBlock(c.args, ind + "  ", "args")
    when (c.ports != null) {
      ind + "  ports {"
      for (_p in c.ports) {
        renderContainerPort(_p, ind + "    ")
      }
      ind + "  }"
    }
    when (c.env != null) {
      ind + "  env {"
      for (_e in c.env) {
        renderEnvVar(_e, ind + "    ")
      }
      ind + "  }"
    }
    when (c.resources != null) {
      renderResourceReqs(c.resources, ind + "  ")
    }
    ind + "}"
  }.toList())

/// Render a container port (anonymous new).
function renderContainerPort(p: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", p.name)
    w.intProp(ind + "  ", "containerPort", p.containerPort)
    w.strProp(ind + "  ", "protocol", p.protocol)
    ind + "}"
  }.toList())

/// Render an env var (anonymous new).
function renderEnvVar(e: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", e.name)
    w.strProp(ind + "  ", "value", e.value)
    ind + "}"
  }.toList())

/// Render resource requirements.
function renderResourceReqs(r: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "resources = new pod.ResourceRequirements {"
    w.qtyMappingBlock(r.limits, ind + "  ", "limits")
    w.qtyMappingBlock(r.requests, ind + "  ", "requests")
    ind + "}"
  }.toList())

/// Render rs.PodTemplateSpec.
function renderPodTemplateSpec(tpl: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "template = new rs.PodTemplateSpec {"
    renderPodTemplateMeta(tpl.metadata, ind + "  ")
    renderPodSpec(tpl.spec, ind + "  ")
    ind + "}"
  }.toList())

// ── Per-type renderers ───────────────────────────────────────────────────────

// ── Core/v1 ──────────────────────────────────────────────────────────────────

function renderNamespace(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new ns.Namespace {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "namespace", src.metadata.name))
    renderNamespaceMetadata(src.metadata, ind + "  ")
    ind + "}"
  }.toList())

function renderPod(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new pod.Pod {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "pod", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    renderPodSpec(src.spec, ind + "  ")
    ind + "}"
  }.toList())

function renderConfigMap(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new cm.ConfigMap {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "configmap", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    w.mappingBlock(src.data, ind + "  ", "data")
    w.mappingBlock(src.binaryData, ind + "  ", "binaryData")
    w.boolProp(ind + "  ", "immutable", src.immutable)
    ind + "}"
  }.toList())

function renderSecret(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new secret.Secret {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "secret", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    w.strProp(ind + "  ", "type", src.type)
    w.mappingBlock(src.data, ind + "  ", "data")
    w.mappingBlock(src.stringData, ind + "  ", "stringData")
    w.boolProp(ind + "  ", "immutable", src.immutable)
    ind + "}"
  }.toList())

function renderServiceAccount(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new sa.ServiceAccount {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "serviceaccount", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    w.boolProp(ind + "  ", "automountServiceAccountToken", src.automountServiceAccountToken)
    ind + "}"
  }.toList())

function renderService(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new svc.Service {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "service", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) { renderServiceSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderServiceSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new svc.ServiceSpec {"
    w.strProp(ind + "  ", "type", spec.type)
    w.strProp(ind + "  ", "clusterIP", spec.clusterIP)
    w.strProp(ind + "  ", "externalTrafficPolicy", spec.externalTrafficPolicy)
    w.strProp(ind + "  ", "sessionAffinity", spec.sessionAffinity)
    w.mappingBlock(spec.selector, ind + "  ", "selector")
    when (spec.ports != null) {
      ind + "  ports {"
      for (_p in spec.ports) {
        renderServicePort(_p, ind + "    ")
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderServicePort(p: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.strProp(ind + "  ", "name", p.name)
    w.intProp(ind + "  ", "port", p.port)
    w.strProp(ind + "  ", "targetPort", if (p.targetPort != null) "\(p.targetPort)" else null)
    w.strProp(ind + "  ", "protocol", p.protocol)
    w.intProp(ind + "  ", "nodePort", p.nodePort)
    ind + "}"
  }.toList())

function renderEndpoints(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new ep.Endpoints {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "endpoints", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.subsets != null) {
      ind + "  subsets {"
      for (_sub in src.subsets) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          when (_sub.addresses != null) {
            ind + "      addresses {"
            for (_addr in _sub.addresses) {
              ind + "        new { ip = " + w.q(_addr.ip) + " }"
            }
            ind + "      }"
          }
          when (_sub.ports != null) {
            ind + "      ports {"
            for (_p in _sub.ports) {
              w.joinNonEmpty(new Listing {
                ind + "        new {"
                w.intProp(ind + "          ", "port", _p.port)
                w.strProp(ind + "          ", "protocol", _p.protocol)
                w.strProp(ind + "          ", "name", _p.name)
                ind + "        }"
              }.toList())
            }
            ind + "      }"
          }
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderLimitRange(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new lr.LimitRange {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "limitrange", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null && src.spec.limits != null) {
      ind + "  limits {"
      for (_item in src.spec.limits) {
        w.joinNonEmpty(new Listing {
          ind + "    new {"
          w.strProp(ind + "      ", "type", _item.type)
          w.qtyMappingBlock(_item.max, ind + "      ", "max")
          w.qtyMappingBlock(_item.min, ind + "      ", "min")
          w.qtyMappingBlock(_item.default, ind + "      ", "default")
          w.qtyMappingBlock(_item.defaultRequest, ind + "      ", "defaultRequest")
          ind + "    }"
        }.toList())
      }
      ind + "  }"
    }
    ind + "}"
  }.toList())

function renderPersistentVolume(src: Any, prefix: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new pv.PersistentVolume {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "persistentvolume", src.metadata.name))
    renderClusterMeta(src.metadata, ind + "  ")
    when (src.spec != null) {
      w.qtyMappingBlock(src.spec.capacity, ind + "  ", "capacity")
      w.stringListBlock(src.spec.accessModes, ind + "  ", "accessModes")
      w.strProp(ind + "  ", "persistentVolumeReclaimPolicy", src.spec.persistentVolumeReclaimPolicy)
      w.strProp(ind + "  ", "storageClassName", src.spec.storageClassName)
      w.strProp(ind + "  ", "volumeMode", src.spec.volumeMode)
    }
    ind + "}"
  }.toList())

function renderPersistentVolumeClaim(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new pvc.PersistentVolumeClaim {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "persistentvolumeclaim", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new pvc.PersistentVolumeClaimSpec {"
        w.stringListBlock(src.spec.accessModes, ind + "    ", "accessModes")
        w.strProp(ind + "    ", "storageClassName", src.spec.storageClassName)
        w.strProp(ind + "    ", "volumeName", src.spec.volumeName)
        w.strProp(ind + "    ", "volumeMode", src.spec.volumeMode)
        when (src.spec.resources != null) {
          w.joinNonEmpty(new Listing {
            ind + "    resources {"
            w.qtyMappingBlock(src.spec.resources.requests, ind + "      ", "requests")
            ind + "    }"
          }.toList())
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderResourceQuota(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new rq.ResourceQuota {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "resourcequota", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.qtyMappingBlock(src.spec.hard, ind + "  ", "hard")
      w.stringListBlock(src.spec.scopes, ind + "  ", "scopes")
    }
    ind + "}"
  }.toList())

// ── Apps/v1 ──────────────────────────────────────────────────────────────────

function renderDeployment(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new dep.Deployment {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "deployment", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) { renderDeploymentSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderDeploymentSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new dep.DeploymentSpec {"
    w.intProp(ind + "  ", "replicas", spec.replicas)
    w.intProp(ind + "  ", "minReadySeconds", spec.minReadySeconds)
    w.intProp(ind + "  ", "progressDeadlineSeconds", spec.progressDeadlineSeconds)
    w.intProp(ind + "  ", "revisionHistoryLimit", spec.revisionHistoryLimit)
    w.boolProp(ind + "  ", "paused", spec.paused)
    renderLabelSelector(spec.selector, "rs", ind + "  ")
    when (spec.strategy != null) { renderDeploymentStrategy(spec.strategy, ind + "  ") }
    when (spec.template != null) { renderPodTemplateSpec(spec.template, ind + "  ") }
    ind + "}"
  }.toList())

function renderDeploymentStrategy(strat: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "strategy = new dep.DeploymentStrategy {"
    w.strProp(ind + "  ", "type", strat.type)
    when (strat.rollingUpdate != null) {
      w.joinNonEmpty(new Listing {
        ind + "  rollingUpdate = new dep.RollingUpdateDeployment {"
        w.strProp(ind + "    ", "maxUnavailable", if (strat.rollingUpdate.maxUnavailable != null) "\(strat.rollingUpdate.maxUnavailable)" else null)
        w.strProp(ind + "    ", "maxSurge", if (strat.rollingUpdate.maxSurge != null) "\(strat.rollingUpdate.maxSurge)" else null)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderReplicaSet(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new rs.ReplicaSet {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "replicaset", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec = new rs.ReplicaSetSpec {"
        w.intProp(ind + "    ", "replicas", src.spec.replicas)
        w.intProp(ind + "    ", "minReadySeconds", src.spec.minReadySeconds)
        renderLabelSelector(src.spec.selector, "rs", ind + "    ")
        when (src.spec.template != null) { renderPodTemplateSpec(src.spec.template, ind + "    ") }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderStatefulSet(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
  w.joinNonEmpty(new Listing {
    ind + "new sts.StatefulSet {"
    w.strProp(ind + "  ", "label", makeLabel(prefix, "statefulset", src.metadata.name))
    renderObjectMeta(src.metadata, ns, ind + "  ")
    when (src.spec != null) { renderStatefulSetSpec(src.spec, ind + "  ") }
    ind + "}"
  }.toList())

function renderStatefulSetSpec(spec: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "spec = new sts.StatefulSetSpec {"
    w.intProp(ind + "  ", "replicas", spec.replicas)
    w.strProp(ind + "  ", "serviceName", spec.serviceName)
    w.strProp(ind + "  ", "podManagementPolicy", spec.podManagementPolicy)
    w.intProp(ind + "  ", "revisionHistoryLimit", spec.revisionHistoryLimit)
    w.intProp(ind + "  ", "minReadySeconds", spec.minReadySeconds)
    renderLabelSelector(spec.selector, "rs", ind + "  ")
    when (spec.template != null) { renderPodTemplateSpec(spec.template, ind + "  ") }
    when (spec.volumeClaimTemplates != null) {
      ind + "  volumeClaimTemplates {"
      for (_vct in spec.volumeClaimTemplates) {
        renderPVCTemplate(_vct, ind + "    ")
      }
      ind + "  }"
    }
    when (spec.updateStrategy != null) {
      w.joinNonEmpty(new Listing {
        ind + "  updateStrategy {"
        w.strProp(ind + "    ", "type", spec.updateStrategy.type)
        when (spec.updateStrategy.rollingUpdate != null) {
          w.joinNonEmpty(new Listing {
            ind + "    rollingUpdate {"
            w.intProp(ind + "      ", "partition", spec.updateStrategy.rollingUpdate.partition)
            w.strProp(ind + "      ", "maxUnavailable", if (spec.updateStrategy.rollingUpdate.maxUnavailable != null) "\(spec.updateStrategy.rollingUpdate.maxUnavailable)" else null)
            ind + "    }"
          }.toList())
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderPVCTemplate(vct: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    renderPodTemplateMeta(vct.metadata, ind + "  ")
    when (vct.spec != null) {
      w.joinNonEmpty(new Listing {
        ind + "  spec {"
        w.stringListBlock(vct.spec.accessModes, ind + "    ", "accessModes")
        w.strProp(ind + "    ", "storageClassName", vct.spec.storageClassName)
        w.strProp(ind + "    ", "volumeMode", vct.spec.volumeMode)
        when (vct.spec.resources != null) {
          w.joinNonEmpty(new Listing {
            ind + "    resources {"
            w.qtyMappingBlock(vct.spec.resources.requests, ind + "      ", "requests")
            w.qtyMappingBlock(vct.spec.resources.limits, ind + "      ", "limits")
            ind + "    }"
          }.toList())
        }
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderDaemonSet(src: Any, prefix: String, ns: String): String =
  let (ind = "  ")
