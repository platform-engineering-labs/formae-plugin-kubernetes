function renderPolicyRule(rule: Any, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "new {"
    w.stringListBlock(rule.apiGroups, ind + "  ", "apiGroups")
    w.stringListBlock(rule.resources, ind + "  ", "resources")
    w.stringListBlock(rule.verbs, ind + "  ", "verbs")
    w.stringListBlock(rule.resourceNames, ind + "  ", "resourceNames")
    ind + "}"
  }.toList())

function renderRoleRef(ref: Any, alias: String, ind: String): String =
  w.joinNonEmpty(new Listing {
    ind + "roleRef = new " + alias + ".RoleRef {"
    w.strProp(ind + "  ", "apiGroup", if (ref.apiGroup != null) "\(ref.apiGroup)" else "rbac.authorization.k8s.io")
    w.strProp(ind + "  ", "kind", ref.kind)
    w.strProp(ind + "  ", "name", ref.name)
    ind + "}"
  }.toList())

function renderSubjects(subjects: Any?, alias: String, ind: String): String =
  if (subjects == null) ""
  else w.joinNonEmpty(new Listing {
    ind + "subjects {"
    for (_s in subjects) {
      w.joinNonEmpty(new Listing {
        ind + "  new {"
        w.strProp(ind + "    ", "kind", _s.kind)
        w.strProp(ind + "    ", "name", _s.name)
        w.strProp(ind + "    ", "namespace", _s.namespace)
        w.strProp(ind + "    ", "apiGroup", _s.apiGroup)
        ind + "  }"
      }.toList())
    }
    ind + "}"
  }.toList())

function renderRole(src: Any, prefix: String, ns: String): String =
