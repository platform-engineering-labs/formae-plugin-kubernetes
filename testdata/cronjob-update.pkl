/*
 * Conformance Test: CronJob (Update)
 * Changes: schedule changed (mutable), suspend set to true
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/core/Namespace.pkl" as ns
import "@formae-plugin-k8s/core/Pod.pkl" as pod
import "@formae-plugin-k8s/apps/ReplicaSet.pkl" as rs
import "@formae-plugin-k8s/batch/Job.pkl" as job
import "@formae-plugin-k8s/batch/CronJob.pkl" as cj
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new cj.CronJob {
    label = "test-cronjob"
    metadata = new k8s.ObjectMeta {
      name = "test-cj-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new cj.CronJobSpec {
      schedule = "*/10 * * * *"
      suspend = true
      successfulJobsHistoryLimit = 1
      failedJobsHistoryLimit = 1
      jobTemplate = new cj.JobTemplateSpec {
        spec = new job.JobSpec {
          backoffLimit = 1
          template = new rs.PodTemplateSpec {
            spec = new pod.PodSpec {
              containers = new Listing {
                new pod.Container {
                  name = "cron-worker"
                  image = "busybox:latest"
                  command = new Listing { "echo"; "tick" }
                }
              }
              restartPolicy = "Never"
            }
          }
        }
      }
    }
  }
}
