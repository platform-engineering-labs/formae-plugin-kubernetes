/*
 * Conformance Test: MutatingWebhookConfiguration (Create)
 *
 * Safety: Uses failurePolicy=Ignore, URL-based clientConfig (no real service),
 * sideEffects=None, and namespaceSelector matching only test namespace.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.21/admissionregistration/MutatingWebhookConfiguration.pkl" as mwc
import "@k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new mwc.MutatingWebhookConfiguration {
    label = "test-mutatingwebhook"
    metadata = new k8s.ObjectMeta {
      name = "test-mwc-\(v.testRunID)"
    }
    webhooks = new Listing {
      new mwc.MutatingWebhook {
        name = "test-mwc-\(v.testRunID).formae.io"
        admissionReviewVersions = new Listing { "v1" }
        sideEffects = "None"
        failurePolicy = "Ignore"
        clientConfig = new k8s.WebhookClientConfig {
          url = "https://localhost:9443/test-mutate"
        }
        namespaceSelector = new k8s.LabelSelector {
          matchLabels = new Mapping {
            ["test-run"] = v.testRunID
          }
        }
        // K8s defaults to {} (matches all); declared for live-state parity.
        objectSelector = new k8s.LabelSelector {}
        rules = new Listing {
          new k8s.RuleWithOperations {
            operations = new Listing { "CREATE" }
            apiGroups = new Listing { "" }
            apiVersions = new Listing { "v1" }
            resources = new Listing { "configmaps" }
            scope = "*"
          }
        }
      }
    }
  }
}
