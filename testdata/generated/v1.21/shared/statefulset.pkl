/*
 * Conformance Test: StatefulSet (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.21/core/Namespace.pkl" as ns
import "@k8s/v1.21/core/Service.pkl" as svc
import "@k8s/v1.21/apps/StatefulSet.pkl" as sts
import "@k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new svc.Service {
    label = "test-sts-svc"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-sts-svc-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new svc.ServiceSpec {
      clusterIP = "None"
      selector = new Mapping {
        ["app"] = "test-sts"
      }
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          name = "http"
        }
      }
    }
  }

  new sts.StatefulSet {
    label = "test-statefulset"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-sts-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new sts.StatefulSetSpec {
      replicas = 1
      serviceName = "test-sts-svc-\(v.testRunID)"
      selector = new k8s.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = "test-sts"
        }
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.ObjectMeta {
          name = "test-sts-\(v.testRunID)"
          labels = new Mapping {
            ["app"] = "test-sts"
          }
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "nginx"
              image = "nginx:alpine"
            }
          }
        }
      }
    }
  }
}
