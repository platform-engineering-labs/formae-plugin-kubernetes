/*
 * Conformance Test: PersistentVolume (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.21/core/PersistentVolume.pkl" as pv
import "@k8s/v1.21/subresources.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new pv.PersistentVolume {
    label = "test-persistentvolume"
    metadata = new k8s.ObjectMeta {
      name = "test-pv-\(v.testRunID)"
    }
    spec = new Mapping {
      ["capacity"] = new Mapping {
        ["storage"] = "1Gi"
      }
      ["accessModes"] = new Listing {
        "ReadWriteOnce"
      }
      ["persistentVolumeReclaimPolicy"] = "Retain"
      ["volumeMode"] = "Filesystem"
      ["hostPath"] = new Mapping {
        ["path"] = "/tmp/test-pv"
      }
    }
  }
}
