/*
 * Conformance Test: CustomResourceDefinition (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.21/apiextensions/CustomResourceDefinition.pkl" as crd
import "@k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new crd.CustomResourceDefinition {
    label = "test-crd"
    metadata = new k8s.ObjectMeta {
      name = "testresources-\(v.testRunID).testing.formae.io"
    }
    spec {
      group = "testing.formae.io"
      names {
        kind = "TestResource"
        listKind = "TestResourceList"
        plural = "testresources-\(v.testRunID)"
        singular = "testresource-\(v.testRunID)"
      }
      scope = "Namespaced"
      versions {
        new {
          name = "v1alpha1"
          served = true
          storage = true
          schema {
            openAPIV3Schema {
              type = "object"
              properties {
                spec {
                  type = "object"
                  properties {
                    name {
                      type = "string"
                    }
                    replicas {
                      type = "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
