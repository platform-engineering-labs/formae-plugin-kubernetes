/*
 * Conformance Test: StatefulSet with PVC retention policy.
 *
 * Exercises spec.persistentVolumeClaimRetentionPolicy (KEP-1847).
 * Sets whenScaled = "Delete" so scaling down also removes the PVC.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.35/core/Namespace.pkl" as ns
import "@k8s/v1.35/core/Service.pkl" as svc
import "@k8s/v1.35/apps/StatefulSet.pkl" as sts
import "@k8s/v1.35/subresources.pkl" as k8s
import "../../shared/config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new svc.Service {
    label = "test-sts-svc-pvc"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-sts-svc-pvc-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new svc.ServiceSpec {
      clusterIP = "None"
      selector = new Mapping {
        ["app"] = "test-sts-pvc"
      }
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          name = "http"
        }
      }
    }
  }

  new sts.StatefulSet {
    label = "test-sts-pvc"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-sts-pvc-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new sts.StatefulSetSpec {
      replicas = 1
      serviceName = "test-sts-svc-pvc-\(v.testRunID)"
      persistentVolumeClaimRetentionPolicy = new sts.StatefulSetPersistentVolumeClaimRetentionPolicy {
        whenScaled = "Delete"
        whenDeleted = "Delete"
      }
      selector = new k8s.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = "test-sts-pvc"
        }
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.ObjectMeta {
          name = "test-sts-pvc-\(v.testRunID)"
          labels = new Mapping {
            ["app"] = "test-sts-pvc"
          }
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "main"
              image = "registry.k8s.io/pause:3.10"
            }
          }
        }
      }
    }
  }
}
