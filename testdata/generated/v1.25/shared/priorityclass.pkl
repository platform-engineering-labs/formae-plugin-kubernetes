/*
 * Conformance Test: PriorityClass (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.25/scheduling/PriorityClass.pkl" as pc
import "@k8s/v1.25/subresources.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new pc.PriorityClass {
    label = "test-priorityclass"
    metadata = new k8s.ObjectMeta {
      name = "test-pc-\(v.testRunID)"
    }
    value = 1000
    globalDefault = false
    description = "Test priority class"
    preemptionPolicy = "PreemptLowerPriority"
  }
}
