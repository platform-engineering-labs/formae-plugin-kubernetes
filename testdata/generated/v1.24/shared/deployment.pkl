/*
 * Conformance Test: Deployment (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.24/core/Namespace.pkl" as ns
import "@k8s/v1.24/apps/Deployment.pkl" as dep
import "@k8s/v1.24/subresources.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new dep.Deployment {
    label = "test-deployment"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-dep-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new dep.DeploymentSpec {
      replicas = 1
      selector = new k8s.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = "test-dep"
        }
      }
      template = new k8s.PodTemplateSpec {
        metadata = new k8s.ObjectMeta {
          name = "test-dep-\(v.testRunID)"
          labels = new Mapping {
            ["app"] = "test-dep"
          }
        }
        spec = new k8s.PodSpec {
          containers = new Listing {
            new k8s.Container {
              name = "nginx"
              image = "nginx:alpine"
              ports = new Listing {
                new k8s.ContainerPort {
                  containerPort = 80
                }
              }
            }
          }
        }
      }
    }
  }
}
