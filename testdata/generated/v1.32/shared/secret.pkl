/*
 * Conformance Test: Secret (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.32/core/Namespace.pkl" as ns
import "@k8s/v1.32/core/Secret.pkl" as sec
import "@k8s/v1.32/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new sec.Secret {
    label = "test-secret"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-secret-\(v.testRunID)"
      namespace = ns.res.name
    }
    type = "Opaque"
    stringData = new Mapping {
      ["username"] = "admin"
      ["password"] = "secret123"
    }
  }
}
