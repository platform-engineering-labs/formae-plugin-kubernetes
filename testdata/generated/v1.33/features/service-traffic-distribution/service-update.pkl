/*
 * Conformance Update: switch trafficDistribution from PreferClose to "".
 * Confirms the field is mutable and can be unset back to default routing.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.33/core/Namespace.pkl" as ns
import "@k8s/v1.33/core/Service.pkl" as svc
import "@k8s/k8s.pkl" as k8s
import "../../shared/config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new svc.Service {
    label = "test-svc-td"
    metadata = new k8s.NamespacedObjectMeta {
      name = "test-svc-td-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new svc.ServiceSpec {
      type = "ClusterIP"
      // trafficDistribution unset on update; expected to revert to round-robin.
      selector = new Mapping {
        ["app"] = "test-svc-td"
      }
      ports = new Listing {
        new svc.ServicePort {
          port = 80
          targetPort = 80
          name = "http"
        }
      }
    }
  }
}
