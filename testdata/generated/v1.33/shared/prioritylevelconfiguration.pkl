/*
 * Conformance Test: PriorityLevelConfiguration (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.33/flowcontrol/PriorityLevelConfiguration.pkl" as plc
import "@k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new plc.PriorityLevelConfiguration {
    label = "test-prioritylevelconfig"
    metadata = new k8s.ObjectMeta {
      name = "test-plc-\(v.testRunID)"
    }
    spec = new plc.PriorityLevelConfigurationSpec {
      type = "Limited"
      limited = new plc.LimitedPriorityLevelConfiguration {
        nominalConcurrencyShares = 10
        lendablePercent = 0
        limitResponse = new plc.LimitResponse {
          type = "Reject"
        }
      }
    }
  }
}
