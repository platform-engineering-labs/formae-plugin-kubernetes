/*
 * Conformance Update: switch unhealthyPodEvictionPolicy from
 * AlwaysAllow to IfHealthyBudget.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/v1.31/core/Namespace.pkl" as ns
import "@k8s/v1.31/policy/PodDisruptionBudget.pkl" as pdb
import "@k8s/k8s.pkl" as k8s
import "../../shared/config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new pdb.PodDisruptionBudget {
    label = "test-pdb-uev"
    metadata = new k8s.ObjectMeta {
      name = "test-pdb-uev-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new pdb.PodDisruptionBudgetSpec {
      minAvailable = 1
      unhealthyPodEvictionPolicy = "IfHealthyBudget"
      selector = new k8s.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = "test-uev"
        }
      }
    }
  }
}
