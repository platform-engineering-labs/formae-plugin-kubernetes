/*
 * Conformance Test: Endpoints (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/core/Namespace.pkl" as ns
import "@formae-plugin-k8s/core/Endpoints.pkl" as ep
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new ep.Endpoints {
    label = "test-endpoints"
    metadata = new k8s.ObjectMeta {
      name = "test-ep-\(v.testRunID)"
      namespace = ns.res.name
    }
    subsets = new Listing {
      new ep.EndpointSubset {
        addresses = new Listing {
          new ep.EndpointAddress {
            ip = "10.0.0.1"
          }
        }
        ports = new Listing {
          new ep.EndpointPort {
            port = 80
            protocol = "TCP"
          }
        }
      }
    }
  }
}
