/*
 * Conformance Test: RuntimeClass (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/node/RuntimeClass.pkl" as rc
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new rc.RuntimeClass {
    label = "test-runtimeclass"
    metadata = new k8s.ObjectMeta {
      name = "test-rc-\(v.testRunID)"
    }
    handler = "runc"
  }
}
