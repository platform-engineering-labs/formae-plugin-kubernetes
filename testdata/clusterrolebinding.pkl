/*
 * Conformance Test: ClusterRoleBinding (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/rbac/ClusterRoleBinding.pkl" as crb
import "@formae-plugin-k8s/rbac/RoleBinding.pkl" as rb
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new crb.ClusterRoleBinding {
    label = "test-clusterrolebinding"
    metadata = new k8s.ObjectMeta {
      name = "test-crb-\(v.testRunID)"
    }
    roleRef = new rb.RoleRef {
      kind = "ClusterRole"
      name = "test-cr-\(v.testRunID)"
    }
    subjects = new Listing {
      new rb.Subject {
        kind = "ServiceAccount"
        name = "default"
        namespace = "default"
      }
    }
  }
}
