/*
 * Conformance Test: ConfigMap (Update)
 * Changes: modified data values (mutable)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@k8s/core/Namespace.pkl" as ns
import "@k8s/core/ConfigMap.pkl" as cm
import "@k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new cm.ConfigMap {
    label = "test-configmap"
    metadata = new k8s.ObjectMeta {
      name = "test-cm-\(v.testRunID)"
      namespace = "formae-test-\(v.testRunID)"
    }
    data = new Mapping {
      ["greeting"] = "hello-updated"
      ["database_url"] = "postgres://localhost:5432/mydb-v2"
    }
  }
}
