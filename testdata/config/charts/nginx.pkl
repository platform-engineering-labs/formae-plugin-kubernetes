/*
 * Chart Smoke Test: NginxChart
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-charts/NginxChart.pkl"
import "./config/vars.pkl" as v

local chart = new NginxChart.Nginx {
  name = "test-nginx-\(v.testRunID)"
  namespace = "chart-nginx-\(v.testRunID)"
  createNamespace = true
  replicas = 1
  image = "nginx:alpine"
}

forma {
  local stack = new formae.Stack {
  label = "chart-test-stack"
  description = "Chart integration test stack"
}
stack
  v.target
  for (r in chart.resources) { r }
}
