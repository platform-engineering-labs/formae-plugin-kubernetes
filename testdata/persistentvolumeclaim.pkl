/*
 * Conformance Test: PersistentVolumeClaim (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/core/Namespace.pkl" as ns
import "@formae-plugin-k8s/core/PersistentVolumeClaim.pkl" as pvc
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new pvc.PersistentVolumeClaim {
    label = "test-persistentvolumeclaim"
    metadata = new k8s.ObjectMeta {
      name = "test-pvc-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new pvc.PersistentVolumeClaimSpec {
      accessModes = new Listing {
        "ReadWriteOnce"
      }
      resources = new pvc.VolumeResourceRequirements {
        requests = new Mapping {
          ["storage"] = "1Gi"
        }
      }
    }
  }
}
