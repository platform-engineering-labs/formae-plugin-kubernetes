/*
 * Conformance Test: NetworkPolicy (Update)
 * Changes: added Egress to policyTypes, added egress rule for port 443 (mutable)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-plugin-k8s/core/Namespace.pkl" as ns
import "@formae-plugin-k8s/apps/ReplicaSet.pkl" as rs
import "@formae-plugin-k8s/networking/NetworkPolicy.pkl" as np
import "@formae-plugin-k8s/k8s.pkl" as k8s
import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  local ns = new ns.Namespace {
    label = "test-ns"
    metadata = new ns.NamespaceMetadata {
      name = "formae-test-\(v.testRunID)"
      labels = new Mapping {
        ["managed-by"] = "formae"
        ["test-run"] = v.testRunID
      }
    }
  }

  ns

  new np.NetworkPolicy {
    label = "test-networkpolicy"
    metadata = new k8s.ObjectMeta {
      name = "test-np-\(v.testRunID)"
      namespace = ns.res.name
    }
    spec = new np.NetworkPolicySpec {
      podSelector = new rs.LabelSelector {
        matchLabels = new Mapping {
          ["app"] = "test"
        }
      }
      ingress = new Listing {
        new np.NetworkPolicyIngressRule {
          ports = new Listing {
            new np.NetworkPolicyPort {
              port = 80
              protocol = "TCP"
            }
          }
        }
      }
      egress = new Listing {
        new np.NetworkPolicyEgressRule {
          ports = new Listing {
            new np.NetworkPolicyPort {
              port = 443
              protocol = "TCP"
            }
          }
        }
      }
      policyTypes = new Listing {
        "Ingress"
        "Egress"
      }
    }
  }
}
