/*
 * Conformance Test: GrafanaFormation (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-formations/GrafanaFormation.pkl"
import "../shared/config/vars.pkl" as v

local chart = new GrafanaFormation.Grafana {
  name = "test-grafana-\(v.testRunID)"
  namespace = "formae-test-\(v.testRunID)"
  createNamespace = true
  replicas = 1
  adminPassword = "test-pass"
  datasourceUrl = "http://localhost:9090"
}

forma {
  new formae.Stack { label = "grafana-chart-test"; description = "Grafana chart conformance test" }
  v.target
  for (r in chart.resources) { r }
}
