/*
 * Conformance Test: KeycloakChart (Create)
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae-charts/KeycloakChart.pkl"
import "./config/vars.pkl" as v

local chart = new KeycloakChart.Keycloak {
  name = "test-kc-\(v.testRunID)"
  namespace = "formae-test-\(v.testRunID)"
  createNamespace = true
  replicas = 1
  adminPassword = "test-admin-pass"
}

forma {
  new formae.Stack { label = "keycloak-chart-test"; description = "Keycloak chart conformance test" }
  v.target
  for (r in chart.resources) { r }
}
