// Shared Type Registry
// =============================================================================
// Maps shared type names to their reflected Class objects.
// These types are generated in k8s.pkl.

// Module-level shared types (each has its own .pkl file in pkl-k8s)
local sharedModuleClasses: Mapping<String, reflect.Class> = new {
  ["LabelSelector"] = reflect.Module(k8sLabelSelector).moduleClass
  ["LabelSelectorRequirement"] = reflect.Module(k8sLabelSelectorRequirement).moduleClass
  ["PodSpec"] = reflect.Module(k8sPodSpec).moduleClass
  ["PodTemplateSpec"] = reflect.Module(k8sPodTemplateSpec).moduleClass
  ["Volume"] = reflect.Module(k8sVolume).moduleClass
  ["VolumeMount"] = reflect.Module(k8sVolumeMount).moduleClass
  ["ContainerPort"] = reflect.Module(k8sContainerPort).moduleClass
  ["EnvVar"] = reflect.Module(k8sEnvVar).moduleClass
  ["ObjectFieldSelector"] = reflect.Module(k8sObjectFieldSelector).moduleClass
  ["ResourceFieldSelector"] = reflect.Module(k8sResourceFieldSelector).moduleClass
  ["ResourceRequirements"] = reflect.Module(k8sResourceRequirements).moduleClass
  ["JobSpec"] = reflect.Module(k8sJobSpec).moduleClass
  ["PolicyRule"] = reflect.Module(k8sPolicyRule).moduleClass
  ["RoleRef"] = reflect.Module(k8sRoleRef).moduleClass
  ["Subject"] = reflect.Module(k8sSubject).moduleClass
  ["RuleWithOperations"] = reflect.Module(k8sRuleWithOperations).moduleClass
  ["WebhookClientConfig"] = reflect.Module(k8sWebhookClientConfig).moduleClass
  ["MatchCondition"] = reflect.Module(k8sMatchCondition).moduleClass
}

// All shared type source modules (for auto-discovering nested classes).
// Every module-level shared type's .pkl may contain nested classes that
// shared type fields reference, so we include them all.
local sharedNestedSources: Listing<reflect.Module> = new {
  reflect.Module(k8sPodSpec)
  reflect.Module(k8sPodTemplateSpec)
  reflect.Module(k8sVolume)
  reflect.Module(k8sVolumeMount)
  reflect.Module(k8sContainerPort)
  reflect.Module(k8sEnvVar)
  reflect.Module(k8sObjectFieldSelector)
  reflect.Module(k8sResourceFieldSelector)
  reflect.Module(k8sResourceRequirements)
  reflect.Module(k8sJobSpec)
  reflect.Module(k8sLabelSelector)
  reflect.Module(k8sLabelSelectorRequirement)
  reflect.Module(k8sPolicyRule)
  reflect.Module(k8sRoleRef)
  reflect.Module(k8sSubject)
  reflect.Module(k8sRuleWithOperations)
  reflect.Module(k8sWebhookClientConfig)
  reflect.Module(k8sMatchCondition)
}

// All shared type classes: module-level + auto-discovered nested classes
local sharedTypeClasses: Mapping<String, reflect.Class> = new {
  for (name, cls in sharedModuleClasses) {
    [name] = cls
  }
  for (_i, mod in sharedNestedSources) {
    for (name, cls in mod.classes) {
      when (!isExcludedClass(name)) {
        [name] = cls
      }
    }
  }
}

// All shared type names (includes static types not from reflection)
local sharedTypeNames: Set<String> =
  sharedTypeClasses.keys.toSet()
    .add("ObjectMeta")
    .add("PodTemplateMetadata")

