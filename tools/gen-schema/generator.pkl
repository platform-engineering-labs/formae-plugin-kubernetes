// k8s.pkl Generation — Static Sections
// =============================================================================

local licenseHeader: String = #"""
  /*
   * © 2025 Platform Engineering Labs Inc.
   *
   * SPDX-License-Identifier: Apache-2.0
   *
   * K8S Plugin Schema - Base definitions for Kubernetes resources
   * Generated by tools/gen-schema/generator.pkl
   */

  """#

local k8sModuleHeader: String = #"""
  module k8s

  import "@formae/formae.pkl"

  """#

local configClass: String = #"""
  // =============================================================================
  // Target Configuration
  // =============================================================================

  /// Configuration for the K8S target.
  /// Maps to the Go Config struct in pkg/config/config.go.
  open class Config {
    hidden fixed type: String = "K8S"

    /// Default namespace for namespaced resources (defaults to "default")
    hidden defaultNamespace: String?

    /// Whether this cluster has a cloud load balancer controller.
    /// Defaults to true (production/cloud clusters). Set to false for local
    /// clusters without a LB controller (OrbStack, minikube, kind).
    hidden hasLoadBalancer: Boolean?

    /// Authentication strategy. Determines how the plugin connects to the
    /// K8S API server.
    hidden auth: Auth

    fixed Type: String = type
    fixed DefaultNamespace: String? = defaultNamespace
    fixed HasLoadBalancer: Boolean? = hasLoadBalancer
    fixed Auth: Auth = auth
  }

  // =============================================================================
  // Auth Strategies
  // =============================================================================

  /// Base class for K8S authentication strategies.
  abstract class Auth {
    /// Discriminator field for Go-side deserialization.
    hidden fixed type: String
    fixed Type: String = type
  }

  /// Kubeconfig-based auth. Covers vanilla K8S, dev clusters, and any
  /// pre-configured cluster.
  class KubeconfigAuth extends Auth {
    fixed type = "Kubeconfig"
    hidden context: String?
    hidden kubeconfig: String?
    fixed Context: String? = context
    fixed Kubeconfig: String? = kubeconfig
  }

  /// AWS EKS auth via STS presigned token.
  class EKSAuth extends Auth {
    fixed type = "EKS"
    hidden endpoint: (String|formae.Resolvable)
    hidden certificateAuthority: (String|formae.Resolvable)
    hidden clusterName: (String|formae.Resolvable)
    hidden region: (String|formae.Resolvable)?
    fixed Endpoint: (String|formae.Resolvable) = endpoint
    fixed CertificateAuthority: (String|formae.Resolvable) = certificateAuthority
    fixed ClusterName: (String|formae.Resolvable) = clusterName
    fixed Region: (String|formae.Resolvable)? = region
  }

  /// Google GKE auth via OAuth2 access token.
  class GKEAuth extends Auth {
    fixed type = "GKE"
    hidden endpoint: (String|formae.Resolvable)
    hidden certificateAuthority: (String|formae.Resolvable)
    fixed Endpoint: (String|formae.Resolvable) = endpoint
    fixed CertificateAuthority: (String|formae.Resolvable) = certificateAuthority
  }

  /// Azure AKS auth via Azure AD token.
  class AKSAuth extends Auth {
    fixed type = "AKS"
    hidden endpoint: (String|formae.Resolvable)
    hidden certificateAuthority: (String|formae.Resolvable)
    hidden resourceGroup: (String|formae.Resolvable)?
    hidden clusterName: (String|formae.Resolvable)?
    fixed Endpoint: (String|formae.Resolvable) = endpoint
    fixed CertificateAuthority: (String|formae.Resolvable) = certificateAuthority
    fixed ResourceGroup: (String|formae.Resolvable)? = resourceGroup
    fixed ClusterName: (String|formae.Resolvable)? = clusterName
  }

  /// OVH Managed K8S auth.
  class OVHAuth extends Auth {
    fixed type = "OVH"
    hidden endpoint: (String|formae.Resolvable)
    hidden certificateAuthority: (String|formae.Resolvable)
    hidden serviceName: (String|formae.Resolvable)
    hidden clusterId: (String|formae.Resolvable)
    fixed Endpoint: (String|formae.Resolvable) = endpoint
    fixed CertificateAuthority: (String|formae.Resolvable) = certificateAuthority
    fixed ServiceName: (String|formae.Resolvable) = serviceName
    fixed ClusterId: (String|formae.Resolvable) = clusterId
  }

  /// Oracle OKE auth via OCI session token.
  class OCIAuth extends Auth {
    fixed type = "OCI"
    hidden endpoint: (String|formae.Resolvable)
    hidden certificateAuthority: (String|formae.Resolvable)
    hidden clusterOcid: (String|formae.Resolvable)
    hidden region: (String|formae.Resolvable)?
    fixed Endpoint: (String|formae.Resolvable) = endpoint
    fixed CertificateAuthority: (String|formae.Resolvable) = certificateAuthority
    fixed ClusterOcid: (String|formae.Resolvable) = clusterOcid
    fixed Region: (String|formae.Resolvable)? = region
  }

  """#

local typealiases: String = #"""
  // =============================================================================
  // Annotation aliases for K8S resources
  // =============================================================================

  typealias ResourceHint = formae.ResourceHint
  typealias FieldHint = formae.FieldHint
  typealias SubResourceHint = formae.SubResourceHint

  """#

local objectMetaClass: String = #"""
  // =============================================================================
  // ObjectMeta - Common K8S metadata
  // =============================================================================

  /// Kubernetes ObjectMeta - standard metadata for all K8S resources.
  @SubResourceHint {}
  open class ObjectMeta extends formae.SubResource {
    /// Name must be unique within a namespace.
    @FieldHint { required = true; createOnly = true }
    name: String

    /// Namespace defines the space within which each name must be unique.
    /// Empty for cluster-scoped resources. Accepts resolvable references.
    @FieldHint {}
    namespace: (String|formae.Resolvable)?

    /// Labels are key/value pairs for resource organization.
    @FieldHint {}
    labels: Mapping<String, String>?

    /// Annotations are key/value pairs for arbitrary metadata.
    @FieldHint {}
    annotations: Mapping<String, String>?
  }

  """#

local resourceClass: String = #"""
  // =============================================================================
  // Base Resource class for K8S
  // =============================================================================

  /// Base class for all K8S resources.
  /// Provides common structure: apiVersion, kind, metadata.
  open class Resource extends formae.Resource {
    /// API version of the resource (e.g., "v1", "apps/v1")
    @FieldHint { required = true }
    apiVersion: String

    /// Kind of the resource (e.g., "Namespace", "Pod")
    @FieldHint { required = true }
    kind: String

    /// Standard K8S metadata
    @FieldHint { required = true }
    metadata: ObjectMeta
  }

  """#

local podTemplateMetadataClass: String = #"""

  /// Simplified metadata for pod/job templates (no name/namespace).
  @SubResourceHint {}
  open class PodTemplateMetadata extends formae.SubResource {
    /// Labels for organization
    @FieldHint {}
    labels: Mapping<String, String>?

    /// Annotations for metadata
    @FieldHint {}
    annotations: Mapping<String, String>?
  }

  """#

// =============================================================================
// k8s.pkl Generation — Dynamic Shared Types
// =============================================================================

local sharedTypesSectionHeader: String = #"""
  // =============================================================================
  // Shared Sub-Resource Types
  // =============================================================================
  // These types are defined here (rather than in individual resource modules)
  // so that Formae's PKL extract can resolve them without cross-module imports.

  """#

local sharedTypesCode: String =
  sharedTypeClasses.keys.toList().map((name) ->
    generateSubResourceClass(name, sharedTypeClasses[name], true, "", Set())
  ).join("\n\n")

local generatedK8sPkl: String =
  licenseHeader +
  k8sModuleHeader +
  configClass +
  typealiases +
  objectMetaClass +
  resourceClass +
  sharedTypesSectionHeader +
  sharedTypesCode + "\n" +
  podTemplateMetadataClass

// =============================================================================
// Resource Module Generation
// =============================================================================

/// Generate a Resolvable class for a resource kind.
local function generateResolvableClass(kind: String): String =
  "open class " + kind + "Resolvable extends formae.Resolvable {\n" +
  "  hidden type = module.type\n" +
  "  hidden name: " + kind + "Resolvable = (this) { property = \"metadata.name\" }\n" +
  "}"

/// Generate the @ResourceHint annotation block.
local function generateResourceHint(entry: registry.ResourceEntry): String =
  if (entry.clusterScoped)
    new Listing<String> {
      "@k8s.ResourceHint {"
      "  type = module.type"
      #"  identifier = "\#(entry.identifier)""#
      "  discoverable = true"
      "}"
    }.toList().join("\n")
  else
    new Listing<String> {
      "@k8s.ResourceHint {"
      "  type = module.type"
      #"  identifier = "\#(entry.identifier)""#
      "  discoverable = true"
      #"  parent = "K8S::Core::Namespace""#
      "  listParam = new formae.ListProperty {"
      #"    parentProperty = "metadata.name""#
      #"    listParameter = "namespace""#
      "  }"
      "}"
    }.toList().join("\n")

/// Generate the resource class body (fields inside the class braces).
local function generateResourceClassBody(
  entry: registry.ResourceEntry,
  resMod: reflect.Module
): String =
  let (moduleProps = resMod.moduleClass.properties
    .filter((k, _) -> !resourceSkipProps.contains(k)))
  let (metadataType =
    if (entry.metadataType != null) entry.metadataType
    else "k8s.ObjectMeta")
  let (classBody =
    if (entry.customClassContent != null) entry.customClassContent
    else if (entry.resolvable)
      "  hidden parent = this\n" +
      "  fixed hidden resourceType: String = module.type\n\n" +
      "  hidden res: " + entry.kind + "Resolvable = new {\n" +
      "    label = parent.label\n" +
      "    stack = parent.stack?.label\n" +
      "  }"
    else "  fixed hidden resourceType: String = module.type")
  let (localNames = resMod.classes.keys.toList()
    .filter((n) -> !isExcludedClass(n)).toSet())
  let (extraFieldLines = moduleProps.keys.toList().map((propName) ->
    generateField(propName, moduleProps[propName], entry.kind, false, "k8s.", localNames)
  ))
  classBody + "\n\n" +
  "  @k8s.FieldHint { required = true }\n" +
  "  apiVersion: String = \"" + entry.apiVersion + "\"\n\n" +
  "  @k8s.FieldHint { required = true }\n" +
  "  kind: String = \"" + entry.kind + "\"\n\n" +
  "  @k8s.FieldHint { required = true }\n" +
  "  metadata: " + metadataType +
  (if (extraFieldLines.isEmpty) ""
   else "\n\n" + extraFieldLines.join("\n\n"))

/// Generate local sub-types for a resource module.
/// Excludes classes matching registry exclusion rules (suffixes, explicit names).
local function generateLocalSubTypes(
  resMod: reflect.Module
): String =
  let (classes = resMod.classes)
  let (classNames = classes.keys.toList()
    .filter((name) -> !isExcludedClass(name)))
  let (localNames = classNames.toSet())
  if (classNames.isEmpty) ""
  else "\n\n" + classNames.map((name) ->
    generateSubResourceClass(name, classes[name], false, "k8s.", localNames)
  ).join("\n\n")

/// Generate the NamespaceMetadata class for the Namespace module.
local namespaceMetadataClass: String = #"""


  /// Simplified metadata for Namespace (cluster-scoped, so no namespace field).
  @k8s.SubResourceHint {}
  open class NamespaceMetadata extends formae.SubResource {
    /// Name of the namespace
    @k8s.FieldHint { required = true; createOnly = true }
    name: String

    /// Labels for organization
    @k8s.FieldHint {}
    labels: Mapping<String, String>?

    /// Annotations for metadata
    @k8s.FieldHint {}
    annotations: Mapping<String, String>?
  }
  """#

/// Generate a complete resource module.
local function generateResourceModule(entry: registry.ResourceEntry): String =
  let (resMod = resourceModuleMap[entry.kind])
  let (docComment =
    if (entry.doc != null) "/// " + entry.doc.replaceAll("\n", "\n/// ") + "\n"
    else "")
  let (resolvableContent =
    if (entry.resolvable) "\n" + generateResolvableClass(entry.kind) + "\n"
    else "")
  let (customContent =
    if (entry.customContent != null) "\n" + entry.customContent + "\n"
    else "")
  let (localSubTypes = generateLocalSubTypes(resMod))
  let (extraTypes =
    if (entry.metadataType == "NamespaceMetadata") namespaceMetadataClass
    else "")
  licenseHeader +
  "module " + entry.moduleName + "\n\n" +
  "import \"@formae/formae.pkl\"\n" +
  "import \"../k8s.pkl\"\n\n" +
  "const type = \"" + entry.type + "\"\n" +
  resolvableContent +
  customContent +
  docComment +
  generateResourceHint(entry) + "\n" +
  "open class " + entry.kind + " extends k8s.Resource {\n" +
  generateResourceClassBody(entry, resMod) +
  "\n}" +
  localSubTypes +
  extraTypes +
  "\n"

// =============================================================================
// Output
// =============================================================================

output {
  files {
    ["k8s.pkl"] {
      text = generatedK8sPkl
    }
    for (_i, res in registry.resources) {
      ["\(res.modulePath).pkl"] {
        text = generateResourceModule(res)
      }
    }
  }
}
