// =============================================================================
// Configuration
// =============================================================================

local allProviderDefaultFields: Set<String> =
  registry.resources.toList()
    .flatMap((res) -> res.providerDefaultFields.keys.toList())
    .toSet()

local function providerDefaultValue(field: String): String? =
  registry.resources.toList()
    .filter((res) -> res.providerDefaultFields.containsKey(field) && res.providerDefaultFields[field] != null)
    .map((res) -> res.providerDefaultFields[field])
    .firstOrNull

local allProviderDefaultValues: Mapping<String, String?> = new {
  for (field in allProviderDefaultFields) {
    [field] = providerDefaultValue(field)
  }
}

local excludePropsSet: Set<String> = registry.excludeProperties.toList().toSet()
local excludeClassesSet: Set<String> = registry.excludeClasses.toList().toSet()
local excludeSuffixes: List<String> = registry.excludeClassSuffixes.toList()
local resourceSkipProps: Set<String> =
  excludePropsSet.add("apiVersion").add("kind").add("metadata")

/// Check if a class name should be excluded (by suffix or explicit name).
local function isExcludedClass(name: String): Boolean =
  excludeClassesSet.contains(name)
    || excludeSuffixes.any((suffix) -> name.endsWith(suffix))

// =============================================================================
// Type Resolution
// =============================================================================

/// Extract type name from a ModuleClass's displayUri.
local function nameFromUri(uri: String): String =
  let (segments = uri.split("/"))
  let (last = segments.last)
  last.replaceFirst(".pkl", "")

/// Convert a pkl:reflect type to a formae PKL type string.
/// [isSharedCtx]: true when generating within k8s.pkl (shared types don't need "k8s." prefix).
local function resolveType(t: reflect.Type, isSharedCtx: Boolean, localClassNames: Set<String>): String =
  if (t is reflect.NullableType)
    resolveType(t.member, isSharedCtx, localClassNames) + "?"
  else if (t is reflect.UnionType)
    let (members = t.members.toList().map((m) -> resolveType(m, isSharedCtx, localClassNames)))
    let (unique = members.distinct)
    if (unique.length == 1) unique[0]
    else "(" + unique.join("|") + ")"
  else if (t is reflect.StringLiteralType)
    "String"
  else if (t is reflect.DeclaredType)
    // Handle TypeAlias referents: resolve through to underlying type
    if (t.referent is reflect.TypeAlias)
      let (aliasName = t.referent.name)
      if (registry.typeAliasMap.containsKey(aliasName))
        registry.typeAliasMap[aliasName]
      else
        resolveType((t.referent as reflect.TypeAlias).referent, isSharedCtx, localClassNames)
    else
    let (name = t.referent.name)
    let (tArgs = t.typeArguments.toList())
    if (name == "String" || name == "Boolean" || name == "Int" || name == "Float"
        || name == "Number" || name == "Dynamic" || name == "Any")
      name
    else if (name == "Listing")
      "Listing<" + resolveType(tArgs[0], isSharedCtx, localClassNames) + ">"
    else if (name == "Mapping" || name == "Map")
      "Mapping<" + resolveType(tArgs[0], isSharedCtx, localClassNames) + ", " + resolveType(tArgs[1], isSharedCtx, localClassNames) + ">"
    else if (name == "Set")
      "Listing<" + resolveType(tArgs[0], isSharedCtx, localClassNames) + ">"
    else if (registry.typeAliasMap.containsKey(name))
      registry.typeAliasMap[name]
    else if (name == "ModuleClass")
      let (realName = nameFromUri(t.referent.location.displayUri))
      if (sharedTypeNames.contains(realName))
        if (isSharedCtx) realName else "k8s." + realName
      else
        "Dynamic"
    else
      // Nested class name — local classes take priority over shared types
      if (localClassNames.contains(name))
        name
      else if (sharedTypeNames.contains(name))
        if (isSharedCtx) name else "k8s." + name
      else
        name
  else
    "Dynamic"

// =============================================================================
// Field Generation
// =============================================================================

/// Generate a single field definition with @FieldHint annotation.
local function generateField(
  propName: String,
  prop: reflect.Property,
  className: String,
  isSharedCtx: Boolean,
  hintPrefix: String,
  localClassNames: Set<String>
): String =
  let (overrideKey = className + "." + propName)
  let (hasOvr = registry.fieldOverrides.containsKey(overrideKey))
  let (ovr = if (hasOvr) registry.fieldOverrides[overrideKey] else null)
  let (baseType = resolveType(prop.type, isSharedCtx, localClassNames))
  let (isNullable = prop.type is reflect.NullableType)
  let (resolvableFlag = if (hasOvr) ovr.resolvable else false)
  let (effectiveType =
    if (hasOvr && ovr.typeOverride != null) ovr.typeOverride
    else if (resolvableFlag)
      let (innerType = if (isNullable) baseType.dropLast(1) else baseType)
      "(" + innerType + "|formae.Resolvable)" + (if (isNullable) "?" else "")
    else baseType)
  let (required = !(prop.type is reflect.NullableType))
  let (createOnly = if (hasOvr) ovr.createOnly else false)
  let (hasProviderDefault = allProviderDefaultFields.contains(overrideKey))
  let (updateMethod = if (hasOvr) ovr.updateMethod else null)
  let (indexField = if (hasOvr) ovr.indexField else null)
  let (hintParts = new Listing<String> {
    when (required) { "required = true" }
    when (createOnly) { "createOnly = true" }
    when (hasProviderDefault) { "hasProviderDefault = true" }
    when (updateMethod != null) { #"updateMethod = "\#(updateMethod)""# }
    when (indexField != null) { #"indexField = "\#(indexField)""# }
  })
  let (hintStr =
    if (hintParts.length == 0) "  @\(hintPrefix)FieldHint {}"
    else "  @\(hintPrefix)FieldHint { " + hintParts.toList().join("; ") + " }")
  // Escape PKL keywords used as field names
  let (pklKeywords = Set(
    "abstract", "amends", "as", "class", "else", "extends", "external",
    "false", "fixed", "for", "function", "hidden", "if", "import", "in",
    "is", "let", "local", "module", "new", "nothing", "null", "open",
    "out", "outer", "read", "super", "this", "throw", "trace", "true",
    "typealias", "unknown", "when", "type"
  ))
  let (escapedName = if (pklKeywords.contains(propName)) "`\(propName)`" else propName)
  let (defaultValueExpr =
    if (allProviderDefaultValues.containsKey(overrideKey) && allProviderDefaultValues[overrideKey] != null)
      allProviderDefaultValues[overrideKey]
    else null)
  hintStr + "\n  " + escapedName + ": " + effectiveType +
    (if (defaultValueExpr != null) " = " + defaultValueExpr else "")

// =============================================================================
// Class Generation
// =============================================================================

/// Generate a SubResource class definition from a reflected class.
local function generateSubResourceClass(
  name: String,
  cls: reflect.Class,
  isSharedCtx: Boolean,
  hintPrefix: String,
  localClassNames: Set<String>
): String =
  let (classExcludes =
    if (registry.excludeClassProperties.containsKey(name))
      registry.excludeClassProperties[name].toList().toSet()
    else Set())
  let (props = cls.properties.filter((k, _) ->
    !excludePropsSet.contains(k) && !classExcludes.contains(k)))
  let (fieldLines = props.keys.toList().map((propName) ->
    generateField(propName, props[propName], name, isSharedCtx, hintPrefix, localClassNames)
  ))
  "@\(hintPrefix)SubResourceHint {}\nopen class \(name) extends formae.SubResource {\n" +
  fieldLines.join("\n\n") +
  "\n}"

