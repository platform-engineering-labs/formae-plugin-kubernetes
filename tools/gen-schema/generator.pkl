  ["Pod"] = reflect.Module(k8sPod)
  ["ConfigMap"] = reflect.Module(k8sConfigMap)
  ["Secret"] = reflect.Module(k8sSecret)
  ["ServiceAccount"] = reflect.Module(k8sServiceAccount)
