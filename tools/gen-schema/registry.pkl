// =============================================================================
// Field Overrides
// =============================================================================
// Keyed by "ClassName.fieldName" — applied during code generation.

fieldOverrides: Mapping<String, FieldOverride> = new {
  ["ObjectMeta.name"] = new { createOnly = true }
  ["ObjectMeta.namespace"] = new { resolvable = true }
  ["NamespaceMetadata.name"] = new { createOnly = true }
  ["PodSpec.containers"] = new { updateMethod = "EntitySet"; indexField = "name" }
  ["PodSpec.serviceAccountName"] = new { resolvable = true }
  ["PodSpec.priorityClassName"] = new { resolvable = true }
  ["PodSpec.runtimeClassName"] = new { resolvable = true }
  ["ServiceSpec.ports"] = new { updateMethod = "EntitySet"; indexField = "port" }
  ["LimitRangeSpec.limits"] = new { updateMethod = "EntitySet"; indexField = "type" }
  ["Secret.type"] = new { createOnly = true }
  ["Subject.namespace"] = new { resolvable = true }
  ["IngressSpec.ingressClassName"] = new { resolvable = true }
  ["PersistentVolumeClaimSpec.storageClassName"] = new { resolvable = true }
  ["PersistentVolumeClaimSpec.volumeName"] = new { resolvable = true }
  ["RoleRef.name"] = new { resolvable = true }
  ["CrossVersionObjectReference.name"] = new { resolvable = true }
  // Volume source references
  ["PersistentVolumeClaimVolumeSource.claimName"] = new { resolvable = true }
  ["SecretVolumeSource.secretName"] = new { resolvable = true }
  ["AzureFileVolumeSource.secretName"] = new { resolvable = true }
  ["ConfigMapVolumeSource.name"] = new { resolvable = true }
  // Projection references
  ["ConfigMapProjection.name"] = new { resolvable = true }
  ["SecretProjection.name"] = new { resolvable = true }
  // Env value references
  ["SecretKeySelector.name"] = new { resolvable = true }
  ["ConfigMapKeySelector.name"] = new { resolvable = true }
  // StatefulSet → Service
  ["StatefulSetSpec.serviceName"] = new { resolvable = true }
  // Ingress → Service backend
  ["IngressServiceBackend.name"] = new { resolvable = true }
  // IngressClass parameters
  ["IngressClassParametersReference.name"] = new { resolvable = true }
  ["IngressClassParametersReference.namespace"] = new { resolvable = true }
  // FlowSchema → PriorityLevelConfiguration
  ["PriorityLevelConfigurationReference.name"] = new { resolvable = true }
  ["ServiceAccountSubject.namespace"] = new { resolvable = true }
}

// =============================================================================
// ObjectMeta Configuration
// =============================================================================
// Only these fields from K8S ObjectMeta are included in the formae schema.

objectMetaFields: Listing<String> = new {
  "name"
  "namespace"
  "labels"
  "annotations"
}

// =============================================================================
// Exclusion Rules
// =============================================================================
// Controls which properties and classes are excluded from generated schemas.
// All of these target read-only, server-managed data that users never set.

/// Properties excluded from ALL generated types (global).
excludeProperties: Listing<String> = new {
  "status"
  "uid"
  "resourceVersion"
  "creationTimestamp"
  "generation"
  "managedFields"
  "selfLink"
  "deletionTimestamp"
  "deletionGracePeriodSeconds"
  "finalizers"
  "ownerReferences"
  "generateName"
}

/// Properties excluded from specific classes.
/// Keyed by class name, values are field names to drop.
excludeClassProperties: Mapping<String, Listing<String>> = new {
}

/// Class name suffixes to exclude from local sub-types.
/// Classes ending with any of these are read-only server-managed types
/// (e.g., PodStatus, DeploymentCondition, HorizontalPodAutoscalerStatus).
excludeClassSuffixes: Listing<String> = new {
  "Status"
  "Condition"
}

/// Explicit class names to exclude from local sub-types.
/// For status-related classes with non-standard names that don't match
/// the suffix patterns above.
excludeClasses: Listing<String> = new {
  "IngressLoadBalancerIngress"
}

// =============================================================================
// K8S Type Alias Mappings
// =============================================================================
// Maps pkl-k8s type alias names to formae PKL type names.

typeAliasMap: Mapping<String, String> = new {
  ["Int32"] = "Int"
  ["Int64"] = "Int"
  ["Quantity"] = "String"
  ["Time"] = "String"
  ["MicroTime"] = "String"
  ["PortNumber"] = "Int"
  ["PortName"] = "String"
  ["Rfc1035Label"] = "String"
  ["Rfc1123Label"] = "String"
  ["QualifiedName"] = "String"
  ["RawExtension"] = "Dynamic"
}
