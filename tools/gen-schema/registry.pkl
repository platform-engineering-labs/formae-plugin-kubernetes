module registry

/// A formae resource to generate from a pkl-k8s source.
class ResourceEntry {
  /// Formae resource type (e.g., "K8S::Apps::Deployment")
  type: String

  /// Output module path relative to schema/pkl/ (e.g., "apps/Deployment")
  modulePath: String

  /// PKL module name (lowercase, e.g., "deployment")
  moduleName: String

  /// K8S API version (e.g., "apps/v1")
  apiVersion: String

  /// K8S kind (e.g., "Deployment")
  kind: String

  /// JSONPath identifier (default: "$.metadata.uid")
  identifier: String = "$.metadata.name"

  /// Whether cluster-scoped (no parent/listParam)
  clusterScoped: Boolean = false

  /// Custom metadata type name (e.g., "NamespaceMetadata" for Namespace)
  metadataType: String?

  /// Raw PKL content before the resource class
  customContent: String?

  /// Custom class body content (replaces default `fixed hidden resourceType` line)
  customClassContent: String?

  /// Whether to generate a Resolvable class for this resource.
  /// Default true — all resources get a <Kind>Resolvable class and `res` field.
  resolvable: Boolean = true

  /// Resource doc comment
  doc: String?

  /// Fields that receive default values from the K8S API server.
  /// Key: "ClassName.fieldName". Value: PKL default expression, or null if ambiguous/complex.
  providerDefaultFields: Mapping<String, String?> = new {}
}

/// Field-level override keyed by "ClassName.fieldName"
class FieldOverride {
  createOnly: Boolean = false
  resolvable: Boolean = false
  updateMethod: String?
  indexField: String?
  typeOverride: String?
}

// =============================================================================
// Provider Default Field Groups
// =============================================================================

/// Provider-default fields for resources containing PodSpec (Pod, Deployment, etc.)
local podSpecProviderDefaults: Mapping<String, String?> = new {
  ["Container.imagePullPolicy"] = null              // depends on image tag
  ["Container.terminationMessagePath"] = #""/dev/termination-log""#
  ["Container.terminationMessagePolicy"] = #""File""#
  ["Container.resources"] = null                    // complex object
  ["ContainerPort.protocol"] = #""TCP""#
  ["PodSpec.restartPolicy"] = #""Always""#
  ["PodSpec.dnsPolicy"] = #""ClusterFirst""#
  ["PodSpec.terminationGracePeriodSeconds"] = "30"
  ["PodSpec.schedulerName"] = #""default-scheduler""#
  ["PodSpec.securityContext"] = null                // complex object
  ["SecretVolumeSource.defaultMode"] = "420"
  ["ConfigMapVolumeSource.defaultMode"] = "420"
  ["ProjectedVolumeSource.defaultMode"] = "420"
  ["DownwardAPIVolumeSource.defaultMode"] = "420"
}

