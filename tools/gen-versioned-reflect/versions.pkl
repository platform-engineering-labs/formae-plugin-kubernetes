/// Supported Kubernetes minor versions for which per-version PKL schema
/// trees are generated by `make generate-versioned-schemas`.
///
/// Edit this list to add or drop versions. Each entry produces a
/// `schema/pkl/v<version>/` directory under the master tree.
///
/// CNCF support window: keep the four most recent GA K8s minors.
/// Update in lockstep with the `client-go` dependency in `go.mod`.

versions: Listing<String> = new {
  "1.21"
  "1.22"
  "1.23"
  "1.24"
  "1.25"
  "1.26"
  "1.27"
  "1.28"
  "1.29"
  "1.30"
  "1.31"
  "1.32"
  "1.33"
  "1.34"
}

output {
  text = versions.join("\n")
}
